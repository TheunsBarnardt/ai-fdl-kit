{
  "feature": "currency-derivatives-eod-data-delivery",
  "version": "1.0.0",
  "description": "End-of-day currency derivatives data delivery via FTP — fixed-width flat files covering daily statistics, MTM, rates, close-out, and risk parameters",
  "category": "trading",
  "tags": [
    "market-data",
    "eod",
    "currency-derivatives",
    "forex",
    "ftp",
    "dissemination",
    "fixed-width",
    "non-live",
    "mtm"
  ],
  "actors": [
    {
      "id": "data_subscriber",
      "name": "Data Subscriber",
      "type": "human",
      "description": "Licensed recipient who receives end-of-day currency derivatives data files"
    },
    {
      "id": "exchange_operations",
      "name": "Exchange Operations",
      "type": "system",
      "description": "Exchange dissemination system that generates and delivers EOD files"
    },
    {
      "id": "customer_services",
      "name": "Customer Services",
      "type": "human",
      "description": "Provisions subscriber credentials and dataset access before go-live"
    }
  ],
