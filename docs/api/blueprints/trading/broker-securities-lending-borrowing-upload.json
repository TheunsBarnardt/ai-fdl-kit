        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "header_validation",
          "permission": "autonomous"
        },
        {
          "action": "open_securities_loan",
          "permission": "autonomous"
        },
        {
          "action": "pledge_collateral",
          "permission": "autonomous"
        },
        {
          "action": "return_securities_loan",
          "permission": "autonomous"
        },
        {
          "action": "release_collateral",
          "permission": "autonomous"
        },
        {
          "action": "mark_to_market_collateral",
          "permission": "autonomous"
        },
        {
          "action": "margin_call",
          "permission": "autonomous"
        },
        {
          "action": "accrue_lending_fee",
          "permission": "autonomous"
        },
