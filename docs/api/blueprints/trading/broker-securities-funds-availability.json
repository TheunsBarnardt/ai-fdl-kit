          "permission": "autonomous"
        },
        {
          "action": "pre_trade_insufficient_securities",
          "permission": "autonomous"
        },
        {
          "action": "trading_limit_exceeded",
          "permission": "autonomous"
        },
        {
          "action": "real_time_position_lookup",
          "permission": "autonomous"
        },
        {
          "action": "settlement_cycle_batch_run",
          "permission": "autonomous"
        },
        {
          "action": "override_failed_check",
          "permission": "supervised"
