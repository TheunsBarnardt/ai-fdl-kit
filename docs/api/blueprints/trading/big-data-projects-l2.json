{
  "feature": "big-data-projects-l2",
  "version": "1.0.0",
  "description": "Execute a big-data analysis project — data preparation and wrangling, feature selection and engineering, model training, and performance evaluation for structured and unstructured data",
  "category": "trading",
  "tags": [
    "quant",
    "big-data",
    "data-wrangling",
    "feature-engineering",
    "model-training",
    "cfa-level-2"
  ],
  "aliases": [
    "data-analysis-project-l2",
    "data-wrangling-cfa",
    "feature-selection-engineering",
    "text-preparation-cleansing",
    "text-wrangling-preprocessing",
    "structured-unstructured-data"
  ],
  "actors": [
    {
      "id": "data_pipeline",
      "name": "Data Pipeline",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "project_id",
      "type": "text",
      "required": true,
      "label": "Project identifier"
    },
    {
      "name": "data_type",
      "type": "select",
      "required": true,
      "label": "structured | unstructured"
    }
  ],
  "rules": {
    "project_steps": {
      "conceptualisation": "Define problem and target variable",
      "data_collection": "Identify sources, ingest",
      "preparation_wrangling": "Clean, transform, integrate",
      "exploration": "EDA, feature selection, feature engineering",
      "model_training": "Method selection, performance evaluation, tuning",
      "results_interpretation": "Communicate insights to stakeholders"
    },
    "structured_data_prep": {
      "cleansing": "Handle missing, invalid, duplicate, inconsistent observations",
      "wrangling": "Extract, aggregate, filter, normalise/standardise"
    },
    "unstructured_text_prep": {
      "cleansing": "Remove HTML tags, punctuation, numbers; case normalisation",
      "wrangling": "Tokenisation, stemming, lemmatisation, stop-word removal, n-gram creation",
      "representation": "Bag-of-words, TF-IDF, word embeddings"
    },
    "feature_selection": {
      "purpose": "Reduce dimensionality, remove noise, prevent overfitting",
      "methods": "Filter (chi-sq, correlation), wrapper (forward/backward), embedded (Lasso)"
    },
    "feature_engineering": {
      "transformations": "Log, square, polynomial, interactions",
      "one_hot_encoding": "Convert categorical to binary indicator columns"
    },
    "model_training": {
      "method_selection": "Match algorithm to problem (regression vs classification, linear vs non-linear)",
      "performance_metrics": "Accuracy, precision, recall, F1, AUC for classification; RMSE, MAE for regression",
      "confusion_matrix": "TP/FP/TN/FN tabulation",
      "tuning": "Grid search or random search with cross-validation"
    },
    "validation": {
      "project_required": "project_id present",
      "valid_data_type": "data_type in [structured, unstructured]"
    }
  },
  "outcomes": {
    "execute_project": {
      "priority": 1,
      "description": "Execute big-data analysis project",
      "given": [
        {
          "field": "project_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "data_type",
          "source": "input",
          "operator": "in",
          "value": [
            "structured",
            "unstructured"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "data_pipeline"
        },
        {
          "action": "emit_event",
          "event": "bigdata.project_executed"
        }
      ]
    },
    "invalid_data_type": {
      "priority": 10,
      "description": "Unsupported data type",
      "given": [
        {
          "field": "data_type",
          "source": "input",
          "operator": "not_in",
          "value": [
            "structured",
            "unstructured"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "bigdata.project_rejected"
        }
      ],
      "error": "BIGDATA_INVALID_DATA_TYPE"
    }
  },
  "errors": [
    {
      "code": "BIGDATA_INVALID_DATA_TYPE",
      "status": 400,
      "message": "data_type must be structured or unstructured"
    }
  ],
  "events": [
    {
      "name": "bigdata.project_executed",
      "payload": [
        "project_id",
        "data_type",
        "model_score",
        "feature_count"
      ]
    },
    {
      "name": "bigdata.project_rejected",
      "payload": [
        "project_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not skip data quality checks before modelling",
      "why": "Garbage in, garbage out — undetected missingness, outliers, or schema drift produce silent model failure in production"
    },
    {
      "rule": "Do not engineer features after the train/test split",
      "why": "Information from test set leaks into training (target leakage); always fit transformers on training data only"
    },
    {
      "rule": "Do not use accuracy alone on imbalanced classification problems",
      "why": "A 95%-accurate model on a 95/5 imbalance can be a constant predictor; use precision, recall, F1, ROC-AUC, or confusion matrix instead"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/quant/bigdata/project/execute"
    },
    "request": {
      "schema": {
        "project_id": "string",
        "data_type": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "project_id": "string",
          "model_score": "number"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "BIGDATA_INVALID_DATA_TYPE"
        }
      ]
    }
  },
  "related": [
    {
      "feature": "big-data-characteristics",
      "type": "required"
    },
    {
      "feature": "machine-learning-l2",
      "type": "required"
    }
  ]
}