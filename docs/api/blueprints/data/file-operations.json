{
  "feature": "file-operations",
  "version": "1.0.0",
  "description": "Cross-platform file reading and writing",
  "category": "data",
  "tags": [
    "data",
    "godot"
  ],
  "actors": [
    {
      "id": "game_engine",
      "name": "Godot Engine",
      "type": "system"
    }
  ],
  "outcomes": {
    "file_reading": {
      "given": [
        "Read file contents as string or bytes is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Read file contents as string or bytes completed",
      "priority": 1
    },
    "file_writing": {
      "given": [
        "Write data to file with overwrite protection is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Write data to file with overwrite protection completed",
      "priority": 2
    },
    "file_existence": {
      "given": [
        "Check if file exists is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Check if file exists completed",
      "priority": 3
    },
    "file_deletion": {
      "given": [
        "Delete file from disk is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Delete file from disk completed",
      "priority": 4
    },
    "file_properties": {
      "given": [
        "Get file size and modification time is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Get file size and modification time completed",
      "priority": 5
    }
  },
  "rules": {
    "implementation": {
      "description": "Feature implemented in C++ engine core"
    },
    "platform_agnostic": {
      "description": "Works across desktop, web, mobile platforms"
    }
  },
  "related": [],
  "extensions": {
    "tech_stack": {
      "language": "C++",
      "runtime": "Godot 4.x"
    }
  }
}