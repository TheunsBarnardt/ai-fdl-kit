  "rules": {
    "scheduling": [
      "MUST: Allow broker users to schedule dissemination via online request process function",
      "MUST: Support multiple scheduled requests per day per broker",
      "MUST: Allow filtering by branch code, partner code, portfolio indicator, and FATCA flags",
      "MUST: Support download of full daily data set or changes-only (delta) mode depending on data type"
    ],
    "grouping": [
      "MUST: Group related data into distinct Card Codes to isolate business domains",
      "MUST: Allocate General Ledger data to separate dataset from other disseminated data",
      "MUST: Allow end users to select which card codes to download per dataset"
    ],
    "format": [
      "MUST: Use fixed-width card code record format",
      "MUST: Start every dissemination file with Header record (Card Code 000)",
      "MUST: End every dissemination file with Trailer record (Card Code 999)",
      "MUST: Include layout version number in each record"
    ],
    "access_control": [
      "MUST: Verify user has relevant access before scheduling dissemination",
      "MUST: Allow dissemination to member firms and authorized service providers"
    ],
    "frozen_file": [
      "MUST: Support frozen elective event file download via online request process",
      "MUST: Require email address setup before frozen file access",
      "MUST: Provide Header (000), Event Detail (071), Account Detail (072), and Trailer (999) records in frozen file"
    ]
  },
  "errors": [
    {
      "code": "DISSEM_ACCESS_DENIED",
      "status": 403,
      "message": "User does not have access to schedule dissemination"
    },
    {
      "code": "DISSEM_INVALID_SCHEDULE",
      "status": 400,
      "message": "Invalid dissemination schedule parameters"
    },
    {
      "code": "DISSEM_DATASET_NOT_FOUND",
      "status": 404,
      "message": "Requested dataset is not available or not configured"
    },
    {
      "code": "DISSEM_FROZEN_FILE_UNAVAILABLE",
      "status": 404,
      "message": "Elective event frozen file not available for requested date"
    },
    {
      "code": "DISSEM_FILE_GENERATION_FAILED",
      "status": 500,
      "message": "Failed to generate dissemination file"
    }
  ],
  "outcomes": {
    "schedule_dissemination_request": {
      "priority": 1,
      "description": "Broker user schedules a dissemination request via online function",
      "given": [
        {
          "field": "user_has_access",
          "source": "db",
          "operator": "eq",
          "value": true
        },
        {
          "field": "schedule_parameters",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "dissemination_schedule",
          "fields": [
            "broker_code",
            "branch_partner_codes",
            "portfolio_indicator",
            "fatca_flag",
            "card_codes_requested",
            "dataset"
          ]
        },
        {
          "action": "emit_event",
          "event": "broker_dissem.schedule.created"
        }
      ],
      "error": "DISSEM_INVALID_SCHEDULE"
    },
    "generate_eod_dissemination_file": {
      "priority": 2,
      "description": "EOD batch generates dissemination file per scheduled request",
      "given": [
        "EOD batch process triggered",
        "scheduled dissemination request exists"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "dissemination_file",
          "fields": [
            "broker_code",
            "file_name",
            "card_codes",
            "record_count",
            "generation_date"
          ]
        },
        {
          "action": "call_service",
          "target": "ftp_or_online_delivery"
        },
        {
          "action": "emit_event",
          "event": "broker_dissem.file.generated"
        }
      ],
      "error": "DISSEM_FROZEN_FILE_UNAVAILABLE"
    },
    "download_full_vs_changes": {
      "priority": 3,
      "description": "User selects full download or changes-only based on data type",
      "given": [
        {
          "field": "download_mode",
          "source": "input",
          "operator": "in",
          "value": [
            "full",
            "changes"
          ]
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "delta_mode",
          "value": "changes"
        },
        {
          "action": "emit_event",
          "event": "broker_dissem.mode.selected"
        }
      ]
    },
    "download_elective_frozen_file": {
      "priority": 4,
      "description": "User downloads frozen elective events file via online request process",
      "given": [
        {
          "field": "email_configured",
          "source": "db",
          "operator": "eq",
          "value": true
        },
        {
          "field": "dataset_access",
          "source": "db",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "frozen_file_download",
          "fields": [
            "broker_code",
            "event_reference",
            "frozen_date"
          ]
        },
        {
          "action": "emit_event",
          "event": "broker_dissem.frozen_file.delivered"
        }
      ]
    },
    "scheduling_access_denied": {
      "priority": 5,
      "error": "DISSEM_ACCESS_DENIED",
      "description": "User without access attempts to schedule dissemination",
      "given": [
        {
          "field": "user_has_access",
          "source": "db",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "broker_dissem.access_denied"
        }
      ]
    },
    "file_generation_failure": {
      "priority": 6,
      "error": "DISSEM_FILE_GENERATION_FAILED",
      "given": [
        {
          "field": "generation_status",
          "source": "system",
          "operator": "eq",
          "value": "failed"
        }
      ],
      "then": [
        {
          "action": "notify",
          "channel": "operations"
        },
        {
          "action": "emit_event",
          "event": "broker_dissem.generation.failed"
        }
      ]
    }
  },
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_back_office_dissemination",
        "description": "Back-office data dissemination from central broker administration to member firms via fixed-width card code records (accounts, balances, deals, scrip, GL, SLB, elective events)",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "schedule_dissemination_request",
          "permission": "autonomous"
        },
        {
          "action": "generate_eod_dissemination_file",
          "permission": "autonomous"
        },
        {
          "action": "download_full_vs_changes",
          "permission": "supervised"
        },
        {
          "action": "download_elective_frozen_file",
          "permission": "autonomous"
        },
        {
          "action": "scheduling_access_denied",
          "permission": "autonomous"
        },
        {
          "action": "file_generation_failure",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
