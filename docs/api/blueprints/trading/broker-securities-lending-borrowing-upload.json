{
  "feature": "broker-securities-lending-borrowing-upload",
  "version": "1.1.0",
  "description": "Broker securities lending and borrowing upload via fixed-width card-code records for loan open, collateral pledge, confirmation, return, mark-to-market, and margin calls",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "upload",
    "slb",
    "securities-lending",
    "borrowing",
    "collateral",
    "fixed-width",
    "card-codes",
    "mark-to-market",
    "margin-call"
  ],
  "actors": [
    {
      "id": "participating_broker",
      "name": "Participating Broker",
      "type": "external"
    },
    {
      "id": "back_office_system",
      "name": "Back Office System",
      "type": "system"
    },
    {
      "id": "slb_counterparty",
      "name": "SLB Counterparty",
      "type": "external"
    },
    {
      "id": "lending_desk",
      "name": "Lending Desk",
      "type": "human"
    },
    {
      "id": "risk_controller",
      "name": "Risk Controller",
      "type": "human"
    }
  ],
  "fields": [
    {
      "name": "card_code",
      "type": "text",
      "required": true,
      "label": "Card Code"
    },
    {
      "name": "broker_code",
      "type": "text",
      "required": true,
      "label": "Broker Code"
    },
    {
      "name": "upload_date",
      "type": "date",
      "required": true,
      "label": "Upload Date"
    },
    {
      "name": "upload_type",
      "type": "select",
      "required": true,
      "label": "Upload Type",
      "options": [
        {
          "value": "N",
          "label": "New"
        },
        {
          "value": "U",
          "label": "Update"
        },
        {
          "value": "R",
          "label": "Reverse"
        },
        {
          "value": "C",
          "label": "Confirm"
        }
      ]
    },
    {
      "name": "lender_account_code",
      "type": "text",
      "required": false,
      "label": "Lender Account Code"
    },
    {
      "name": "borrower_account_code",
      "type": "text",
      "required": false,
      "label": "Borrower Account Code"
    },
    {
      "name": "loan_deal_id",
      "type": "text",
      "required": false,
      "label": "Loan Deal Id"
    },
    {
      "name": "loan_quantity",
      "type": "number",
      "required": false,
      "label": "Loan Quantity"
    },
    {
      "name": "loan_rate",
      "type": "number",
      "required": false,
      "label": "Loan Rate Percent"
    },
    {
      "name": "borrow_rate",
      "type": "number",
      "required": false,
      "label": "Borrower Rate Percent"
    },
    {
      "name": "loan_collateral_value",
      "type": "number",
      "required": false,
      "label": "Loan Collateral Value"
    },
    {
      "name": "collateral_type",
      "type": "select",
      "required": false,
      "label": "Collateral Type",
      "options": [
        {
          "value": "S",
          "label": "Securities"
        },
        {
          "value": "C",
          "label": "Cash"
        },
        {
          "value": " ",
          "label": "None"
        }
      ]
    },
    {
      "name": "collateral_quantity",
      "type": "number",
      "required": false,
      "label": "Collateral Quantity"
    },
    {
      "name": "instrument_type",
      "type": "text",
      "required": false,
      "label": "Instrument Type"
    },
    {
      "name": "instrument_alpha",
      "type": "text",
      "required": false,
      "label": "Instrument Alpha"
    },
    {
      "name": "instrument_version",
      "type": "number",
      "required": false,
      "label": "Instrument Version"
    },
    {
      "name": "receive_date",
      "type": "date",
      "required": false,
      "label": "Receive Date"
    },
    {
      "name": "return_date",
      "type": "date",
      "required": false,
      "label": "Return Date"
    },
    {
      "name": "provide_date",
      "type": "date",
      "required": false,
      "label": "Provide Date"
    },
    {
      "name": "trade_date",
      "type": "date",
      "required": false,
      "label": "Trade Date"
    },
    {
      "name": "return_cash_collateral",
      "type": "select",
      "required": false,
      "label": "Return Cash Collateral",
      "options": [
        {
          "value": "Y",
          "label": "Yes"
        },
        {
          "value": "N",
          "label": "No"
        }
      ]
    },
    {
      "name": "create_swift_message",
      "type": "select",
      "required": false,
      "label": "Create Swift Message",
      "options": [
        {
          "value": "Y",
          "label": "Immediate"
        },
        {
          "value": "N",
          "label": "No"
        },
        {
          "value": "L",
          "label": "Later"
        }
      ]
    },
    {
      "name": "accrued_fee",
      "type": "number",
      "required": false,
      "label": "Accrued Lending Fee"
    },
    {
      "name": "mark_price",
      "type": "number",
      "required": false,
      "label": "Mark-to-Market Price"
    },
    {
      "name": "margin_shortfall",
      "type": "number",
      "required": false,
      "label": "Margin Shortfall"
    }
  ],
  "rules": {
    "submission": [
      "MUST: Support automated upload submission via FTP",
      "MUST: Configure email addresses before allowing upload",
      "MUST: Provide error reporting via common error enquiry functions",
      "MUST: Generate response dataset with per-record response codes",
      "MUST: Archive processed upload files in a retention cycle"
    ],
    "validation": [
      "MUST: Reject entire file if trailer record missing or mismatched",
      "MUST: Reject entire file if broker code on detail differs from header",
      "MUST: Validate loan and collateral deal id uniqueness",
      "MUST: Link collateral records to existing loan deal ids",
      "MUST: Validate counterparty account exists and is active",
      "MUST: Enforce return date not before receive/provide date",
      "MUST: Reject loan rate outside 0-999.99 percent"
    ],
    "format": [
      "MUST: Use fixed-width non-delimited record format",
      "MUST: Start file with Header Record (Card Code 000)",
      "MUST: End file with Trailer Record (Card Code 999)",
      "MUST: Use Layout 025 for loan upload (total length 400)",
      "MUST: Use Layout 026 for collateral upload (total length 400)",
      "MUST: Use Layout 027 for loan confirmation/return (total length 400)",
      "MUST: Use Layout 028 for collateral confirmation/return (total length 400)",
      "MUST: Zero-fill numeric fields when value is absent"
    ],
    "lifecycle": [
      "MUST: Support open-ended and fixed-term loan types",
      "MUST: Allow partial or full return of loans and collateral",
      "MUST: Mark collateral to market and raise margin calls",
      "MUST: Accrue lending fee daily as rate * value * days / 365",
      "MUST: Force-close loans on counterparty default or contractual breach"
    ]
  },
  "errors": [
    {
      "code": "SLB_INVALID_CARD_CODE",
      "status": 422,
      "message": "Card code is invalid"
    },
    {
      "code": "SLB_INVALID_BROKER_CODE",
      "status": 422,
      "message": "Broker code is invalid or inactive"
    },
    {
      "code": "SLB_INVALID_UPLOAD_TYPE",
      "status": 422,
      "message": "Upload type must be N, U, R, C"
    },
    {
      "code": "SLB_INVALID_ACCOUNT_CODE",
      "status": 422,
      "message": "Account code is invalid or not permitted"
    },
    {
      "code": "SLB_INVALID_DEAL_ID",
      "status": 422,
      "message": "Deal id is invalid for upload type"
    },
    {
      "code": "SLB_INVALID_INSTRUMENT",
      "status": 422,
      "message": "Instrument code not loaded or not electronically settled"
    },
    {
      "code": "SLB_INVALID_LOAN_QUANTITY",
      "status": 422,
      "message": "Loan quantity out of range"
    },
    {
      "code": "SLB_INVALID_LOAN_RATE",
      "status": 422,
      "message": "Loan rate must be between 0 and 999.99 percent"
    },
    {
      "code": "SLB_INVALID_COLLATERAL_TYPE",
      "status": 422,
      "message": "Collateral type must be S, C or blank"
    },
    {
      "code": "SLB_RETURN_DATE_BEFORE_RECEIVE",
      "status": 422,
      "message": "Return date may not be before receive date"
    },
    {
      "code": "SLB_TRAILER_MISSING",
      "status": 422,
      "message": "Trailer record not found"
    },
    {
      "code": "SLB_TRAILER_COUNT_MISMATCH",
      "status": 422,
      "message": "Trailer total not same as records sent"
    },
    {
      "code": "SLB_DETAIL_BROKER_MISMATCH",
      "status": 422,
      "message": "Detail broker code not same as header broker code"
    },
    {
      "code": "SLB_RECORD_AFTER_TRAILER",
      "status": 422,
      "message": "Record received after trailer"
    },
    {
      "code": "SLB_DUPLICATE_TRAILER",
      "status": 422,
      "message": "Duplicate trailer received"
    },
    {
      "code": "SLB_COLLATERAL_UNLINKED",
      "status": 422,
      "message": "Collateral record references non-existent loan"
    },
    {
      "code": "SLB_MARGIN_CALL_REQUIRED",
      "status": 422,
      "message": "Collateral value below required margin threshold"
    },
    {
      "code": "SLB_FORCE_CLOSE_REQUIRED",
      "status": 409,
      "message": "Loan must be force-closed due to default or breach"
    },
    {
      "code": "SLB_PROCESSING_FAILED",
      "status": 500,
      "message": "SLB upload processing failed"
    }
  ],
  "events": [
    {
      "name": "slb.loan.opened",
      "payload": [
        "broker_code",
        "loan_deal_id",
        "lender_account_code",
        "borrower_account_code",
        "loan_quantity",
        "loan_rate"
      ]
    },
    {
      "name": "slb.loan.returned",
      "payload": [
        "broker_code",
        "loan_deal_id",
        "return_date",
        "return_quantity"
      ]
    },
    {
      "name": "slb.collateral.pledged",
      "payload": [
        "broker_code",
        "loan_deal_id",
        "collateral_type",
        "collateral_quantity",
        "collateral_value"
      ]
    },
    {
      "name": "slb.collateral.released",
      "payload": [
        "broker_code",
        "loan_deal_id",
        "collateral_quantity"
      ]
    },
    {
      "name": "slb.collateral.marked",
      "payload": [
        "loan_deal_id",
        "mark_price",
        "collateral_value"
      ]
    },
    {
      "name": "slb.margin.call",
      "payload": [
        "loan_deal_id",
        "margin_shortfall"
      ]
    },
    {
      "name": "slb.loan.force_closed",
      "payload": [
        "loan_deal_id",
        "reason"
      ]
    },
    {
      "name": "slb.fee.accrued",
      "payload": [
        "loan_deal_id",
        "accrued_fee",
        "accrual_date"
      ]
    },
    {
      "name": "slb.upload.response_delivered",
      "payload": [
        "broker_code",
        "sequence_number",
        "records_processed",
        "records_rejected"
      ]
    }
  ],
  "outcomes": {
    "header_validation": {
      "priority": 1,
      "description": "Validate header record (Card Code 000)",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "000"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "header_validated",
          "value": true
        },
        {
          "action": "emit_event",
          "event": "slb.upload.response_delivered"
        }
      ],
      "error": "SLB_INVALID_CARD_CODE"
    },
    "open_securities_loan": {
      "priority": 2,
      "description": "Open a new securities loan (Layout 025 with upload type N)",
      "transaction": true,
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "025"
        },
        {
          "field": "upload_type",
          "source": "input",
          "operator": "eq",
          "value": "N"
        },
        {
          "field": "loan_quantity",
          "source": "input",
          "operator": "gt",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_loan"
        },
        {
          "action": "set_field",
          "target": "loan_status",
          "value": "open"
        },
        {
          "action": "emit_event",
          "event": "slb.loan.opened"
        }
      ],
      "error": "SLB_INVALID_LOAN_QUANTITY"
    },
    "pledge_collateral": {
      "priority": 3,
      "description": "Pledge cash or securities collateral against a loan (Layout 026)",
      "transaction": true,
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "026"
        },
        {
          "field": "upload_type",
          "source": "input",
          "operator": "eq",
          "value": "N"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_collateral"
        },
        {
          "action": "set_field",
          "target": "collateral_status",
          "value": "posted"
        },
        {
          "action": "emit_event",
          "event": "slb.collateral.pledged"
        }
      ],
      "error": "SLB_COLLATERAL_UNLINKED"
    },
    "return_securities_loan": {
      "priority": 4,
      "description": "Confirm or return an open securities loan (Layout 027)",
      "transaction": true,
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "027"
        },
        {
          "field": "upload_type",
          "source": "input",
          "operator": "in",
          "value": [
            "C",
            "R"
          ]
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "loan_status",
          "from": "open",
          "to": "returned"
        },
        {
          "action": "emit_event",
          "event": "slb.loan.returned"
        }
      ]
    },
    "release_collateral": {
      "priority": 5,
      "description": "Confirm or release collateral (Layout 028)",
      "transaction": true,
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "028"
        },
        {
          "field": "upload_type",
          "source": "input",
          "operator": "in",
          "value": [
            "C",
            "R"
          ]
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "collateral_status",
          "from": "posted",
          "to": "released"
        },
        {
          "action": "emit_event",
          "event": "slb.collateral.released"
        }
      ]
    },
    "mark_to_market_collateral": {
      "priority": 6,
      "description": "Revalue collateral at current mark price and compute exposure",
      "given": [
        {
          "field": "loan_status",
          "source": "db",
          "operator": "eq",
          "value": "open"
        },
        {
          "field": "mark_price",
          "source": "input",
          "operator": "gt",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "collateral_value",
          "value": "mark_price_times_quantity"
        },
        {
          "action": "emit_event",
          "event": "slb.collateral.marked"
        }
      ]
    },
    "margin_call": {
      "priority": 7,
      "description": "Raise margin call when collateral value falls below required threshold",
      "given": [
        {
          "field": "collateral_value",
          "source": "computed",
          "operator": "lt",
          "value": "required_margin"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "margin_call_raised",
          "value": true
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "slb.margin.call"
        }
      ],
      "error": "SLB_MARGIN_CALL_REQUIRED"
    },
    "accrue_lending_fee": {
      "priority": 8,
      "description": "Daily fee accrual as loan_rate * loan_value * days / 365",
      "given": [
        {
          "field": "loan_status",
          "source": "db",
          "operator": "eq",
          "value": "open"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "accrued_fee",
          "value": "loan_rate_times_value_times_days_over_365"
        },
        {
          "action": "emit_event",
          "event": "slb.fee.accrued"
        }
      ]
    },
    "force_close_loan": {
      "priority": 9,
      "description": "Force close loan on counterparty default or unmet margin call",
      "transaction": true,
      "given": [
        {
          "any": [
            {
              "field": "margin_call_unmet",
              "source": "db",
              "operator": "eq",
              "value": true
            },
            {
              "field": "counterparty_default",
              "source": "db",
              "operator": "eq",
              "value": true
            }
          ]
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "loan_status",
          "from": "open",
          "to": "force_closed"
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "slb.loan.force_closed"
        }
      ],
      "error": "SLB_FORCE_CLOSE_REQUIRED"
    },
    "trailer_validation": {
      "priority": 10,
      "description": "Validate trailer record counts against records sent",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "999"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "slb.upload.response_delivered"
        }
      ],
      "error": "SLB_TRAILER_COUNT_MISMATCH"
    },
    "generate_response_dataset": {
      "priority": 11,
      "description": "Generate SLB upload response dataset with per-record codes",
      "given": [
        {
          "field": "processing_complete",
          "source": "computed",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_response_dataset"
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "slb.upload.response_delivered"
        }
      ]
    }
  },
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_securities_lending_borrowing_upload",
        "description": "Broker securities lending and borrowing upload via fixed-width card-code records for loan open, collateral pledge, confirmation, return, mark-to-market, and margin calls",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
