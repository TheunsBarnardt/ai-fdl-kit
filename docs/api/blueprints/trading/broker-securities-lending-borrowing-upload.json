{
  "feature": "broker-securities-lending-borrowing-upload",
  "version": "1.0.0",
  "description": "Broker securities lending and borrowing (SLB) upload to central back-office via fixed-width records for loan, collateral, loan confirmation/return, and collateral confirmation/return",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "upload",
    "slb",
    "securities-lending",
    "borrowing",
    "collateral",
    "fixed-width",
    "card-codes"
  ],
  "actors": [
    {
      "id": "participating_broker",
      "name": "Participating Broker",
      "type": "external"
    },
    {
      "id": "back_office_system",
      "name": "Back Office System",
      "type": "system"
    },
    {
      "id": "slb_counterparty",
      "name": "SLB Counterparty",
      "type": "external",
      "description": "Lending or borrowing counterparty"
    }
  ],
  "fields": [
    {
      "name": "card_code",
      "type": "text",
      "required": true
    },
    {
      "name": "broker_code",
      "type": "text",
      "required": true
    },
    {
      "name": "upload_date",
      "type": "date",
      "required": true
    },
    {
      "name": "loan_reference",
      "type": "text",
      "required": false
    },
    {
      "name": "loan_trade_date",
      "type": "date",
      "required": false
    },
    {
      "name": "loan_start_date",
      "type": "date",
      "required": false
    },
    {
      "name": "loan_end_date",
      "type": "date",
      "required": false
    },
    {
      "name": "loan_account_code",
      "type": "text",
      "required": false
    },
    {
      "name": "loan_instrument_code",
      "type": "text",
      "required": false
    },
    {
      "name": "loan_isin",
      "type": "text",
      "required": false
    },
    {
      "name": "loan_quantity",
      "type": "number",
      "required": false
    },
    {
      "name": "loan_rate",
      "type": "number",
      "required": false
    },
    {
      "name": "loan_fee",
      "type": "number",
      "required": false
    },
    {
      "name": "loan_counterparty",
      "type": "text",
      "required": false
    },
    {
      "name": "loan_type",
      "type": "select",
      "required": false
    },
    {
      "name": "loan_direction",
      "type": "select",
      "required": false
    },
    {
      "name": "collateral_reference",
      "type": "text",
      "required": false
    },
    {
      "name": "collateral_trade_date",
      "type": "date",
      "required": false
    },
    {
      "name": "collateral_type",
      "type": "select",
      "required": false
    },
    {
      "name": "collateral_instrument",
      "type": "text",
      "required": false
    },
    {
      "name": "collateral_quantity",
      "type": "number",
      "required": false
    },
    {
      "name": "collateral_value",
      "type": "number",
      "required": false
    },
    {
      "name": "collateral_currency",
      "type": "text",
      "required": false
    },
    {
      "name": "collateral_haircut",
      "type": "number",
      "required": false
    },
    {
      "name": "collateral_linked_loan_reference",
      "type": "text",
      "required": false
    },
    {
      "name": "confirmation_type",
      "type": "select",
      "required": false
    },
    {
      "name": "confirmation_date",
      "type": "date",
      "required": false
    },
    {
      "name": "return_quantity",
      "type": "number",
      "required": false
    },
    {
      "name": "return_amount",
      "type": "number",
      "required": false
    },
    {
      "name": "collateral_confirmation_type",
      "type": "select",
      "required": false
    },
    {
      "name": "collateral_return_quantity",
      "type": "number",
      "required": false
    },
    {
      "name": "collateral_return_value",
      "type": "number",
      "required": false
    }
  ],
  "rules": {
    "submission": [
      "MUST: Support automated upload submission via FTP",
      "MUST: Configure email addresses before allowing upload",
      "MUST: Provide error reporting via COMPR and PCOMPR functions",
      "MUST: Generate response dataset with per-record response codes",
      "MUST: Archive processed upload files"
    ],
    "validation": [
      "MUST: Validate loan and collateral reference uniqueness",
      "MUST: Link collateral records to existing loan references",
      "MUST: Validate trade date is within acceptable window",
      "MUST: Validate counterparty exists in master data"
    ],
    "format": [
      "MUST: Use fixed-width card code record format",
      "MUST: Start file with Header Record (Card Code 000)",
      "MUST: End file with Trailer Record (Card Code 999)",
      "MUST: Use Layout 025 for loan upload",
      "MUST: Use Layout 026 for collateral upload",
      "MUST: Use Layout 027 for loan confirmation/return",
      "MUST: Use Layout 028 for collateral confirmation/return"
    ],
    "lifecycle": [
      "MUST: Support open-ended and fixed-term loan types",
      "MUST: Allow partial or full return of loans and collateral",
      "MUST: Update loan status on confirmation and return"
    ]
  },
  "errors": [
    {
      "code": "SLB_UPLOAD_INVALID_LOAN_REF",
      "status": 422,
      "message": "Loan reference is invalid or duplicate"
    },
    {
      "code": "SLB_UPLOAD_COLLATERAL_NOT_LINKED",
      "status": 422,
      "message": "Collateral record references non-existent loan"
    },
    {
      "code": "SLB_UPLOAD_INVALID_COUNTERPARTY",
      "status": 422,
      "message": "SLB counterparty not found in master data"
    },
    {
      "code": "SLB_UPLOAD_INSTRUMENT_NOT_FOUND",
      "status": 422,
      "message": "Referenced instrument does not exist"
    },
    {
      "code": "SLB_UPLOAD_PROCESSING_FAILED",
      "status": 500,
      "message": "SLB upload processing failed"
    }
  ],
  "outcomes": {
    "automated_loan_upload": {
      "priority": 1,
      "description": "Broker submits loan upload records (Layout 025)",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "025"
        },
        {
          "field": "email_configured",
          "source": "db",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_loan_upload",
          "fields": [
            "broker_code",
            "loan_reference",
            "counterparty",
            "quantity",
            "rate"
          ]
        },
        {
          "action": "emit_event",
          "event": "slb_upload.loan.received"
        }
      ]
    },
    "automated_collateral_upload": {
      "priority": 2,
      "description": "Broker submits collateral upload records (Layout 026)",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "026"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_collateral_upload"
        },
        {
          "action": "emit_event",
          "event": "slb_upload.collateral.received"
        }
      ]
    },
    "loan_confirmation_return": {
      "priority": 3,
      "description": "Broker submits loan confirmation or return (Layout 027)",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "027"
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "loan_status",
          "from": "open",
          "to": "confirmed_or_returned"
        },
        {
          "action": "emit_event",
          "event": "slb_upload.loan.confirmed"
        }
      ]
    },
    "collateral_confirmation_return": {
      "priority": 4,
      "description": "Broker submits collateral confirmation or return (Layout 028)",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "028"
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "collateral_status",
          "from": "posted",
          "to": "confirmed_or_returned"
        },
        {
          "action": "emit_event",
          "event": "slb_upload.collateral.confirmed"
        }
      ]
    },
    "validate_collateral_link": {
      "priority": 5,
      "description": "Validate collateral record is linked to existing loan",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "026"
        },
        {
          "field": "collateral_linked_loan_exists",
          "source": "computed",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "slb_upload.collateral.unlinked"
        }
      ]
    },
    "generate_response_dataset": {
      "priority": 6,
      "description": "Generate SLB upload response dataset",
      "given": [
        "upload processing complete"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "slb_response_dataset"
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "slb_upload.response.delivered"
        }
      ]
    }
  },
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_securities_lending_borrowing_upload",
        "description": "Broker securities lending and borrowing (SLB) upload to central back-office via fixed-width records for loan, collateral, loan confirmation/return, and collateral confirmation/return",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "automated_loan_upload",
          "permission": "autonomous"
        },
        {
          "action": "automated_collateral_upload",
          "permission": "autonomous"
        },
        {
          "action": "loan_confirmation_return",
          "permission": "autonomous"
        },
        {
          "action": "collateral_confirmation_return",
          "permission": "autonomous"
        },
        {
          "action": "validate_collateral_link",
          "permission": "autonomous"
        },
        {
          "action": "generate_response_dataset",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
  "extensions": {
    "card_codes": {
      "999": {
        "name": "Trailer Record"
      },
      "000": {
        "name": "Header Record"
      },
      "025": {
        "name": "Loan Upload Record",
        "purpose": "Create new securities lending/borrowing loan"
      },
      "026": {
        "name": "Collateral Upload Record",
        "purpose": "Post collateral against loan"
      },
      "027": {
        "name": "Loan Confirmation/Return Record",
        "purpose": "Confirm or return existing loan"
      },
      "028": {
        "name": "Collateral Confirmation/Return Record",
        "purpose": "Confirm or return posted collateral"
      }
    },
    "loan_types": [
      "Open (no fixed end date)",
      "Term (fixed end date)",
      "Call (callable on demand)"
    ],
    "collateral_types": [
      "Cash",
      "Securities"
    ],
    "lifecycle_states": {
      "loan": [
        "open",
        "confirmed",
        "returned",
        "cancelled"
      ],
      "collateral": [
        "posted",
        "confirmed",
        "returned",
        "cancelled"
      ]
    },
    "workflow": [
      "1. Email address set-up",
      "2. Loan upload (Layout 025)",
      "3. Collateral upload (Layout 026)",
      "4. Loan confirmation/return (Layout 027)",
      "5. Collateral confirmation/return (Layout 028)",
      "6. Response dataset and archiving"
    ]
  },
  "related": [
    {
      "feature": "broker-back-office-dissemination",
      "type": "recommended"
    },
    {
      "feature": "broker-deal-management-upload",
      "type": "optional"
    },
    {
      "feature": "broker-client-data-upload",
      "type": "optional"
    }
  ]
}