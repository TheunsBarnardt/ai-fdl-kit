{
  "feature": "money-market-eod-data-delivery",
  "version": "1.0.0",
  "description": "End-of-day money market instrument reference data delivery via FTP — ISIN reference, coupon resets, payment dates, and intraday priority updates",
  "category": "trading",
  "tags": [
    "market-data",
    "eod",
    "money-market",
    "isin",
    "reference-data",
    "ftp",
    "dissemination",
    "fixed-width",
    "non-live"
  ],
  "actors": [
    {
      "id": "data_subscriber",
      "name": "Data Subscriber",
      "type": "human",
      "description": "Licensed recipient who receives money market instrument data files"
    },
    {
      "id": "exchange_operations",
      "name": "Exchange Operations",
      "type": "system",
      "description": "National Numbering Agent system that issues ISINs and generates data files"
    },
    {
      "id": "customer_services",
      "name": "Customer Services",
      "type": "human",
      "description": "Provisions subscriber credentials and dataset access"
    }
  ],
