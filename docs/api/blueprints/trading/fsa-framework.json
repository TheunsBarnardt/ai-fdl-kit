{
  "feature": "fsa-framework",
  "version": "1.0.0",
  "description": "Apply a six-step financial statement analysis framework — purpose, data collection, processing, analysis, communication, follow-up — using regulated and supplementary information sources",
  "category": "trading",
  "tags": [
    "financial-statement-analysis",
    "fsa-framework",
    "ifrs",
    "us-gaap",
    "mdna",
    "audit-report",
    "cfa-level-1"
  ],
  "aliases": [
    "financial-statement-analysis-framework",
    "fsa-process",
    "ifrs-vs-gaap",
    "management-discussion",
    "auditor-opinion",
    "segment-reporting"
  ],
  "actors": [
    {
      "id": "fsa_analyst",
      "name": "Financial Statement Analyst",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "analysis_id",
      "type": "text",
      "required": true,
      "label": "Analysis identifier"
    },
    {
      "name": "purpose",
      "type": "text",
      "required": true,
      "label": "Analysis purpose and context"
    },
    {
      "name": "reporting_framework",
      "type": "select",
      "required": false,
      "label": "ifrs | us_gaap | other"
    }
  ],
  "rules": {
    "framework_steps": {
      "purpose": "Articulate purpose and context",
      "collect": "Collect financial and non-financial data",
      "process": "Adjust, restate, standardise",
      "analyze": "Ratios, common-size, trend, peer comparison",
      "communicate": "Report findings with recommendations",
      "follow_up": "Update conclusions with new data"
    },
    "regulated_sources": {
      "iosco": "Global principles for securities regulation",
      "sec": "US 10-K, 10-Q, 8-K, proxies, registration statements",
      "europe": "IFRS-based annual and interim reports",
      "notes": "Disclosures on accounting choices, estimates",
      "segment_reporting": "Business and geographic",
      "mdna": "Management commentary on performance and prospects",
      "auditor_report": "Unqualified, qualified, adverse, disclaimer"
    },
    "ifrs_vs_gaap": {
      "convergence": "Many standards aligned (revenue, leases) but differences remain",
      "examples": "LIFO allowed under US GAAP but not IFRS; development cost capitalisation differs"
    },
    "other_sources": [
      "Industry data, peer filings, analyst reports",
      "News, earnings calls, investor presentations",
      "Alternative data — satellite, web traffic, shipping"
    ],
    "validation": {
      "purpose_required": "purpose present",
      "analysis_id_required": "analysis_id present"
    }
  },
  "outcomes": {
    "start_analysis": {
      "priority": 1,
      "description": "Kick off FSA pipeline",
      "given": [
        {
          "field": "analysis_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "purpose",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "fsa_analyst"
        },
        {
          "action": "emit_event",
          "event": "fsa.analysis_started"
        }
      ]
    },
    "missing_inputs": {
      "priority": 10,
      "description": "Missing required inputs",
      "given": [
        {
          "any": [
            {
              "field": "analysis_id",
              "source": "input",
              "operator": "not_exists"
            },
            {
              "field": "purpose",
              "source": "input",
              "operator": "not_exists"
            }
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "fsa.analysis_rejected"
        }
      ],
      "error": "FSA_MISSING_INPUTS"
    }
  },
  "errors": [
    {
      "code": "FSA_MISSING_INPUTS",
      "status": 400,
      "message": "analysis_id and purpose are required"
    }
  ],
  "events": [
    {
      "name": "fsa.analysis_started",
      "payload": [
        "analysis_id",
        "purpose",
        "reporting_framework",
        "data_sources"
      ]
    },
    {
      "name": "fsa.analysis_rejected",
      "payload": [
        "analysis_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not start analysis without a defined purpose",
      "why": "Analytical focus determines which ratios, adjustments, and comparisons matter; context-free FSA yields generic output"
    },
    {
      "rule": "Do not rely on the primary statements alone",
      "why": "Notes, MD&A, and auditor opinions often contain the most material disclosures"
    },
    {
      "rule": "Do not assume auditor reports guarantee accuracy",
      "why": "Unqualified opinions have limits; frauds (Enron, Wirecard) have passed audit scrutiny"
    },
    {
      "rule": "Do not ignore accounting framework differences",
      "why": "IFRS and US GAAP treatments of leases, inventory, R&D, and taxes produce different ratios"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/fsa/framework/start"
    },
    "request": {
      "schema": {
        "analysis_id": "string",
        "purpose": "string",
        "reporting_framework": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "analysis_id": "string",
          "status": "string",
          "next_step": "string"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "FSA_MISSING_INPUTS"
        }
      ]
    }
  },
  "related": [
    {
      "feature": "fsa-income-statement",
      "type": "recommended"
    },
    {
      "feature": "fsa-balance-sheet",
      "type": "recommended"
    },
    {
      "feature": "fsa-cash-flow",
      "type": "recommended"
    }
  ]
}