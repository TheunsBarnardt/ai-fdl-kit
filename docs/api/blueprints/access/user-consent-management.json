{
  "feature": "user-consent-management",
  "version": "1.0.0",
  "description": "OAuth/OIDC consent tracking and enforcement",
  "category": "access",
  "tags": [
    "consent",
    "oauth2"
  ],
  "fields": [
    {
      "name": "client_id",
      "type": "text",
      "required": true,
      "label": "Client ID",
      "validation": [
        {
          "type": "required",
          "message": "Client ID required"
        }
      ]
    },
    {
      "name": "scope",
      "type": "text",
      "required": true,
      "label": "Scope",
      "validation": [
        {
          "type": "required",
          "message": "Scope required"
        }
      ]
    }
  ],
  "rules": {
    "core": "Consent enforcement"
  },
  "outcomes": {
    "consent_granted": {
      "priority": 5,
      "given": [
        {
          "field": "client_id",
          "operator": "exists",
          "value": null
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "consent.granted",
          "payload": [
            "client_id"
          ]
        }
      ],
      "result": "Consent recorded"
    }
  },
  "errors": [
    {
      "code": "CONSENT_DENIED",
      "status": 403,
      "message": "Consent denied"
    }
  ],
  "events": [
    {
      "name": "consent.granted",
      "description": "Consent granted",
      "payload": [
        "client_id"
      ]
    }
  ],
  "related": [],
  "agi": {
    "goals": [
      {
        "id": "reliable_user_consent_management",
        "description": "OAuth/OIDC consent tracking and enforcement",
        "success_metrics": [
          {
            "metric": "unauthorized_access_rate",
            "target": "0%",
            "measurement": "Failed authorization attempts that succeed"
          },
          {
            "metric": "response_time_p95",
            "target": "< 500ms",
            "measurement": "95th percentile response time"
          }
        ],
        "constraints": [
          {
            "type": "security",
            "description": "Follow OWASP security recommendations",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "consent_granted",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "security",
        "over": "usability",
        "reason": "access control must enforce least-privilege principle"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
  "extensions": {
    "source": {
      "repo": "https://github.com/keycloak/keycloak",
      "project": "Keycloak",
      "tech_stack": "Java"
    }
  }
}