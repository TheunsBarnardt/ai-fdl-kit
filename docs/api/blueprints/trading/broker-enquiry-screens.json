{
  "feature": "broker-enquiry-screens",
  "version": "1.0.0",
  "description": "Online enquiry facilities for broker back-office users to view client balances, open deals, securities positions, financial history, charge and trade statistics, and portfolio holdings",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "enquiry",
    "read-only",
    "client-positions",
    "balances",
    "financial-history",
    "portfolio",
    "trade-statistics"
  ],
  "aliases": [
    "broker-enquiries",
    "enquiry-screens",
    "client-enquiry",
    "deal-enquiry",
    "portfolio-enquiry",
    "account-balance-enquiry",
    "open-positions-and-history",
    "menuk"
  ],
  "actors": [
    {
      "id": "broker_user",
      "name": "Broker Back-Office User",
      "type": "human"
    },
    {
      "id": "broker_supervisor",
      "name": "Broker Supervisor",
      "type": "human"
    },
    {
      "id": "back_office_system",
      "name": "Back-Office Deal-Accounting System",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "account_code",
      "type": "text",
      "required": true,
      "label": "Account Code"
    },
    {
      "name": "instrument_code",
      "type": "text",
      "required": false,
      "label": "Instrument / Share Code"
    },
    {
      "name": "deal_number",
      "type": "text",
      "required": false,
      "label": "Deal Number"
    },
    {
      "name": "trade_date_from",
      "type": "date",
      "required": false,
      "label": "Trade Date From"
    },
    {
      "name": "trade_date_to",
      "type": "date",
      "required": false,
      "label": "Trade Date To"
    },
    {
      "name": "enquiry_screen",
      "type": "select",
      "required": true,
      "label": "Enquiry Screen Code"
    },
    {
      "name": "buy_sell_indicator",
      "type": "select",
      "required": false,
      "label": "Buy / Sell Indicator"
    },
    {
      "name": "quantity",
      "type": "number",
      "required": false,
      "label": "Quantity"
    },
    {
      "name": "price",
      "type": "number",
      "required": false,
      "label": "Price"
    },
    {
      "name": "consideration",
      "type": "number",
      "required": false,
      "label": "Consideration"
    },
    {
      "name": "settlement_date",
      "type": "date",
      "required": false,
      "label": "Settlement Date"
    },
    {
      "name": "balance_type",
      "type": "select",
      "required": false,
      "label": "Balance Type"
    },
    {
      "name": "currency_code",
      "type": "text",
      "required": false,
      "label": "Currency Code"
    },
    {
      "name": "transfer_from_account",
      "type": "text",
      "required": false,
      "label": "Transfer From Account"
    },
    {
      "name": "transfer_to_account",
      "type": "text",
      "required": false,
      "label": "Transfer To Account"
    },
    {
      "name": "transfer_amount",
      "type": "number",
      "required": false,
      "label": "Transfer Amount"
    },
    {
      "name": "portfolio_as_at_date",
      "type": "date",
      "required": false,
      "label": "Portfolio Valuation Date"
    },
    {
      "name": "average_price",
      "type": "number",
      "required": false,
      "label": "Average Price"
    },
    {
      "name": "charges_total",
      "type": "number",
      "required": false,
      "label": "Charges Total"
    },
    {
      "name": "trade_statistics_period",
      "type": "select",
      "required": false,
      "label": "Trade Statistics Period"
    }
  ],
  "states": {
    "field": "enquiry_session_state",
    "values": [
      {
        "name": "open",
        "initial": true
      },
      {
        "name": "filtered"
      },
      {
        "name": "drilled_down"
      },
      {
        "name": "closed",
        "terminal": true
      }
    ],
    "transitions": [
      {
        "from": "open",
        "to": "filtered",
        "actor": "broker_user"
      },
      {
        "from": "filtered",
        "to": "drilled_down",
        "actor": "broker_user"
      },
      {
        "from": "drilled_down",
        "to": "filtered",
        "actor": "broker_user"
      },
      {
        "from": "filtered",
        "to": "closed",
        "actor": "broker_user"
      }
    ]
  },
  "rules": {
    "data_integrity": {
      "read_consistency": "Enquiry screens reflect ledger state as at last completed batch; intraday deals shown with pending flag",
      "drill_down_linkage": "Summary lines must resolve to a single underlying deal, scrip movement, or financial entry record",
      "balance_reconciliation": "Cash and scrip balances across enquiry screens must tie back to the general ledger control totals"
    },
    "security": {
      "access_control": "Screen-level and account-level access controlled by back-office resource access facility",
      "account_scope": "Users may only query accounts within their assigned branch, partner, or advisor scope",
      "supervisor_override": "Cross-scope enquiries require supervisor role and are audit-logged",
      "transfer_dual_control": "Balance transfer actions require operator capture plus supervisor release"
    },
    "compliance": {
      "popia_minimum_necessary": "Enquiry responses must mask personal information not needed for the operational task",
      "audit_trail": "Every enquiry logged with user, account queried, screen, timestamp, and IP for regulatory inspection",
      "data_retention": "Enquiry access logs retained for at least 36 months"
    },
    "business": {
      "open_positions_view": "Open deals, open scrip, and settlement obligations surfaced on a single positions-and-history menu",
      "deal_summary_drilldown": "Deal summaries drill down to specified deal and specified scrip records for full audit detail",
      "portfolio_valuation": "Securities positions valued using post-release average price and current market price",
      "balance_transfer": "Intra-account balance transfers permitted on the balance screen, inter-account transfers blocked and routed to cash management",
      "trade_statistics": "Charge and trade statistics aggregated by instrument, period, and account"
    }
  },
  "errors": [
    {
      "code": "ENQUIRY_ACCOUNT_NOT_FOUND",
      "status": 404,
      "message": "Account does not exist or is not within your access scope"
    },
    {
      "code": "ENQUIRY_FORBIDDEN_SCOPE",
      "status": 403,
      "message": "Access denied, account outside your branch or advisor scope"
    },
    {
      "code": "ENQUIRY_INVALID_DATE_RANGE",
      "status": 400,
      "message": "Trade date range is invalid or exceeds maximum permitted window"
    },
    {
      "code": "ENQUIRY_DATA_STALE",
      "status": 409,
      "message": "Enquiry data temporarily unavailable, ledger batch in progress"
    },
    {
      "code": "BALANCE_TRANSFER_FORBIDDEN",
      "status": 403,
      "message": "Balance transfer requires supervisor release"
    },
    {
      "code": "BALANCE_TRANSFER_INSUFFICIENT",
      "status": 422,
      "message": "Insufficient available balance for requested transfer"
    },
    {
      "code": "ENQUIRY_POPIA_MASK_REQUIRED",
      "status": 422,
      "message": "Response suppressed, personal information masking rules not satisfied"
    }
  ],
  "events": [
    {
      "name": "enquiry.executed",
      "payload": [
        "user_id",
        "account_code",
        "enquiry_screen",
        "timestamp"
      ]
    },
    {
      "name": "enquiry.drilldown",
      "payload": [
        "user_id",
        "account_code",
        "deal_number",
        "from_screen",
        "to_screen",
        "timestamp"
      ]
    },
    {
      "name": "enquiry.scope_violation",
      "payload": [
        "user_id",
        "account_code",
        "enquiry_screen",
        "timestamp"
      ]
    },
    {
      "name": "balance.transfer_captured",
      "payload": [
        "account_code",
        "transfer_amount",
        "balance_type",
        "captured_by",
        "timestamp"
      ]
    },
    {
      "name": "balance.transfer_released",
      "payload": [
        "account_code",
        "transfer_amount",
        "released_by",
        "timestamp"
      ]
    },
    {
      "name": "portfolio.valuation_viewed",
      "payload": [
        "user_id",
        "account_code",
        "portfolio_as_at_date",
        "timestamp"
      ]
    },
    {
      "name": "trade_statistics.viewed",
      "payload": [
        "user_id",
        "account_code",
        "trade_statistics_period",
        "timestamp"
      ]
    }
  ],
  "outcomes": {
    "view_open_positions_and_history": {
      "priority": 1,
      "description": "User opens the positions-and-history menu for a valid in-scope account",
      "given": [
        {
          "field": "account_code",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "account_in_scope",
          "source": "session",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "open_positions_service"
        },
        {
          "action": "emit_event",
          "event": "enquiry.executed"
        }
      ],
      "transaction": false
    },
    "reject_out_of_scope_enquiry": {
      "priority": 2,
      "error": "ENQUIRY_FORBIDDEN_SCOPE",
      "description": "Block enquiries on accounts outside the user's branch or advisor scope",
      "given": [
        {
          "field": "account_in_scope",
          "source": "session",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "enquiry.scope_violation"
        }
      ]
    },
    "drill_into_specified_deal": {
      "priority": 3,
      "description": "User drills from open-deals summary into a specified deal record",
      "given": [
        {
          "field": "deal_number",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "specified_deal_service"
        },
        {
          "action": "emit_event",
          "event": "enquiry.drilldown"
        }
      ]
    },
    "view_account_balance": {
      "priority": 4,
      "description": "User displays current cash and scrip balance for the account",
      "given": [
        {
          "field": "enquiry_screen",
          "source": "input",
          "operator": "eq",
          "value": "ACBAL"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "account_balance_service"
        },
        {
          "action": "emit_event",
          "event": "enquiry.executed"
        }
      ]
    },
    "capture_balance_transfer": {
      "priority": 5,
      "description": "Operator captures an intra-account balance transfer for supervisor release",
      "given": [
        {
          "field": "enquiry_screen",
          "source": "input",
          "operator": "eq",
          "value": "ACBAL"
        },
        {
          "field": "transfer_amount",
          "source": "input",
          "operator": "gt",
          "value": 0
        },
        {
          "field": "available_balance",
          "source": "db",
          "operator": "gte",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "balance_transfer_request"
        },
        {
          "action": "emit_event",
          "event": "balance.transfer_captured"
        }
      ],
      "transaction": true
    },
    "reject_unreleased_transfer": {
      "priority": 6,
      "error": "BALANCE_TRANSFER_FORBIDDEN",
      "description": "Block balance transfer posting without supervisor release",
      "given": [
        {
          "field": "user_role",
          "source": "session",
          "operator": "neq",
          "value": "broker_supervisor"
        },
        {
          "field": "transfer_released",
          "source": "input",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "balance.transfer_captured"
        }
      ]
    },
    "view_portfolio_valuation": {
      "priority": 7,
      "description": "User views securities positions valued at post-release average and market price",
      "given": [
        {
          "field": "portfolio_as_at_date",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "portfolio_valuation_service"
        },
        {
          "action": "emit_event",
          "event": "portfolio.valuation_viewed"
        }
      ]
    },
    "view_financial_history": {
      "priority": 8,
      "description": "User queries deal and financial history over a date range",
      "given": [
        {
          "field": "trade_date_from",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "trade_date_to",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "financial_history_service"
        },
        {
          "action": "emit_event",
          "event": "enquiry.executed"
        }
      ]
    },
    "view_trade_statistics": {
      "priority": 9,
      "description": "User views charge and trade statistics aggregated by period",
      "given": [
        {
          "field": "trade_statistics_period",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "trade_statistics_service"
        },
        {
          "action": "emit_event",
          "event": "trade_statistics.viewed"
        }
      ]
    },
    "reject_invalid_date_range": {
      "priority": 10,
      "error": "ENQUIRY_INVALID_DATE_RANGE",
      "description": "Reject enquiries where date range is inverted or exceeds maximum window",
      "given": [
        {
          "field": "trade_date_from",
          "source": "input",
          "operator": "gt",
          "value": "trade_date_to"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "enquiry.executed"
        }
      ]
    }
  },
  "api": {
    "http": {
      "method": "GET",
      "path": "/api/v1/enquiries/{enquiry_screen}"
    },
    "request": {
      "schema": {
        "account_code": "text",
        "enquiry_screen": "select",
        "instrument_code": "text",
        "trade_date_from": "date",
        "trade_date_to": "date",
        "portfolio_as_at_date": "date"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "account_code": "text",
          "enquiry_screen": "select",
          "rows": "json",
          "totals": "json"
        }
      },
      "errors": [
        {
          "error_code": "ENQUIRY_ACCOUNT_NOT_FOUND",
          "status": 404
        },
        {
          "error_code": "ENQUIRY_FORBIDDEN_SCOPE",
          "status": 403
        },
        {
          "error_code": "ENQUIRY_INVALID_DATE_RANGE",
          "status": 400
        },
        {
          "error_code": "ENQUIRY_DATA_STALE",
          "status": 409
        },
        {
          "error_code": "ENQUIRY_POPIA_MASK_REQUIRED",
          "status": 422
        }
      ]
    }
  },
  "anti_patterns": [
    {
      "rule": "Do not allow enquiries to bypass branch or advisor scope checks",
      "why": "Cross-scope data access breaches segregation-of-duties and POPIA minimum-necessary principles"
    },
    {
      "rule": "Do not expose unmasked personal information on enquiry screens used for operational tasks",
      "why": "POPIA s.19 and minimum-necessary require masking where the full value is not required"
    },
    {
      "rule": "Do not allow balance transfers without dual-control capture and release",
      "why": "Single-user balance movement is a known fraud vector in broker back-office systems"
    },
    {
      "rule": "Do not serve stale enquiry data during batch cut-over without a clear indicator",
      "why": "Users making decisions on mid-batch state can post duplicate or offsetting entries"
    },
    {
      "rule": "Do not log full account identifiers or personal information in enquiry audit logs without protection",
      "why": "Audit logs inherit the same POPIA retention and protection obligations as source records"
    },
    {
      "rule": "Do not permit unbounded date ranges on financial history queries",
      "why": "Unbounded scans degrade the ledger and are frequently used for bulk data exfiltration"
    }
  ],
  "related": [
    {
      "feature": "broker-client-account-maintenance",
      "type": "required"
    },
    {
      "feature": "popia-compliance",
      "type": "required"
    },
    {
      "feature": "broker-back-office-dissemination",
      "type": "recommended"
    },
    {
      "feature": "broker-client-data-upload",
      "type": "optional"
    }
  ],
  "extensions": {
    "screens": {
      "MENUK": "Open Positions and History Menu",
      "ACDLS": "Open Deals By Share Display",
      "SPDEL": "Specified Deal Record",
      "SPSCR": "Specified Scrip Record",
      "SHDLS": "Deals and Scrip by Instrument",
      "AFINH": "Account Deal and Financial History",
      "ASAFH": "Account Safex History",
      "ASAFP": "Safex Positions",
      "ACBAL": "Account Balance",
      "ASHRH": "Account Share History",
      "CSEXD": "Controlled Account Transactions",
      "PRAVP": "Post Release Average Price Summary",
      "PRAVG": "Equity Average Price Summary",
      "SFENQ": "Securities and Funds Availability Selection Enquiry",
      "SFPSS": "Securities and Funds Availability Proprietary Sales",
      "SFPPS": "Securities and Funds Availability Proprietary Purchases",
      "TRELT": "Trades Released Today"
    }
  }
}