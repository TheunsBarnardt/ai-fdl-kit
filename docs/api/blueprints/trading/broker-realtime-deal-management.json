      "level": "supervised",
      "human_checkpoints": [
        "before transitioning to a terminal state"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "release_trade_intraday",
          "permission": "autonomous"
        },
        {
          "action": "reject_duplicate_release",
          "permission": "supervised"
        },
        {
          "action": "calculate_average_price",
          "permission": "autonomous"
        },
        {
          "action": "same_day_allocation_at_average",
          "permission": "autonomous"
        },
        {
          "action": "block_allocation_when_underlying_unreleased",
          "permission": "human_required"
        },
        {
          "action": "generate_realtime_contract_note",
          "permission": "autonomous"
        },
        {
          "action": "confirm_electronic_trade_confirmation",
          "permission": "autonomous"
        },
        {
          "action": "flag_etc_mismatch",
          "permission": "autonomous"
        },
        {
          "action": "verify_allocation_balance",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
