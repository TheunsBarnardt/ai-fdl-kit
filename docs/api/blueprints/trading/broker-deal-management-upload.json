{
  "feature": "broker-deal-management-upload",
  "version": "1.0.0",
  "description": "Broker deal management upload to central back-office - deal allocations, same-day allocations, and deals uploads with manual and automated FTP submission modes, external account code mapping",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "upload",
    "deal-allocation",
    "t+3",
    "trades",
    "fixed-width"
  ],
  "actors": [
    {
      "id": "participating_broker",
      "name": "Participating Broker",
      "type": "external"
    },
    {
      "id": "back_office_system",
      "name": "Back Office System",
      "type": "system"
    },
    {
      "id": "broker_dealing_room",
      "name": "Broker Dealing Room",
      "type": "human"
    }
  ],
  "fields": [
    {
      "name": "record_type",
      "type": "text",
      "required": true,
      "label": "Record Type"
    },
    {
      "name": "broker_code",
      "type": "text",
      "required": true,
      "label": "Broker Code"
    },
    {
      "name": "upload_date",
      "type": "date",
      "required": true,
      "label": "Upload Date"
    },
    {
      "name": "deal_reference",
      "type": "text",
      "required": true,
      "label": "Deal Reference"
    },
    {
      "name": "order_reference",
      "type": "text",
      "required": false,
      "label": "Order Reference"
    },
    {
      "name": "trade_date",
      "type": "date",
      "required": true,
      "label": "Trade Date"
    },
    {
      "name": "settlement_date",
      "type": "date",
      "required": false,
      "label": "Settlement Date"
    },
    {
      "name": "buy_sell_indicator",
      "type": "select",
      "required": true,
      "label": "Buy Sell Indicator"
    },
    {
      "name": "instrument_code",
      "type": "text",
      "required": true,
      "label": "Instrument Code"
    },
    {
      "name": "isin",
      "type": "text",
      "required": false,
      "label": "Isin"
    },
    {
      "name": "quantity",
      "type": "number",
      "required": true,
      "label": "Quantity"
    },
    {
      "name": "price",
      "type": "number",
      "required": true,
      "label": "Price"
    },
    {
      "name": "consideration",
      "type": "number",
      "required": false,
      "label": "Consideration"
    },
    {
      "name": "trade_time",
      "type": "text",
      "required": false,
      "label": "Trade Time"
    },
    {
      "name": "client_account",
      "type": "text",
      "required": true,
      "label": "Client Account"
    },
    {
      "name": "external_account_code",
      "type": "text",
      "required": false,
      "label": "External Account Code"
    },
    {
      "name": "commission_amount",
      "type": "number",
      "required": false,
      "label": "Commission Amount"
    },
    {
      "name": "charges_amount",
      "type": "number",
      "required": false,
      "label": "Charges Amount"
    },
    {
      "name": "vat_amount",
      "type": "number",
      "required": false,
      "label": "Vat Amount"
    },
    {
      "name": "stt_amount",
      "type": "number",
      "required": false,
      "label": "Stt Amount"
    },
    {
      "name": "allocation_reference",
      "type": "text",
      "required": false,
      "label": "Allocation Reference"
    },
    {
      "name": "partner_code",
      "type": "text",
      "required": false,
      "label": "Partner Code"
    },
    {
      "name": "branch_code",
      "type": "text",
      "required": false,
      "label": "Branch Code"
    },
    {
      "name": "portfolio_code",
      "type": "text",
      "required": false,
      "label": "Portfolio Code"
    },
    {
      "name": "dealer_code",
      "type": "text",
      "required": false,
      "label": "Dealer Code"
    },
    {
      "name": "trade_type",
      "type": "select",
      "required": false,
      "label": "Trade Type"
    },
    {
      "name": "execution_venue",
      "type": "text",
      "required": false,
      "label": "Execution Venue"
    },
    {
      "name": "counter_party_code",
      "type": "text",
      "required": false,
      "label": "Counter Party Code"
    },
    {
      "name": "principal_indicator",
      "type": "select",
      "required": false,
      "label": "Principal Indicator"
    },
    {
      "name": "cancellation_indicator",
      "type": "select",
      "required": false,
      "label": "Cancellation Indicator"
    }
  ],
  "rules": {
    "submission_modes": [
      "MUST: Support manual submission of deal allocations via FTP process",
      "MUST: Support automated submission of deal allocations via FTP",
      "MUST: Support automated submission of same-day allocations",
      "MUST: Support automated submission of deals upload"
    ],
    "setup": [
      "MUST: Complete member setup and FTP process configuration before use",
      "MUST: Set up email addresses for notifications"
    ],
    "validation": [
      "MUST: Validate external account code mapping to internal client account",
      "MUST: Validate trade date, settlement date, and T+3 settlement rules",
      "MUST: Validate buy/sell indicator is B or S",
      "MUST: Reject unbalanced or incomplete allocation records"
    ],
    "timing": [
      "MUST: Process same-day allocations within business day cutoff",
      "MUST: Process T+3 deal allocations before settlement cutoff",
      "MUST: Support T+2 settlement where applicable per market rules"
    ],
    "format": [
      "MUST: Use fixed-width upload file format",
      "MUST: Include Header and Trailer records in every upload"
    ]
  },
  "errors": [
    {
      "code": "DEAL_UPLOAD_INVALID_EXTERNAL_ACCOUNT",
      "status": 422,
      "message": "External account code cannot be mapped to a client account"
    },
    {
      "code": "DEAL_UPLOAD_INVALID_TRADE_DATE",
      "status": 422,
      "message": "Trade date is invalid or outside allowed window"
    },
    {
      "code": "DEAL_UPLOAD_INSTRUMENT_NOT_FOUND",
      "status": 422,
      "message": "Referenced instrument does not exist"
    },
    {
      "code": "DEAL_UPLOAD_ALLOCATION_CUTOFF_EXCEEDED",
      "status": 422,
      "message": "Same-day allocation submitted after cutoff time"
    },
    {
      "code": "DEAL_UPLOAD_DUPLICATE_DEAL",
      "status": 409,
      "message": "Deal reference already exists"
    }
  ],
  "outcomes": {
    "manual_deal_allocation_upload": {
      "priority": 1,
      "description": "Broker manually submits deal allocations via FTP",
      "given": [
        {
          "field": "submission_mode",
          "source": "input",
          "operator": "eq",
          "value": "manual_ftp"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "deal_allocation_upload",
          "fields": [
            "broker_code",
            "file_name",
            "deal_count",
            "submission_timestamp"
          ]
        },
        {
          "action": "emit_event",
          "event": "deal_upload.manual.received"
        }
      ],
      "error": "DEAL_UPLOAD_INVALID_EXTERNAL_ACCOUNT"
    },
    "automated_deal_allocation_upload": {
      "priority": 2,
      "description": "Automated deal allocation upload via FTP",
      "given": [
        {
          "field": "submission_mode",
          "source": "input",
          "operator": "eq",
          "value": "automated_ftp"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "deal_allocation_upload_auto"
        },
        {
          "action": "emit_event",
          "event": "deal_upload.automated.received"
        }
      ],
      "error": "DEAL_UPLOAD_INVALID_TRADE_DATE"
    },
    "same_day_allocation_upload": {
      "priority": 3,
      "description": "Same-day allocation upload with intraday processing",
      "given": [
        {
          "field": "allocation_type",
          "source": "input",
          "operator": "eq",
          "value": "same_day"
        },
        {
          "field": "submission_time",
          "source": "system",
          "operator": "lt",
          "value": "cutoff_time"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "same_day_allocation"
        },
        {
          "action": "emit_event",
          "event": "deal_upload.same_day.received"
        }
      ]
    },
    "deals_upload": {
      "priority": 4,
      "description": "Automated deals upload",
      "given": [
        {
          "field": "upload_type",
          "source": "input",
          "operator": "eq",
          "value": "deals"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "deals_upload"
        },
        {
          "action": "emit_event",
          "event": "deal_upload.deals.received"
        }
      ],
      "error": "DEAL_UPLOAD_INSTRUMENT_NOT_FOUND"
    },
    "external_account_mapping": {
      "priority": 5,
      "description": "Map external account code to internal client account",
      "given": [
        {
          "field": "external_account_code",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "external_account_mapper"
        },
        {
          "action": "emit_event",
          "event": "deal_upload.external_account.mapped"
        }
      ]
    },
    "allocation_cutoff_exceeded": {
      "priority": 6,
      "error": "DEAL_UPLOAD_ALLOCATION_CUTOFF_EXCEEDED",
      "given": [
        {
          "field": "allocation_type",
          "source": "input",
          "operator": "eq",
          "value": "same_day"
        },
        {
          "field": "submission_time",
          "source": "system",
          "operator": "gte",
          "value": "cutoff_time"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "deal_upload.cutoff_exceeded"
        }
      ]
    }
  },
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_deal_management_upload",
        "description": "Broker deal management upload to central back-office - deal allocations, same-day allocations, and deals uploads with manual and automated FTP submission modes, external account code mapping",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "manual_deal_allocation_upload",
          "permission": "autonomous"
        },
        {
          "action": "automated_deal_allocation_upload",
          "permission": "autonomous"
        },
        {
          "action": "same_day_allocation_upload",
          "permission": "autonomous"
        },
        {
          "action": "deals_upload",
          "permission": "autonomous"
        },
        {
          "action": "external_account_mapping",
          "permission": "autonomous"
        },
        {
          "action": "allocation_cutoff_exceeded",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
  "extensions": {
    "upload_types": {
      "manual_deal_allocation": {
        "description": "Manual submission of deal allocations via FTP",
        "member_setup_required": true
      },
      "automated_deal_allocation": {
        "description": "Automated FTP submission of deal allocations"
      },
      "same_day_allocation": {
        "description": "Same-day allocations with intraday cutoff"
      },
      "deals_upload": {
        "description": "Automated deals upload"
      }
    },
    "submission_workflow": [
      "1. Member setup and FTP process configuration",
      "2. Email address set-up",
      "3. Upload file creation per layout",
      "4. FTP or online submission",
      "5. Error reporting",
      "6. Response processing"
    ],
    "external_account_mapping": {
      "description": "External account codes provided by broker trading systems are mapped to internal account numbers by back-office"
    },
    "settlement_cycles": [
      "T+3 standard settlement",
      "T+2 settlement (where applicable)",
      "Same-day settlement"
    ]
  },
  "related": [
    {
      "feature": "broker-back-office-dissemination",
      "type": "recommended"
    },
    {
      "feature": "broker-client-data-upload",
      "type": "recommended"
    },
    {
