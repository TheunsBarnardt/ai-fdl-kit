      "reason": "Equities EOD data uses same FTP delivery infrastructure"
    },
    {
      "feature": "interest-rates-derivatives-eod-data-delivery",
      "type": "optional",
      "reason": "Interest rates derivatives uses similar record structure"
    },
    {
      "feature": "currency-derivatives-eod-data-delivery",
      "type": "optional",
      "reason": "Currency derivatives uses identical record structure with different prefixes"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_equity_derivatives_eod_data_delivery",
        "description": "End-of-day equity derivatives data delivery via FTP — fixed-width flat files covering daily/weekly/monthly statistics, MTM, rates, and risk parameters",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "successful_delivery",
          "permission": "autonomous"
        },
        {
          "action": "subscriber_provisioned",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
