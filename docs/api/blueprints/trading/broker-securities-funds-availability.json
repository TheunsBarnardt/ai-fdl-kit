        "trading_limit",
        "limit_utilisation",
        "attempted_amount",
        "timestamp"
      ]
    },
    {
      "name": "availability.override_applied",
      "payload": [
        "account_code",
        "deal_id",
        "overridden_by",
        "reason",
        "timestamp"
      ]
    },
    {
      "name": "availability.batch_completed",
      "payload": [
        "batch_date",
        "source_indicator",
        "account_group",
        "records_processed",
        "timestamp"
      ]
    }
  ],
  "outcomes": {
    "pre_trade_cash_sufficient": {
      "priority": 1,
      "description": "Purchase order passes pre-trade funds availability check",
      "given": [
        {
          "field": "purchase_sale_indicator",
          "source": "input",
          "operator": "eq",
          "value": "P"
        },
        {
          "field": "cash_balance",
          "source": "db",
          "operator": "gte",
          "value": "purchase_amount"
        },
        {
          "field": "limit_utilisation",
          "source": "computed",
          "operator": "lte",
          "value": "trading_limit"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "availability_status",
          "value": "passed"
        },
        {
          "action": "transition_state",
          "field": "availability_status",
          "from": "pending",
          "to": "passed"
        },
        {
          "action": "emit_event",
          "event": "availability.check.passed"
        }
      ],
      "transaction": true
    },
    "pre_trade_insufficient_funds": {
      "priority": 2,
      "error": "SFA_INSUFFICIENT_FUNDS",
      "description": "Purchase order fails because available cash does not cover the purchase amount",
      "given": [
        {
          "field": "purchase_sale_indicator",
          "source": "input",
          "operator": "eq",
          "value": "P"
        },
        {
          "field": "cash_balance",
          "source": "db",
          "operator": "lt",
          "value": "purchase_amount"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "availability_status",
          "value": "failed"
        },
        {
          "action": "transition_state",
          "field": "availability_status",
          "from": "pending",
          "to": "failed"
        },
        {
          "action": "emit_event",
          "event": "availability.check.failed"
        },
        {
          "action": "emit_event",
          "event": "availability.funding_shortfall_detected"
        }
      ]
    },
    "pre_trade_securities_sufficient": {
      "priority": 3,
      "description": "Sale order passes pre-trade securities availability check",
      "given": [
        {
          "field": "purchase_sale_indicator",
          "source": "input",
          "operator": "eq",
          "value": "S"
        },
        {
          "field": "securities_holding_qty",
          "source": "db",
          "operator": "gte",
          "value": "sale_quantity"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "availability_status",
          "value": "passed"
        },
        {
          "action": "transition_state",
          "field": "availability_status",
          "from": "pending",
          "to": "passed"
        },
        {
          "action": "emit_event",
          "event": "availability.check.passed"
        }
      ],
      "transaction": true
    },
    "pre_trade_insufficient_securities": {
      "priority": 4,
      "error": "SFA_INSUFFICIENT_SECURITIES",
      "description": "Sale order fails because available securities do not cover the sale quantity",
      "given": [
        {
          "field": "purchase_sale_indicator",
          "source": "input",
          "operator": "eq",
          "value": "S"
        },
        {
          "field": "securities_holding_qty",
          "source": "db",
          "operator": "lt",
          "value": "sale_quantity"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "availability_status",
          "value": "failed"
        },
        {
          "action": "transition_state",
          "field": "availability_status",
          "from": "pending",
          "to": "failed"
        },
        {
          "action": "emit_event",
          "event": "availability.check.failed"
        },
        {
          "action": "emit_event",
          "event": "availability.short_position_detected"
        }
      ]
    },
    "trading_limit_exceeded": {
      "priority": 5,
      "error": "SFA_TRADING_LIMIT_EXCEEDED",
      "description": "Order is rejected because it would breach the account trading limit",
      "given": [
        {
          "field": "limit_utilisation",
          "source": "computed",
          "operator": "gt",
          "value": "trading_limit"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "availability_status",
          "value": "failed"
        },
        {
          "action": "transition_state",
          "field": "availability_status",
          "from": "pending",
          "to": "failed"
        },
        {
          "action": "emit_event",
          "event": "availability.trading_limit_breached"
        },
        {
          "action": "emit_event",
          "event": "availability.check.failed"
        }
      ]
    },
    "real_time_position_lookup": {
      "priority": 6,
      "description": "Back-office system returns real-time aggregated position for an account and instrument",
      "given": [
        {
          "field": "account_code",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "instrument_code",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "position_service"
        },
        {
          "action": "emit_event",
          "event": "availability.check.requested"
        }
      ]
    },
    "settlement_cycle_batch_run": {
      "priority": 7,
      "description": "Scheduled batch extracts availability for open allocations to feed the clearing system",
      "given": [
        {
          "field": "batch_date",
          "source": "system",
          "operator": "exists"
        },
        {
          "field": "source_indicator",
          "source": "input",
          "operator": "in",
          "value": [
            "B",
            "I"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "availability_batch_job"
        },
        {
          "action": "emit_event",
          "event": "availability.batch_completed"
        }
      ],
      "transaction": true
    },
    "override_failed_check": {
      "priority": 8,
      "description": "Risk officer overrides a failed availability check with documented reason",
      "given": [
        {
          "field": "user_role",
          "source": "session",
          "operator": "eq",
          "value": "risk_officer"
        },
        {
          "field": "availability_status",
          "source": "db",
          "operator": "eq",
          "value": "failed"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "availability.override_applied"
        }
      ]
    },
    "reject_non_risk_override": {
      "priority": 9,
      "error": "SFA_OVERRIDE_FORBIDDEN",
      "description": "Prevent non-risk-officer roles from overriding a failed availability check",
      "given": [
        {
          "field": "user_role",
          "source": "session",
          "operator": "neq",
          "value": "risk_officer"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "availability.check.failed"
        }
      ]
    }
  },
  "api": {
    "http": {
      "method": "POST",
      "path": "/api/v1/availability/check"
