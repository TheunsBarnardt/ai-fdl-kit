{
  "feature": "price-transform-indicators",
  "version": "1.0.0",
  "description": "Single-bar OHLC price transformation functions that synthesize a representative scalar price from open, high, low, and close without any time-period smoothing",
  "category": "trading",
  "tags": [
    "technical-analysis",
    "price-transform",
    "avgprice",
    "medprice",
    "typprice",
    "wclprice",
    "ta-lib",
    "indicators"
  ],
  "aliases": [
    "price-transforms",
    "ohlc-transforms",
    "representative-price",
    "ta-lib-price-transform",
    "price-synthesis"
  ],
  "actors": [
    {
      "id": "quant_analyst",
      "name": "Quantitative Analyst",
      "type": "human"
    },
    {
      "id": "indicator_engine",
      "name": "Technical Indicator Engine",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "open_prices",
      "type": "json",
      "required": false,
      "label": "Open Prices (required for AVGPRICE only)"
    },
    {
      "name": "high_prices",
      "type": "json",
      "required": true,
      "label": "High Prices (chronological double array)"
    },
    {
      "name": "low_prices",
      "type": "json",
      "required": true,
      "label": "Low Prices (chronological double array)"
    },
    {
      "name": "close_prices",
      "type": "json",
      "required": true,
      "label": "Close Prices (chronological double array)"
    },
    {
      "name": "indicator_type",
      "type": "select",
      "required": true,
      "label": "Price transform to compute",
      "options": [
        {
          "value": "AVGPRICE",
          "label": "AVGPRICE"
        },
        {
          "value": "MEDPRICE",
          "label": "MEDPRICE"
        },
        {
          "value": "TYPPRICE",
          "label": "TYPPRICE"
        },
        {
          "value": "WCLPRICE",
          "label": "WCLPRICE"
        }
      ]
    },
    {
      "name": "out_beg_idx",
      "type": "number",
      "required": false,
      "label": "Output Begin Index"
    },
    {
      "name": "out_nb_element",
      "type": "number",
      "required": false,
      "label": "Number of valid output elements"
    },
    {
      "name": "out_values",
      "type": "json",
      "required": false,
      "label": "Transformed price output array (double values; same unit as input prices)"
    }
  ],
  "rules": {
    "lookback_model": {
      "lookback": 0,
      "output_length": "input_length (1-to-1 bar mapping)"
    },
    "avgprice": {
      "formula": "AVGPRICE = (Open + High + Low + Close) / 4",
      "inputs_required": [
        "Open",
        "High",
        "Low",
        "Close"
      ],
      "output_unit": "Same price unit as inputs",
      "use_case": "Equal-weight price that considers session direction (Open) as well as range"
    },
    "medprice": {
      "formula": "MEDPRICE = (High + Low) / 2",
      "inputs_required": [
        "High",
        "Low"
      ],
      "output_unit": "Same price unit as inputs",
      "use_case": "Midpoint of the day's range; ignores open and close; simpler than typical price"
    },
    "typprice": {
      "formula": "TYPPRICE = (High + Low + Close) / 3",
      "inputs_required": [
        "High",
        "Low",
        "Close"
      ],
      "output_unit": "Same price unit as inputs",
      "use_case": "Standard representative price for volume-weighting (CCI, MFI, On Balance Volume variants)",
      "note": "Equal weight to high, low, and close — downplays opening gaps"
    },
    "wclprice": {
      "formula": "WCLPRICE = (High + Low + (Close * 2)) / 4",
      "inputs_required": [
        "High",
        "Low",
        "Close"
      ],
      "output_unit": "Same price unit as inputs",
      "use_case": "Close-biased representative price; close receives double weighting relative to high and low",
      "note": "Useful when closing price is considered most significant (e.g., for daily settlement)"
    }
  },
  "outcomes": {
    "compute_success": {
      "priority": 10,
      "given": [
        "input_length >= 1",
        "all required OHLC arrays present and equal length"
      ],
      "then": [
        {
          "action": "set_field",
          "target": "out_beg_idx",
          "value": 0
        },
        {
          "action": "set_field",
          "target": "out_nb_element",
          "value": "input_length"
        },
        {
          "action": "set_field",
          "target": "out_values",
          "value": "transformed price values (one per input bar)"
        },
        {
          "action": "emit_event",
          "event": "price_transform.computed",
          "payload": [
            "indicator_type",
            "out_nb_element"
          ]
        }
      ],
      "result": "Output array aligned 1-to-1 with input bars; no lookback offset required"
    },
    "missing_open": {
      "priority": 2,
      "error": "MISSING_INPUT",
      "given": [
        "indicator_type == AVGPRICE",
        "open_prices is null or empty"
      ],
      "result": "AVGPRICE requires Open prices; supply the open_prices array"
    },
    "mismatched_lengths": {
      "priority": 2,
      "error": "INVALID_INPUT",
      "given": [
        "open_prices, high_prices, low_prices, close_prices arrays differ in length"
      ],
      "result": "All supplied OHLC arrays must have the same number of elements"
    }
  },
  "errors": [
    {
      "code": "MISSING_INPUT",
      "message": "Open prices are required for AVGPRICE. High, Low, Close required for all transforms.",
      "status": 400
    },
    {
      "code": "INVALID_INPUT",
      "message": "Input price arrays must be the same length.",
      "status": 400
    }
  ],
  "events": [
    {
      "name": "price_transform.computed",
      "payload": [
        "indicator_type",
        "out_nb_element",
        "out_beg_idx"
      ]
    }
  ],
  "related": [
    {
      "feature": "momentum-oscillators",
      "type": "recommended"
    },
    {
      "feature": "volume-flow-indicators",
      "type": "recommended"
    },
    {
      "feature": "moving-average-overlap-studies",
      "type": "recommended"
    },
    {
      "feature": "market-data-feeds",
      "type": "required"
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not use AVGPRICE or TYPPRICE interchangeably without understanding the difference",
      "why": "AVGPRICE weights Open equally; TYPPRICE omits Open — in markets with large overnight gaps, the two can diverge significantly"
    },
    {
      "rule": "Do not apply these transforms expecting trend smoothing",
      "why": "All four are zero-lookback single-bar transforms with no averaging over time — they do not reduce noise; use a moving average on top for smoothing"
    },
    {
      "rule": "Do not use MEDPRICE as a proxy for close in volume-based indicators",
      "why": "Indicators like MFI and CCI require Typical Price (TYPPRICE), not Median Price — wrong formula produces incorrect signals"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_price_transform_indicators",
        "description": "Single-bar OHLC price transformation functions that synthesize a representative scalar price from open, high, low, and close without any time-period smoothing",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "compute_success",
          "permission": "autonomous"
        },
        {
          "action": "missing_open",
          "permission": "autonomous"
        },
        {
          "action": "mismatched_lengths",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "orchestrated",
      "consumes": [
        {
          "capability": "market_data_feeds",
          "from": "market-data-feeds",
          "fallback": "fail"
        }
      ]
    }
  },
  "extensions": {
    "tech_stack": {
      "language": "C99",
      "bindings": "Java, .NET, Rust, Python",
      "source_repo": "https://github.com/TA-Lib/ta-lib"
    },
    "indicator_count": 4,
    "lookback": 0,
    "output_type": "Double Array — same price scale as input"
  }
}