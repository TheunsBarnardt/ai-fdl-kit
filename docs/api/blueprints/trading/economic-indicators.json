{
  "feature": "economic-indicators",
  "version": "1.0.0",
  "description": "Classify and interpret leading, coincident, and lagging economic indicators — including composite indices and nowcasting — to track and forecast the business cycle",
  "category": "trading",
  "tags": [
    "economics",
    "macroeconomics",
    "leading-indicators",
    "coincident-indicators",
    "lagging-indicators",
    "nowcasting",
    "cfa-level-1"
  ],
  "aliases": [
    "leading-indicators",
    "coincident-indicators",
    "lagging-indicators",
    "composite-index",
    "nowcasting",
    "gdpnow"
  ],
  "actors": [
    {
      "id": "indicator_tracker",
      "name": "Economic Indicator Tracker",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "indicator_name",
      "type": "text",
      "required": true,
      "label": "Indicator name or code"
    },
    {
      "name": "category",
      "type": "select",
      "required": true,
      "label": "leading | coincident | lagging"
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "label": "Latest observation"
    },
    {
      "name": "release_date",
      "type": "datetime",
      "required": false,
      "label": "Observation release timestamp"
    }
  ],
  "rules": {
    "leading_indicators": {
      "definition": "Turn before the business cycle — useful for forecasting",
      "examples": [
        "Average weekly hours, manufacturing",
        "New orders for capital goods",
        "Building permits",
        "Stock prices (S&P 500)",
        "Interest rate spread (10y minus 3m)",
        "Consumer expectations"
      ]
    },
    "coincident_indicators": {
      "definition": "Move contemporaneously with the cycle — identify current state",
      "examples": [
        "Employees on nonfarm payrolls",
        "Personal income less transfer payments",
        "Industrial production",
        "Manufacturing and trade sales"
      ]
    },
    "lagging_indicators": {
      "definition": "Change after the cycle — confirm prior turns",
      "examples": [
        "Average duration of unemployment",
        "Inventory-to-sales ratio",
        "Change in labour cost per unit of output",
        "Average prime rate",
        "Commercial and industrial loans",
        "Consumer debt to income",
        "CPI services"
      ]
    },
    "composite_indices": {
      "leading_economic_index": "LEI aggregates 10 leading series",
      "coincident_index": "CEI aggregates 4 coincident series",
      "lagging_index": "LAG combines 7 lagging series",
      "signal_rules": "Three consecutive declines in LEI traditionally flag recession risk"
    },
    "surveys": {
      "ism_pmi": "Purchasing Managers Index — 50 is expansion/contraction boundary",
      "consumer_confidence": "Sentiment surveys supplement hard data",
      "senior_loan_officer": "Gauge of lending standards"
    },
    "nowcasting": {
      "definition": "Real-time estimation of current-quarter GDP using high-frequency data",
      "example": "Atlanta Fed GDPNow updates each data release",
      "benefits": "Reduce information lag between release and decision"
    },
    "applications": {
      "asset_allocation": "Overweight cyclicals when LEI is rising",
      "interest_rate_forecasting": "Yield-curve shape is a tested recession predictor",
      "sector_rotation": "Building permits lead housing and construction equities"
    },
    "validation": {
      "valid_category": "category in {leading, coincident, lagging}",
      "indicator_name_present": "indicator_name required"
    }
  },
  "outcomes": {
    "register_indicator_reading": {
      "priority": 1,
      "description": "Record a new reading and update composite indices",
      "given": [
        {
          "field": "indicator_name",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "category",
          "source": "input",
          "operator": "in",
          "value": [
            "leading",
            "coincident",
            "lagging"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "indicator_tracker"
        },
        {
          "action": "emit_event",
          "event": "macro.indicator_updated"
        }
      ]
    },
    "invalid_category": {
      "priority": 10,
      "description": "Unsupported category",
      "given": [
        {
          "field": "category",
          "source": "input",
          "operator": "not_in",
          "value": [
            "leading",
            "coincident",
            "lagging"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "macro.indicator_rejected"
        }
      ],
      "error": "INDICATOR_INVALID_CATEGORY"
    },
    "missing_indicator_name": {
      "priority": 11,
      "description": "Indicator name missing",
      "given": [
        {
          "field": "indicator_name",
          "source": "input",
          "operator": "not_exists"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "macro.indicator_rejected"
        }
      ],
      "error": "INDICATOR_NAME_MISSING"
    }
  },
  "errors": [
    {
      "code": "INDICATOR_INVALID_CATEGORY",
      "status": 400,
      "message": "category must be leading, coincident, or lagging"
    },
    {
      "code": "INDICATOR_NAME_MISSING",
      "status": 400,
      "message": "indicator_name is required"
    }
  ],
  "events": [
    {
      "name": "macro.indicator_updated",
      "payload": [
        "indicator_name",
        "category",
        "value",
        "release_date",
        "composite_change"
      ]
    },
    {
      "name": "macro.indicator_rejected",
      "payload": [
        "indicator_name",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not confuse leading indicators with causality",
      "why": "Indicators correlate with the cycle; they do not necessarily drive it. Treat them as signals, not triggers"
    },
    {
      "rule": "Do not over-react to a single monthly indicator release",
      "why": "Monthly data are noisy and often revised; use multi-month trends and the composite index"
    },
    {
      "rule": "Do not ignore revisions when acting on real-time data",
      "why": "Real-time vintages differ from final data; backtests using final data overstate performance of rules based on real-time readings"
    },
    {
      "rule": "Do not stop tracking lagging indicators because they 'lag'",
      "why": "Lagging indicators confirm phase transitions and flag persistence of trends; they discipline premature phase calls"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/macro/indicators/update"
    },
    "request": {
      "schema": {
        "indicator_name": "string",
        "category": "string",
        "value": "number",
        "release_date": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "indicator_name": "string",
          "category": "string",
          "composite_change": "number"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "INDICATOR_INVALID_CATEGORY"
        },
        {
          "status": 400,
          "error_code": "INDICATOR_NAME_MISSING"
        }
      ]
    }
  },
  "extensions": {
    "us_composite_leading_components": [
      "Average weekly hours, manufacturing",
      "Average weekly initial claims for unemployment",
      "Manufacturers' new orders, consumer goods",
      "ISM New Orders index",
      "Manufacturers' new orders, non-defense capital goods ex aircraft",
      "Building permits, private housing",
      "Stock prices, S&P 500",
      "Leading credit index",
      "Interest rate spread, 10y minus federal funds",
      "Average consumer expectations"
    ]
  },
  "related": [
    {
      "feature": "business-cycle-phases",
      "type": "required"
    },
    {
      "feature": "credit-cycles",
      "type": "recommended"
    }
  ]
}