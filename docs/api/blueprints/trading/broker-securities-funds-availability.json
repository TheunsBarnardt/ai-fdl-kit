          "error_code": "SFA_INSUFFICIENT_FUNDS",
          "status": 409
        },
        {
          "error_code": "SFA_TRADING_LIMIT_EXCEEDED",
          "status": 409
        },
        {
          "error_code": "SFA_INVALID_BATCH_DATE",
          "status": 400
        },
        {
          "error_code": "SFA_POSITION_LOOKUP_FAILED",
          "status": 503
        }
      ]
    }
  },
  "anti_patterns": [
    {
      "rule": "Do not rely solely on overnight batch availability figures for intraday trading decisions",
      "why": "Batch figures are point-in-time and do not reflect intraday allocations, leading to oversell or overspend"
    },
    {
      "rule": "Do not aggregate proprietary availability at the individual sub-account level",
      "why": "Proprietary availability is inherently a firm-wide netted view; per-account views misrepresent the true position and can cause incorrect short-sell flagging"
    },
    {
      "rule": "Do not allow operators to override failed availability checks without risk-officer approval",
      "why": "Overrides expose the firm to failed-trade penalties, margin calls and regulatory censure"
    },
    {
      "rule": "Do not persist personal information of clients in availability audit logs in plaintext",
      "why": "POPIA s.19 requires appropriate technical safeguards; availability audit logs often transit third-party systems"
    },
    {
      "rule": "Do not bypass trading limit checks for any order channel",
      "why": "Consistent limit enforcement across channels is the only reliable control against runaway exposure"
    },
    {
      "rule": "Do not treat foreign-currency deals as settled in the local cash balance",
      "why": "Foreign-indicator deals settle in a different currency pool; mixing them overstates available funds"
    }
  ],
