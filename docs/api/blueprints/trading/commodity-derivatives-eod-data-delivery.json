{
  "feature": "commodity-derivatives-eod-data-delivery",
  "version": "1.0.0",
  "description": "End-of-day commodity derivatives data delivery via FTP — fixed-width flat files covering daily statistics, mark-to-market, and reference rates",
  "category": "trading",
  "tags": [
    "market-data",
    "eod",
    "commodity-derivatives",
    "agricultural",
    "ftp",
    "dissemination",
    "fixed-width",
    "non-live"
  ],
  "actors": [
    {
      "id": "data_subscriber",
      "name": "Data Subscriber",
      "type": "human",
      "description": "Licensed recipient who receives end-of-day commodity derivatives data files"
    },
    {
      "id": "exchange_operations",
      "name": "Exchange Operations",
      "type": "system",
      "description": "Exchange dissemination system that generates and delivers EOD files"
    },
    {
      "id": "customer_services",
      "name": "Customer Services",
      "type": "human",
      "description": "Provisions subscriber credentials and dataset access before go-live"
    }
  ],
