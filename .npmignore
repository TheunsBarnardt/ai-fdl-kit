# ai-fdl-kit — npm publish ignore list
# Note: we also use `files` in package.json as an allow-list.
# This file exists as a belt-and-braces backup.

# Working files
.git/
.github/
.claude/
.cursor/
.vscode/
.fdl/
.gitignore
.gitattributes

# Blueprints live remotely — do not bundle them all into the npm tarball
blueprints/
docs/
tests/
tmp/
tmp-bda-pdfs/

# Source scripts that aren't needed by CLI consumers
scripts/generate-api.js
scripts/generate-docs.js
scripts/add_rules_temp.py

# Schema source (we ship the compiled copy under schema/)
# (Keep schema/blueprint.schema.yaml via files[])

# Dev artifacts
node_modules/
*.log
.DS_Store
Thumbs.db
*.proposed.blueprint.yaml

# Project docs that aren't part of the published package
CONTRIBUTING.md
UsersC298.claudeplansserene-percolating-reddy-agent-a171cb8c114ebc290.md
fdl.config.example.yaml
