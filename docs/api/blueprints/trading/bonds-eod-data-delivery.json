  "rules": {
    "dissemination": [
      "MUST: Disseminate Zero Curve reports at 14:30, 15:30, and 17:30 SAST daily",
      "MUST: Generate MTM reports at 17:30 (T+3, T+1, T+0) and UTMTM reports at 15:30",
      "MUST: Publish Trade Detail and Instrument Detail reports at end of day",
      "MUST: Exclude trades reported and cancelled on the same day from all reports",
      "MUST: Include backdated trades reported on the day in all reports"
    ],
    "formats": [
      "MUST: Provide all MTM reports in both XLS and CSV formats",
      "MUST: Use comma delimiter for CSV files",
      "MUST: Use fixed column counts per report (MTM Detailed = 26, UTMTM = 28, Trade Detail = 16)"
    ],
    "identification": [
      "MUST: Use ISIN with ZAG prefix for all listed bonds",
      "MUST: Use bond code as short identifier, max 20 chars"
    ],
    "valuation": [
      "MUST: Calculate MTM yields for T+3, T+1, and T+0 settlement scenarios",
      "MUST: Include BEASSA Yield Curve worksheet only in MTM Detailed report",
      "SHOULD: Populate companion_bond for parallel yield curve shift calculations"
    ],
    "access_control": [
      "MUST: Verify subscriber entitlement before file generation",
      "MUST: Deliver files only via IDP FTP to provisioned subscribers"
    ]
  },
  "errors": [
    {
      "code": "BONDS_SUBSCRIBER_NOT_PROVISIONED",
      "message": "Subscriber not provisioned for bonds market data products",
      "status": 403
    },
    {
      "code": "BONDS_FILE_GENERATION_FAILED",
      "message": "Failed to generate bonds EOD data file",
      "status": 500
    },
    {
      "code": "BONDS_DISSEMINATION_FAILED",
      "message": "Failed to disseminate bonds data file via FTP",
      "status": 500
    },
    {
      "code": "BONDS_INVALID_REPORT_DATE",
      "message": "Report date is invalid or report unavailable for requested date",
      "status": 400
    }
  ],
  "outcomes": {
    "generate_zero_curve_1430": {
      "priority": 1,
      "description": "Zero Curve report generated and disseminated at 14:30 daily",
      "given": [
        "system time reaches 14:30 SAST",
        "daily curve inputs are available"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "zero_curve_report",
          "description": "Build ZeroCurve<CCYYMMDD>.xls with Zeroes, Compact, and Inputs worksheets"
        },
        {
          "action": "call_service",
          "target": "idp_ftp_dissemination"
        },
        {
          "action": "emit_event",
          "event": "bonds.zero_curve.1430.disseminated"
        }
      ]
    },
    "generate_zero_curve_1530": {
      "priority": 2,
      "description": "Zero Curve report disseminated at 15:30 with updated inputs",
      "given": [
        "system time reaches 15:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "zero_curve_report_1530"
        },
        {
          "action": "emit_event",
          "event": "bonds.zero_curve.1530.disseminated"
        }
      ]
    },
    "generate_zero_curve_1730": {
      "priority": 3,
      "description": "Final Zero Curve report disseminated at 17:30",
      "given": [
        "system time reaches 17:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "zero_curve_report_1730"
        },
        {
          "action": "emit_event",
          "event": "bonds.zero_curve.1730.disseminated"
        }
      ]
    },
    "generate_zaronia_zero_curve": {
      "priority": 4,
      "description": "ZARONIA Zero Curve (Zaronia Swap Curve) disseminated 3 times daily",
      "given": [
        "system time reaches 14:30, 15:30, or 17:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "zaronia_zero_curve"
        },
        {
          "action": "emit_event",
          "event": "bonds.zaronia_curve.disseminated"
        }
      ]
    },
    "generate_mtm_detailed_1730": {
      "priority": 5,
      "description": "MTM Detailed report (T+3 settlement) disseminated at 17:30",
      "given": [
        "system time reaches 17:30 SAST",
        "all trades for the day have been processed"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "mtm_detailed_report",
          "description": "MTMDetailed<CCYYMMDD>.xls with MTM sheet (26 cols) and BEASSA Yield Curve sheet"
        },
        {
          "action": "create_record",
          "type": "mtm_detailed_csv"
        },
        {
          "action": "emit_event",
          "event": "bonds.mtm_detailed.disseminated"
        }
      ]
    },
    "generate_mtm_t1_1730": {
      "priority": 6,
      "description": "MTM T+1 report (T+1 settlement valuations) disseminated at 17:30",
      "given": [
        "system time reaches 17:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "mtm_t1_report"
        },
        {
          "action": "emit_event",
          "event": "bonds.mtm_t1.disseminated"
        }
      ]
    },
    "generate_mtm_value_today_1730": {
      "priority": 7,
      "description": "MTM Value Today report (T+0 settlement) disseminated at 17:30",
      "given": [
        "system time reaches 17:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "mtm_value_today_report"
        },
        {
          "action": "emit_event",
          "event": "bonds.mtm_value_today.disseminated"
        }
      ]
    },
    "generate_utmtm_reports_1530": {
      "priority": 8,
      "description": "UTMTM, UTMTM+1, and UTMTM Value Today reports (Unit Trust MTM, 15:00 data) disseminated at 15:30",
      "given": [
        "system time reaches 15:30 SAST"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "utmtm_reports",
          "description": "Three Unit Trust MTM reports for T+3, T+1, T+0 settlement"
        },
        {
          "action": "emit_event",
          "event": "bonds.utmtm.disseminated"
        }
      ]
    },
    "generate_trade_detail_eod": {
      "priority": 9,
      "description": "Trade Detail report with all reported trades for the day",
      "given": [
        "end of day batch triggered"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "trade_detail_report",
          "description": "TradeDetail_Daily<CCYYMMDD>.xls/.csv with 16 columns (excludes same-day cancelled trades)"
        },
        {
          "action": "emit_event",
          "event": "bonds.trade_detail.disseminated"
        }
      ]
    },
    "generate_instrument_detail_eod": {
      "priority": 10,
      "description": "Instrument Detail statistical report per trade type",
      "given": [
        "end of day batch triggered"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "instrument_detail_report",
          "description": "InstrumentDetail_Daily<CCYYMMDD>.xls/.csv with turnover stats per trade type"
        },
        {
          "action": "emit_event",
          "event": "bonds.instrument_detail.disseminated"
        }
      ]
    },
    "generate_member_client_position_eod": {
      "priority": 11,
      "description": "Member/Client Position report with Buy/Sell split per member/local/foreign",
      "given": [
        "end of day batch triggered"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "member_client_position_report"
        },
        {
          "action": "emit_event",
          "event": "bonds.member_client_position.disseminated"
        }
      ]
    },
    "ftp_dissemination_failure": {
      "priority": 12,
      "error": "BONDS_DISSEMINATION_FAILED",
      "description": "FTP dissemination to IDP fails",
      "given": [
        "any bonds EOD file generation succeeds",
        {
          "field": "ftp_transfer_status",
          "source": "system",
          "operator": "eq",
          "value": "failed"
        }
      ],
      "then": [
        {
          "action": "notify",
          "channel": "operations",
          "target": "exchange_operations"
        },
        {
          "action": "emit_event",
          "event": "bonds.dissemination.failed"
        }
      ]
    },
    "subscriber_not_provisioned": {
      "priority": 13,
      "error": "BONDS_SUBSCRIBER_NOT_PROVISIONED",
      "description": "Subscriber attempts to retrieve file without entitlement",
      "given": [
        {
          "field": "subscriber_entitled",
          "source": "db",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "bonds.access_denied"
        }
      ]
    }
  },
