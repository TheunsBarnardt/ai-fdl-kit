{
  "feature": "broker-derivatives",
  "version": "1.0.0",
  "description": "Nightly derivatives upload into the broker back-office producing automatic margin and mark-to-market journals, booking-fee and brokerage calculation, and position enquiry for futures and options",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "derivatives",
    "futures",
    "options",
    "margin",
    "mark-to-market",
    "booking-fees",
    "brokerage",
    "positions"
  ],
  "aliases": [
    "derivatives-upload",
    "futures-and-options",
    "safex-upload",
    "derivative-positions",
    "margin-journals",
    "mtm-journals",
    "contract-rate-table",
    "derivatives-back-office"
  ],
  "actors": [
    {
      "id": "broker_operator",
      "name": "Broker Back-Office Operator",
      "type": "human"
    },
    {
      "id": "derivatives_clerk",
      "name": "Derivatives Clerk",
      "type": "human",
      "description": "Loads and maintains contract rate table and derivative account codes"
    },
    {
      "id": "account_supervisor",
      "name": "Account Supervisor",
      "type": "human"
    },
    {
      "id": "back_office_system",
      "name": "Back-Office Accounting System",
      "type": "system"
    },
    {
      "id": "derivatives_exchange",
      "name": "Derivatives Exchange",
      "type": "external",
      "description": "Upstream derivatives trading system supplying nightly contract files"
    },
    {
      "id": "clearing_house",
      "name": "Clearing House",
      "type": "external",
      "description": "Initial and variation margin counterparty"
    }
  ],
  "fields": [
    {
      "name": "broker_code",
      "type": "text",
      "required": true,
      "label": "Broker Code"
    },
    {
      "name": "derivatives_broker_code",
      "type": "text",
      "required": true,
      "label": "Derivatives Broker Code"
    },
    {
      "name": "derivatives_user_flag",
      "type": "boolean",
      "required": true,
      "label": "Derivatives Upload Enabled Flag"
    },
    {
      "name": "account_code",
      "type": "text",
      "required": true,
      "label": "Client Account Code"
    },
    {
      "name": "derivatives_account_code",
      "type": "text",
      "required": true,
      "label": "Client Derivatives Account Code"
    },
    {
      "name": "rate_classification",
      "type": "text",
      "required": true,
      "label": "Contract Rate Classification"
    },
    {
      "name": "instrument_code",
      "type": "text",
      "required": true,
      "label": "Instrument Code"
    },
    {
      "name": "contract_type",
      "type": "select",
      "required": true,
      "label": "Contract Type"
    },
    {
      "name": "option_type",
      "type": "select",
      "required": false,
      "label": "Option Type"
    },
    {
      "name": "contract_expiry_date",
      "type": "date",
      "required": true,
      "label": "Contract Expiry Date"
    },
    {
      "name": "strike_price",
      "type": "number",
      "required": false,
      "label": "Strike Price"
    },
    {
      "name": "trade_price",
      "type": "number",
      "required": true,
      "label": "Trade Price"
    },
    {
      "name": "contract_reference",
      "type": "text",
      "required": true,
      "label": "Contract Reference"
    },
    {
      "name": "number_of_contracts",
      "type": "number",
      "required": true,
      "label": "Number of Contracts"
    },
    {
      "name": "buy_sell_indicator",
      "type": "select",
      "required": true,
      "label": "Buy or Sell Indicator"
    },
    {
      "name": "principal_agent_option",
      "type": "select",
      "required": false,
      "label": "Principal or Agent Option"
    },
    {
      "name": "rate_from_date",
      "type": "date",
      "required": true,
      "label": "Rate Effective From Date"
    },
    {
      "name": "brokerage_rate",
      "type": "number",
      "required": true,
      "label": "Brokerage Rate Per Contract"
    },
    {
      "name": "booking_fee",
      "type": "number",
      "required": true,
      "label": "Booking Fee Per Contract Band"
    },
    {
      "name": "contract_count_band",
      "type": "number",
      "required": true,
      "label": "Contract Count Band Ceiling"
    },
    {
      "name": "opening_position",
      "type": "number",
      "required": true,
      "label": "Opening Position"
    },
    {
      "name": "buy_quantity",
      "type": "number",
      "required": true,
      "label": "Buy Quantity"
    },
    {
      "name": "sell_quantity",
      "type": "number",
      "required": true,
      "label": "Sell Quantity"
    },
    {
      "name": "closing_position",
      "type": "number",
      "required": true,
      "label": "Closing Position"
    },
    {
      "name": "initial_margin_amount",
      "type": "number",
      "required": false,
      "label": "Initial Margin Amount"
    },
    {
      "name": "variation_margin_amount",
      "type": "number",
      "required": false,
      "label": "Variation Margin (Mark-to-Market) Amount"
    },
    {
      "name": "mark_to_market_price",
      "type": "number",
      "required": false,
      "label": "Mark-to-Market Closing Price"
    },
    {
      "name": "futures_balance",
      "type": "number",
      "required": true,
      "label": "Futures Balance on Account"
    },
    {
      "name": "trading_balance",
      "type": "number",
      "required": true,
      "label": "Trading Balance on Account"
    },
    {
      "name": "position_status",
      "type": "select",
      "required": true,
      "label": "Position Status"
    },
    {
      "name": "upload_process_date",
      "type": "date",
      "required": true,
      "label": "Nightly Upload Process Date"
    },
    {
      "name": "non_resident_flag",
      "type": "boolean",
      "required": false,
      "label": "Non-Resident Client Flag"
    }
  ],
  "states": {
    "field": "position_status",
    "values": [
      {
        "name": "opened",
        "initial": true
      },
      {
        "name": "marked_to_market"
      },
      {
        "name": "closed",
        "terminal": true
      }
    ],
    "transitions": [
      {
        "from": "opened",
        "to": "marked_to_market",
        "actor": "back_office_system",
        "description": "Nightly upload applies daily variation margin against the open position"
      },
      {
        "from": "marked_to_market",
        "to": "marked_to_market",
        "actor": "back_office_system",
        "description": "Subsequent daily mark-to-market cycles continue while position remains open"
      },
      {
        "from": "marked_to_market",
        "to": "closed",
        "actor": "back_office_system",
        "description": "Offsetting trade, expiry, or exercise closes the position"
      },
      {
        "from": "opened",
        "to": "closed",
        "actor": "back_office_system",
        "description": "Same-day close-out before first mark-to-market cycle"
      }
    ]
  },
  "rules": {
    "upload": {
      "nightly_interface": "Derivatives contract file is uploaded from the exchange into the back-office once per business day, after market close",
      "idempotent_processing": "Each contract reference may only be booked once; duplicate references in a rerun are suppressed",
      "broker_flag_required": "Upload only processes for brokers flagged as derivatives users; other brokers are skipped",
      "prerequisite_setup": "Contract rate table must be loaded before client rate classification can be assigned"
    },
    "accounting": {
      "margin_journal": "Initial margin debits or credits the futures balance and sweeps funds to the clearing-house margin account",
      "mtm_journal": "Daily mark-to-market gains and losses post to the futures balance with an equal-and-opposite clearing-house leg",
      "booking_fee_journal": "Booking fees and brokerage are debited to the income balance with VAT calculated per jurisdiction rules",
      "month_end_sweep": "Income balance is squared off at month-end by transfer from trading balance where account remains in debit"
    },
    "fees": {
      "rate_lookup": "Booking fee and brokerage are looked up by broker, classification, account, instrument, contract type, and effective date",
      "contract_count_banding": "Fee is charged per contract up to the banded ceiling; bands stack for higher contract counts",
      "principal_vs_agent": "Principal trades (A, B) and agent trades (C, D) may attract different rates"
    },
    "positions": {
      "daily_snapshot": "Positions are captured daily as opening, buys, sells, and closing per instrument and expiry",
      "close_calculation": "Closing position equals opening plus buys minus sells for each contract and expiry",
      "history_retention": "Derivative trade history is retained for at least 24 months for enquiry"
    },
    "non_resident": {
      "segregation": "Non-resident client funds must flow through the non-resident trust account and never mix with resident funds",
      "pre_funded_margin": "Margin requirement must be pre-funded to the futures balance before daily sweep to clearing house"
    },
    "security": {
      "access_control": "Rate table and derivative account maintenance are restricted by resource access control",
      "segregation_of_duties": "Rate table changes require maintainer role; operators have enquiry only"
    },
    "compliance": {
      "popia_client_data": "Client personal information linked to a derivatives account must comply with POPIA lawful basis and minimisation",
      "exchange_control": "Non-resident derivative trading must follow exchange-control regulations for financial rand accounts",
      "audit_trail": "All journals, rate changes, and uploads are logged with user, timestamp, old/new values"
    }
  },
  "errors": [
    {
      "code": "DERIV_BROKER_NOT_ENABLED",
      "status": 409,
      "message": "Broker is not flagged as a derivatives user, upload skipped"
    },
    {
      "code": "DERIV_RATE_NOT_FOUND",
      "status": 404,
      "message": "No active contract rate found for broker, classification, instrument, and date"
    },
    {
      "code": "DERIV_DUPLICATE_CONTRACT",
      "status": 409,
      "message": "Contract reference has already been booked"
    },
    {
      "code": "DERIV_ACCOUNT_MISSING_CODE",
      "status": 422,
      "message": "Client account is missing derivatives account code or rate classification"
    },
    {
      "code": "DERIV_MARGIN_UNDERFUNDED",
      "status": 409,
      "message": "Futures balance is insufficient to cover initial margin requirement"
    },
    {
      "code": "DERIV_NON_RESIDENT_TRUST_VIOLATION",
      "status": 422,
      "message": "Non-resident client funds must flow through the non-resident trust account"
    },
    {
      "code": "DERIV_RATE_TABLE_NOT_LOADED",
      "status": 409,
      "message": "Contract rate table must be loaded before rate classification can be assigned"
    },
    {
      "code": "DERIV_UPLOAD_FILE_INVALID",
      "status": 422,
      "message": "Derivatives upload file failed schema or checksum validation"
    },
    {
      "code": "DERIV_POSITION_RECONCILIATION_FAIL",
      "status": 409,
      "message": "Computed closing position does not match exchange-reported closing position"
    }
  ],
  "events": [
    {
      "name": "derivatives.upload.started",
      "payload": [
        "broker_code",
        "upload_process_date",
        "file_reference",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.upload.completed",
      "payload": [
        "broker_code",
        "upload_process_date",
        "contracts_loaded",
        "journals_posted",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.upload.failed",
      "payload": [
        "broker_code",
        "upload_process_date",
        "error_code",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.contract.booked",
      "payload": [
        "account_code",
        "contract_reference",
        "instrument_code",
        "contract_type",
        "number_of_contracts",
        "trade_price",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.position.opened",
      "payload": [
        "account_code",
        "contract_reference",
        "instrument_code",
        "number_of_contracts",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.position.marked_to_market",
      "payload": [
        "account_code",
        "contract_reference",
        "variation_margin_amount",
        "mark_to_market_price",
        "upload_process_date"
      ]
    },
    {
      "name": "derivatives.position.closed",
      "payload": [
        "account_code",
        "contract_reference",
        "closing_position",
        "timestamp"
      ]
    },
    {
      "name": "derivatives.margin.journal_posted",
      "payload": [
        "account_code",
        "initial_margin_amount",
        "futures_balance",
        "upload_process_date"
      ]
    },
    {
      "name": "derivatives.mtm.journal_posted",
      "payload": [
        "account_code",
        "variation_margin_amount",
        "futures_balance",
        "upload_process_date"
      ]
    },
    {
      "name": "derivatives.fees.calculated",
      "payload": [
        "account_code",
        "contract_reference",
        "brokerage_amount",
        "booking_fee_amount",
        "vat_amount"
      ]
    },
    {
      "name": "derivatives.rate_table.updated",
      "payload": [
        "broker_code",
        "rate_classification",
        "instrument_code",
        "contract_type",
        "rate_from_date",
        "updated_by"
      ]
    }
  ],
  "outcomes": {
    "nightly_upload_success": {
      "priority": 1,
      "description": "Nightly derivatives file is received, validated, and applied producing contracts, positions, and journals",
      "given": [
        {
          "field": "derivatives_user_flag",
          "source": "db",
          "operator": "eq",
          "value": true
        },
        {
          "field": "upload_file_valid",
          "source": "input",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "derivatives.upload.started"
        },
        {
          "action": "create_record",
          "type": "derivative_contract"
        },
        {
          "action": "transition_state",
          "field": "position_status",
          "from": "opened",
          "to": "marked_to_market"
        },
        {
          "action": "emit_event",
          "event": "derivatives.upload.completed"
        }
      ],
      "transaction": true
    },
    "reject_upload_broker_not_enabled": {
      "priority": 2,
      "error": "DERIV_BROKER_NOT_ENABLED",
      "description": "Skip upload for brokers not flagged as derivatives users",
      "given": [
        {
          "field": "derivatives_user_flag",
          "source": "db",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "derivatives.upload.failed"
        }
      ]
    },
    "reject_duplicate_contract": {
      "priority": 3,
      "error": "DERIV_DUPLICATE_CONTRACT",
      "description": "Suppress duplicate contract references on rerun",
      "given": [
        {
          "field": "contract_reference",
          "source": "db",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "derivatives.upload.failed"
        }
      ]
    },
    "calculate_booking_fee_and_brokerage": {
      "priority": 4,
      "description": "Look up the contract rate table and compute fees, contract banding, and VAT per contract",
      "given": [
        {
          "field": "rate_classification",
          "source": "db",
          "operator": "exists"
        },
        {
          "field": "instrument_code",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "contract_type",
          "source": "input",
          "operator": "in",
          "value": [
            "F",
            "O"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "rate_table_lookup"
        },
        {
          "action": "set_field",
          "target": "booking_fee",
          "value": "computed"
        },
        {
          "action": "set_field",
          "target": "brokerage_rate",
          "value": "computed"
        },
        {
          "action": "emit_event",
          "event": "derivatives.fees.calculated"
        }
      ],
      "transaction": true
    },
    "reject_missing_rate": {
      "priority": 5,
      "error": "DERIV_RATE_NOT_FOUND",
      "description": "No active rate matches the broker, classification, instrument, type, and effective date",
      "given": [
        {
          "field": "rate_lookup_result",
          "source": "computed",
          "operator": "not_exists"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "derivatives.upload.failed"
        }
      ]
    },
    "post_initial_margin_journal": {
      "priority": 6,
      "description": "Debit or credit the futures balance with initial margin on a newly opened position",
      "given": [
        {
          "field": "position_status",
          "source": "db",
          "operator": "eq",
          "value": "opened"
        },
        {
          "field": "initial_margin_amount",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "futures_balance",
          "value": "adjusted"
        },
        {
          "action": "emit_event",
          "event": "derivatives.margin.journal_posted"
        }
      ],
      "transaction": true
    },
    "post_mark_to_market_journal": {
      "priority": 7,
      "description": "Post daily variation margin reflecting price movement on open positions",
      "given": [
        {
          "field": "position_status",
          "source": "db",
          "operator": "in",
          "value": [
            "opened",
            "marked_to_market"
          ]
        },
        {
          "field": "variation_margin_amount",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "mark_to_market_price",
          "value": "updated"
        },
        {
          "action": "set_field",
          "target": "futures_balance",
          "value": "adjusted"
        },
        {
          "action": "transition_state",
          "field": "position_status",
          "from": "opened",
          "to": "marked_to_market"
        },
        {
          "action": "emit_event",
          "event": "derivatives.mtm.journal_posted"
        }
      ],
      "transaction": true
    },
    "close_position_on_offset": {
      "priority": 8,
      "description": "When buys and sells offset, or on expiry, transition the position to closed",
      "given": [
        {
          "field": "closing_position",
          "source": "computed",
          "operator": "eq",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "position_status",
          "from": "marked_to_market",
          "to": "closed"
        },
        {
          "action": "emit_event",
          "event": "derivatives.position.closed"
        }
      ]
    },
    "reject_non_resident_mixing": {
      "priority": 9,
      "error": "DERIV_NON_RESIDENT_TRUST_VIOLATION",
      "description": "Prevent non-resident derivative activity from mixing with resident trust funds",
      "given": [
        {
          "field": "non_resident_flag",
          "source": "db",
          "operator": "eq",
          "value": true
        },
        {
          "field": "funds_source",
          "source": "input",
          "operator": "neq",
          "value": "non_resident_trust"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "derivatives.upload.failed"
        }
      ]
    },
    "position_enquiry_snapshot": {
      "priority": 10,
      "description": "Return daily positions snapshot by account or broker as at an enquiry date",
      "given": [
        {
          "field": "enquiry_date",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "positions_snapshot"
        }
      ]
    }
  },
  "api": {
    "http": {
      "method": "POST",
      "path": "/api/v1/derivatives/uploads"
    },
    "request": {
      "schema": {
        "broker_code": "text",
        "upload_process_date": "date",
        "file_reference": "text",
        "contracts": "json"
      }
    },
    "response": {
      "success": {
        "status": 202,
        "schema": {
          "upload_id": "text",
          "contracts_loaded": "number",
          "journals_posted": "number"
        }
      },
      "errors": [
        {
          "error_code": "DERIV_BROKER_NOT_ENABLED",
          "status": 409
        },
        {
          "error_code": "DERIV_UPLOAD_FILE_INVALID",
          "status": 422
        },
        {
          "error_code": "DERIV_DUPLICATE_CONTRACT",
          "status": 409
        },
        {
          "error_code": "DERIV_RATE_NOT_FOUND",
          "status": 404
        },
        {
          "error_code": "DERIV_MARGIN_UNDERFUNDED",
          "status": 409
        },
        {
          "error_code": "DERIV_NON_RESIDENT_TRUST_VIOLATION",
          "status": 422
        }
      ]
    }
  },
  "anti_patterns": [
    {
      "rule": "Do not post margin or mark-to-market journals intraday from preliminary exchange files",
      "why": "Preliminary files are restated; intraday postings create reconciliation breaks with official end-of-day file"
    },
    {
      "rule": "Do not hard-code brokerage and booking fees in application code",
      "why": "Rates change per broker, classification, instrument, and date; table-driven lookup is required for auditable fee changes"
    },
    {
      "rule": "Do not allow derivative trading without a loaded derivatives account code and rate classification",
      "why": "Missing codes cause fee miscalculation and unreconcilable clearing-house breaks"
    },
    {
      "rule": "Do not fund non-resident margin from resident trust balances",
      "why": "Exchange-control regulations prohibit mixing; breach carries regulatory penalty and reporting obligation"
    },
    {
      "rule": "Do not delete derivative trade history inside the retention window",
      "why": "Audit, tax, and regulatory enquiries require full trade history for the defined retention period"
    },
    {
      "rule": "Do not reprocess the nightly upload without idempotency checks on contract reference",
      "why": "Reruns without idempotency duplicate journals and distort margin and income balances"
    }
  ],
  "related": [
    {
      "feature": "broker-client-account-maintenance",
      "type": "required"
    },
    {
      "feature": "popia-compliance",
      "type": "required"
    },
    {
      "feature": "broker-client-data-upload",
      "type": "recommended"
    }
  ],
  "extensions": {
    "screens": {
      "BROKM": "Broker Maintenance — derivatives broker code and upload flag",
      "T.BKF": "Contract Rate Table — booking fees and brokerage by broker, class, instrument, type, date",
      "CLMNT": "Client Account Maintenance — derivatives account code and rate classification",
      "AGMNT": "Agent Account Maintenance — derivatives account code and rate classification",
      "ASAFH": "Account Derivatives History — per-account contract history by balance code and date",
      "ASAFP": "Derivative Positions — opening, buys, sells, closing positions as at enquiry date"
    },
    "contract_types": {
      "F": "Future",
      "O": "Option"
    },
    "option_types": {
      "C": "Call",
      "P": "Put"
    },
    "principal_agent_options": {
      "A": "Dealt as principal",
      "B": "Dealt as principal",
      "C": "Dealt as agent",
      "D": "Dealt as agent"
    }
  }
}