      "schema": {
        "account_code": "text",
        "instrument_code": "text",
        "purchase_sale_indicator": "select",
        "quantity": "number",
        "amount": "number",
        "settlement_date": "date"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "availability_status": "select",
          "quantity_short": "number",
          "amount_short": "number",
          "trading_limit": "number",
          "limit_utilisation": "number"
        }
      },
