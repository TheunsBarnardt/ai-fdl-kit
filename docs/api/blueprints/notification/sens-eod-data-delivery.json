  "rules": {
    "format": [
      "MUST: Use NewsML-G2 standard v2.9 with power conformance",
      "MUST: Use Windows-1252 encoding for XML and announcement text",
      "MUST: Use UTC ISO 8601 timestamps with milliseconds (CCYY-MM-DDTHH:MM:SS.sssZ)",
      "MUST: Limit headline to 150 characters maximum",
      "MUST: Limit plain text announcement size to 4MB",
      "SHOULD: Limit PDF announcements to 10MB (configurable)"
    ],
    "identification": [
      "MUST: Use standard GUID format with announcement reference and product code",
      "MUST: Use announcement number format CCYYMMDDNNNNNA (never recycled)",
      "MUST: Include altId with AnnNo and AnnRefNo for every announcement"
    ],
    "classification": [
      "MUST: Set urgency=1 for price-sensitive, urgency=4 for non-price-sensitive",
      "MUST: Use AnnRegCde R for regulatory, N for non-regulatory",
      "MUST: Omit announcement_group_code for company announcements with listed shares",
      "MUST: Include announcement_group_code for no-share companies, exchanges, and regulators"
    ],
    "corrections": [
      "MUST: Use signal=CorTyp:Cncl for cancellations with pubStatus=stat:canceled",
      "MUST: Use signal=CorTyp:Repl for replacements referencing previousVersion GUID",
      "MUST NOT: Cancel PackageItems (use replacement only)"
    ],
    "delivery": [
      "MUST: Group all daily announcements into end-of-day PackageItem with Wrapup genre",
      "MUST: Deliver as compressed ZIP via IDP FTP"
    ]
  },
  "errors": [
    {
      "code": "SENS_SUBSCRIBER_NOT_PROVISIONED",
      "message": "Subscriber not provisioned for SENS data product",
      "status": 403
    },
    {
      "code": "SENS_NEWSML_VALIDATION_FAILED",
      "message": "NewsML-G2 XML failed schema validation",
      "status": 422
    },
    {
      "code": "SENS_ANNOUNCEMENT_TEXT_TOO_LARGE",
      "message": "Announcement text exceeds 4MB limit",
      "status": 413
    },
    {
      "code": "SENS_PDF_TOO_LARGE",
      "message": "Announcement PDF exceeds configured size limit",
      "status": 413
    },
    {
      "code": "SENS_HEADLINE_TOO_LONG",
      "message": "Announcement headline exceeds 150 character limit",
      "status": 422
    },
    {
      "code": "SENS_PACKAGE_GENERATION_FAILED",
      "message": "Failed to generate end-of-day SENS package",
      "status": 500
    }
  ],
  "outcomes": {
    "company_announcement_with_share": {
      "priority": 1,
      "description": "Company announcement when primary company has listed share",
      "given": [
        {
          "field": "announcement_class",
          "source": "input",
          "operator": "eq",
          "value": "company_with_share"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "company_org_id",
          "value": "primary_company_id"
        },
        {
          "action": "set_field",
          "target": "instrument_num_code",
          "value": "instrument_id"
        },
        {
          "action": "create_record",
          "type": "news_item_xml"
        },
        {
          "action": "emit_event",
          "event": "sens.company_announcement.created"
        }
      ]
    },
    "company_announcement_no_share": {
      "priority": 2,
      "description": "Company announcement when primary company has no share (debt issuer)",
      "given": [
        {
          "field": "announcement_class",
          "source": "input",
          "operator": "eq",
          "value": "company_no_share"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "company_org_id",
          "value": "primary_company_id"
        },
        {
          "action": "set_field",
          "target": "announcement_group_code",
          "value": "JSEO_or_NSXO"
        },
        {
          "action": "emit_event",
          "event": "sens.company_no_share_announcement.created"
        }
      ]
    },
    "exchange_announcement": {
      "priority": 3,
      "description": "Exchange announcement with EXCH group code and General role",
      "given": [
        {
          "field": "announcement_class",
          "source": "input",
          "operator": "eq",
          "value": "exchange"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "announcement_group_code",
          "value": "EXCH"
        },
        {
          "action": "set_field",
          "target": "company_role",
          "value": "General"
        },
        {
          "action": "emit_event",
          "event": "sens.exchange_announcement.created"
        }
      ]
    },
    "regulatory_institution_announcement": {
      "priority": 4,
      "description": "Regulatory institution announcement",
      "given": [
        {
          "field": "announcement_class",
          "source": "input",
          "operator": "eq",
          "value": "regulatory_institution"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "company_role",
          "value": "General"
        },
        {
          "action": "set_field",
          "target": "announcement_regulatory_code",
          "value": "R"
        },
        {
          "action": "emit_event",
          "event": "sens.regulatory_announcement.created"
        }
      ]
    },
    "price_sensitive_urgency_1": {
      "priority": 5,
      "description": "Price-sensitive announcements get urgency=1",
      "given": [
        {
          "field": "price_sensitivity_indicator",
          "source": "input",
          "operator": "eq",
          "value": "Y"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "urgency",
          "value": 1
        },
        {
          "action": "emit_event",
          "event": "sens.price_sensitive.flagged"
        }
      ]
    },
    "non_price_sensitive_urgency_4": {
      "priority": 6,
      "description": "Non-price-sensitive announcements get urgency=4",
      "given": [
        {
          "field": "price_sensitivity_indicator",
          "source": "input",
          "operator": "eq",
          "value": "N"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "urgency",
          "value": 4
        }
      ]
    },
    "announcement_cancellation": {
      "priority": 7,
      "description": "Cancellation correction with signal=Cncl",
      "given": [
        {
          "field": "correction_type",
          "source": "input",
          "operator": "eq",
          "value": "cancellation"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "signal",
          "value": "CorTyp:Cncl"
        },
        {
          "action": "set_field",
          "target": "pub_status",
          "value": "stat:canceled"
        },
        {
          "action": "emit_event",
          "event": "sens.announcement.cancelled"
        }
      ]
    },
    "announcement_replacement": {
      "priority": 8,
      "description": "Replacement correction with signal=Repl",
      "given": [
        {
          "field": "correction_type",
          "source": "input",
          "operator": "eq",
          "value": "replacement"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "signal",
          "value": "CorTyp:Repl"
        },
        {
          "action": "emit_event",
          "event": "sens.announcement.replaced"
        }
      ]
    },
    "headline_too_long": {
      "priority": 9,
      "error": "SENS_HEADLINE_TOO_LONG",
      "description": "Headline exceeds 150 characters",
      "given": [
        {
          "field": "headline_length",
          "source": "computed",
          "operator": "gt",
          "value": 150
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "sens.validation.headline_rejected"
        }
      ]
    },
    "eod_text_too_large": {
      "priority": 10,
      "error": "SENS_ANNOUNCEMENT_TEXT_TOO_LARGE",
      "description": "Plain text announcement exceeds 4MB",
      "given": [
        {
          "field": "inline_data_size_bytes",
          "source": "computed",
          "operator": "gt",
          "value": 4194304
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "sens.validation.text_too_large"
        }
      ]
    },
    "eod_pdf_too_large": {
      "priority": 11,
      "error": "SENS_PDF_TOO_LARGE",
      "description": "PDF exceeds configured limit (default 10MB)",
      "given": [
        {
          "field": "remote_content_size",
          "source": "input",
          "operator": "gt",
          "value": 10485760
        }
      ],
      "then": [
        {
          "action": "notify",
          "channel": "operations",
          "target": "exchange_operations"
        },
        {
          "action": "emit_event",
          "event": "sens.validation.pdf_too_large"
        }
      ]
    },
    "generate_eod_package": {
      "priority": 12,
      "description": "End-of-day PackageItem groups daily announcements into zip",
      "given": [
        "end of trading day reached"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "package_item_xml"
        },
        {
          "action": "call_service",
          "target": "compress_eod_package"
        },
        {
          "action": "call_service",
          "target": "idp_ftp_dissemination"
        },
        {
          "action": "emit_event",
          "event": "sens.eod_package.disseminated"
        }
      ]
    }
  },
  "extensions": {
    "product_codes": {
      "eod_sens": {
        "code": "ETNI",
        "description": "End of Day SENS NewsItem - plain text",
        "item_class": "ninat:text",
        "content_type": "text/plain",
        "encoding": "windows-1252",
        "max_size_mb": 4
      },
      "eod_sens_plus": {
        "code": "EPNI",
        "description": "End of Day SENS Plus NewsItem - PDF",
        "item_class": "ninat:composite",
        "content_type": "application/pdf",
        "default_max_size_mb": 10
      },
      "eod_sens_package": {
        "code": "ETPI",
        "description": "End of Day SENS PackageItem for text product"
      },
      "eod_sens_plus_package": {
        "code": "EPPI",
        "description": "End of Day SENS Plus PackageItem for PDF product"
      }
    },
    "announcement_categories": {
      "dual_listed": [
        "Company announcements",
        "Exchange announcements"
      ],
      "single_listed": [
        "Company announcements (with share)",
        "Company announcements (no share - debt issuers)",
        "Exchange announcements",
        "Regulatory institution announcements"
      ]
