  "rules": {
    "dissemination": [
      "MUST: Publish Bonds Instrument Reference 3x daily (SLA 11:30, 13:30, 16:20 SAST)",
      "MUST: Publish New Bonds Listing 3x daily at the same SLA times",
      "MUST: Retain daily files for rolling 40 business days with _yyyymmdd suffix",
      "MUST: Replace entire file each time (no delta changes)"
    ],
    "identification": [
      "MUST: Generate ISIN per ISO 6166 (12 chars, 2-letter country + 9-char identifier + check digit)",
      "MUST: Use G in 3rd character of ISIN for debt securities",
      "MUST: Assign alpha code as primary identifier (max 6 alphanumeric, uppercase)"
    ],
    "lifecycle": [
      "MUST: Include new instrument on Issue date with status Listed",
      "MUST: Retain instrument until month-end of status change month for delisted/matured/called/redeemed/repurchased",
      "MUST: Create Callable/Step Up events at least 4 days before effective date"
    ],
    "formats": [
      "MUST: Provide CSV (one file per section) and XLS (consolidated workbook) formats",
      "MUST: Use comma delimiter for CSV and blank row separators between files"
    ],
    "access_control": [
      "MUST: Verify subscriber entitlement before file generation"
    ]
  },
  "errors": [
    {
      "code": "BONDS_REF_SUBSCRIBER_NOT_PROVISIONED",
      "message": "Subscriber not provisioned for bonds reference data products",
      "status": 403
    },
    {
      "code": "BONDS_REF_FILE_GENERATION_FAILED",
      "message": "Failed to generate bonds reference data file",
      "status": 500
    },
    {
      "code": "BONDS_REF_INVALID_ISIN",
      "message": "Generated ISIN does not conform to ISO 6166",
      "status": 400
    },
    {
      "code": "BONDS_REF_MISSING_REQUIRED_FIELD",
      "message": "Required reference field missing for listed instrument",
      "status": 422
    }
  ],
  "outcomes": {
    "generate_bonds_instrument_reference_daily": {
      "priority": 1,
      "description": "Daily Bonds Instrument Reference file published 3 times per day (SLA 11:30, 13:30, 16:20)",
      "given": [
        "scheduled dissemination time reached"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "bonds_instrument_reference_file",
          "description": "Generate 12 CSV files + 1 consolidated XLS workbook with General, Redemption Schedule, Coupon General, Coupon Schedule, Callable Step Up, Market Listing, Split Maturity, Reference Index, Reference Instrument, Reference Entities, Guarantor, Mixed Rate sheets"
        },
        {
          "action": "call_service",
          "target": "idp_ftp_dissemination"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.instrument_reference.disseminated"
        }
      ]
    },
    "generate_new_bonds_listing_daily": {
      "priority": 2,
      "description": "New Bonds Listing file published 3 times per day (11:30, 13:30, 16:20)",
      "given": [
        "scheduled dissemination time reached"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "new_bonds_listing_file",
          "description": "13 CSV files + 1 consolidated XLS covering instruments in process of listing (status Draft Approved, Pre-Listed, Listed Pending Coupon, Cancelled)"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.new_listings.disseminated"
        }
      ]
    },
    "generate_corporate_actions_schedule": {
      "priority": 3,
      "description": "Bonds Corporate Actions Events Schedule disseminated daily",
      "given": [
        "end of day corporate actions processing complete"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "corporate_actions_schedule_file"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.corporate_actions.disseminated"
        }
      ]
    },
    "generate_coupon_rate_update": {
      "priority": 4,
      "description": "Bonds Coupon Rate Update disseminated when floating rate notes reset",
      "given": [
        "coupon reset date reached for floating rate instrument"
      ],
      "then": [
        {
          "action": "create_record",
          "type": "coupon_rate_update_file"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.coupon_rate_update.disseminated"
        }
      ]
    },
    "instrument_listed_new": {
      "priority": 5,
      "description": "New instrument included on Issue date with status 'Listed'",
      "given": [
        {
          "field": "instrument_status",
          "source": "input",
          "operator": "eq",
          "value": "Listed"
        },
        {
          "field": "issue_date",
          "source": "input",
          "operator": "eq",
          "value": "today"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "listed_flag",
          "value": true
        },
        {
          "action": "create_record",
          "type": "instrument_reference_row"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.instrument.listed"
        }
      ]
    },
    "instrument_delisted_or_matured": {
      "priority": 6,
      "description": "Instrument remains in file until month-end of status change month",
      "given": [
        {
          "field": "instrument_status",
          "source": "input",
          "operator": "in",
          "value": [
            "Delisted",
            "Matured",
            "Called",
            "Redeemed",
            "Repurchased"
          ]
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "maturity_date",
          "value": "effective_date_of_status_change"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.instrument.retired"
        }
      ]
    },
    "isin_generation_fails": {
      "priority": 7,
      "error": "BONDS_REF_INVALID_ISIN",
      "description": "ISIN validation fails (must be 12 chars, G in 3rd position for debt)",
      "given": [
        {
          "any": [
            {
              "field": "isin",
              "source": "computed",
              "operator": "matches",
              "value": "^.{0,11}$"
            },
            {
              "field": "isin_third_character",
              "source": "computed",
              "operator": "neq",
              "value": "G"
            }
          ]
        }
      ],
      "then": [
        {
          "action": "notify",
          "channel": "operations",
          "target": "national_numbering_agency"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.isin.generation_failed"
        }
      ]
    },
    "callable_step_up_event_created": {
      "priority": 8,
      "description": "Callable / Step Up event created at least 4 days before effective date",
      "given": [
        {
          "field": "callable_step_up_date",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "days_until_effective",
          "source": "computed",
          "operator": "gte",
          "value": 4
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "callable_step_up_event"
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.callable_step_up.created"
        }
      ]
    },
    "historical_retention_40_days": {
      "priority": 9,
      "description": "Daily files retained on IDP for rolling 40 business days with _yyyymmdd suffix",
      "given": [
        "file disseminated successfully"
      ],
      "then": [
        {
          "action": "set_field",
          "target": "retention_days",
          "value": 40
        },
        {
          "action": "emit_event",
          "event": "bonds_ref.file.archived"
        }
      ]
    }
  },
  "extensions": {
