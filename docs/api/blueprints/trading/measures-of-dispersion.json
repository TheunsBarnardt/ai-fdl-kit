{
  "feature": "measures-of-dispersion",
  "version": "1.0.0",
  "description": "Compute measures of dispersion — range, mean absolute deviation (MAD), variance, standard deviation, and coefficient of variation — to describe variability of observations around their mean",
  "category": "trading",
  "tags": [
    "quantitative-methods",
    "descriptive-statistics",
    "dispersion",
    "variance",
    "standard-deviation",
    "mad",
    "coefficient-of-variation",
    "volatility",
    "cfa-level-1"
  ],
  "aliases": [
    "variance",
    "standard-deviation",
    "mad",
    "mean-absolute-deviation",
    "coefficient-of-variation",
    "cv",
    "range",
    "volatility",
    "dispersion"
  ],
  "actors": [
    {
      "id": "statistics_engine",
      "name": "Statistical Analytics Engine",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "observations",
      "type": "json",
      "required": true,
      "label": "Array of numeric observations"
    },
    {
      "name": "measure",
      "type": "select",
      "required": true,
      "label": "range | mad | variance | std_dev | cv"
    },
    {
      "name": "population_or_sample",
      "type": "select",
      "required": false,
      "label": "sample (default, uses n-1) | population (uses N)"
    },
    {
      "name": "annualise",
      "type": "boolean",
      "required": false,
      "label": "Annualise std_dev by multiplying by sqrt(periods_per_year)"
    },
    {
      "name": "periods_per_year",
      "type": "number",
      "required": false,
      "label": "For annualisation (252 trading days, 12 months, 4 quarters)"
    }
  ],
  "rules": {
    "core_formulas": {
      "range": "max(X) - min(X)",
      "mad": "MAD = (1/n) * sum(|X_i - X_bar|)",
      "sample_variance": "s^2 = (1/(n-1)) * sum((X_i - X_bar)^2)",
      "population_variance": "sigma^2 = (1/N) * sum((X_i - mu)^2)",
      "sample_std_dev": "s = sqrt(s^2)",
      "coefficient_of_variation": "CV = s / X_bar",
      "annualisation": "sigma_annual = sigma_period * sqrt(periods_per_year)"
    },
    "bessel_correction": {
      "rule": "Sample variance uses n-1 (Bessel's correction) to produce an unbiased estimator; population variance uses N",
      "why": "Using n biases variance downward because X_bar is itself estimated from the sample"
    },
    "properties": {
      "units": {
        "variance": "Square of the data units (e.g., return² )",
        "std_dev": "Same units as the data (e.g., decimal return)",
        "mad": "Same units as the data",
        "cv": "Unit-free (scale-invariant)"
      },
      "relationships": {
        "sd_gte_mad": "Standard deviation >= MAD for any dataset",
        "cv_comparison": "CV allows comparison of dispersion across different-magnitude datasets"
      }
    },
    "applications": {
      "volatility": "Annualised standard deviation is the industry-standard volatility measure",
      "risk_adjusted_return": "CV of returns compares risk per unit of return; lower = more efficient"
    },
    "validation": {
      "non_empty": "observations array must be non-empty",
      "sufficient_for_sample": "n >= 2 for sample variance (n-1 denominator)",
      "cv_mean_nonzero": "Mean must be non-zero (and typically positive) for CV to be meaningful"
    }
  },
  "outcomes": {
    "compute_range": {
      "priority": 1,
      "description": "Range",
      "given": [
        {
          "field": "measure",
          "source": "input",
          "operator": "eq",
          "value": "range"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "statistics_engine"
        },
        {
          "action": "emit_event",
          "event": "stats.dispersion_calculated"
        }
      ]
    },
    "compute_mad": {
      "priority": 2,
      "description": "Mean absolute deviation",
      "given": [
        {
          "field": "measure",
          "source": "input",
          "operator": "eq",
          "value": "mad"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "statistics_engine"
        },
        {
          "action": "emit_event",
          "event": "stats.dispersion_calculated"
        }
      ]
    },
    "compute_variance": {
      "priority": 3,
      "description": "Variance (sample or population)",
      "given": [
        {
          "field": "measure",
          "source": "input",
          "operator": "eq",
          "value": "variance"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "statistics_engine"
        },
        {
          "action": "emit_event",
          "event": "stats.dispersion_calculated"
        }
      ]
    },
    "compute_std_dev": {
      "priority": 4,
      "description": "Standard deviation (optionally annualised)",
      "given": [
        {
          "field": "measure",
          "source": "input",
          "operator": "eq",
          "value": "std_dev"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "statistics_engine"
        },
        {
          "action": "emit_event",
          "event": "stats.dispersion_calculated"
        }
      ]
    },
    "compute_cv": {
      "priority": 5,
      "description": "Coefficient of variation",
      "given": [
        {
          "field": "measure",
          "source": "input",
          "operator": "eq",
          "value": "cv"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "statistics_engine"
        },
        {
          "action": "emit_event",
          "event": "stats.dispersion_calculated"
        }
      ]
    },
    "insufficient_sample": {
      "priority": 10,
      "description": "Fewer than 2 observations for sample variance",
      "given": [
        {
          "all": [
            {
              "field": "measure",
              "source": "input",
              "operator": "in",
              "value": [
                "variance",
                "std_dev"
              ]
            },
            {
              "field": "sample_size",
              "source": "computed",
              "operator": "lt",
              "value": 2
            }
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "stats.dispersion_rejected"
        }
      ],
      "error": "DISPERSION_INSUFFICIENT_SAMPLE"
    },
    "cv_mean_zero": {
      "priority": 11,
      "description": "CV undefined when mean is zero",
      "given": [
        {
          "all": [
            {
              "field": "measure",
              "source": "input",
              "operator": "eq",
              "value": "cv"
            },
            {
              "field": "mean",
              "source": "computed",
              "operator": "eq",
              "value": 0
            }
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "stats.dispersion_rejected"
        }
      ],
      "error": "DISPERSION_CV_MEAN_ZERO"
    },
    "empty_observations": {
      "priority": 12,
      "description": "Empty dataset",
      "given": [
        {
          "field": "observations",
          "source": "input",
          "operator": "not_exists"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "stats.dispersion_rejected"
        }
      ],
      "error": "DISPERSION_EMPTY"
    }
  },
  "errors": [
    {
      "code": "DISPERSION_EMPTY",
      "status": 400,
      "message": "Observations array must not be empty"
    },
    {
      "code": "DISPERSION_INSUFFICIENT_SAMPLE",
      "status": 400,
      "message": "Sample variance requires at least 2 observations"
    },
    {
      "code": "DISPERSION_CV_MEAN_ZERO",
      "status": 422,
      "message": "Coefficient of variation is undefined when the mean is zero"
    }
  ],
  "events": [
    {
      "name": "stats.dispersion_calculated",
      "payload": [
        "dataset_id",
        "measure",
        "value",
        "sample_size",
        "annualised"
      ]
    },
    {
      "name": "stats.dispersion_rejected",
      "payload": [
        "dataset_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not annualise monthly std dev by multiplying by 12 instead of sqrt(12)",
      "why": "Variance scales with time (linear), std dev scales with sqrt(time); linear scaling overstates annualised volatility by a factor of sqrt(12)"
    },
    {
      "rule": "Do not report CV for return series that cross zero",
      "why": "When X_bar ≈ 0, CV explodes and sign-flips; use absolute volatility or Sharpe-style ratios with risk-free benchmark instead"
    },
    {
      "rule": "Do not use range as the sole volatility measure",
      "why": "Range uses only two observations and is sensitive to a single outlier; always pair with MAD or std dev"
    },
    {
      "rule": "Do not apply the sqrt-time annualisation to non-iid return series",
      "why": "Annualisation assumes independently and identically distributed returns; autocorrelation (momentum or mean-reversion) violates this and biases the result"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/analytics/stats/dispersion"
    },
    "request": {
      "schema": {
        "observations": "array",
        "measure": "string",
        "population_or_sample": "string",
        "annualise": "boolean",
        "periods_per_year": "number"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "measure": "string",
          "value": "number",
          "sample_size": "number",
          "annualised": "boolean"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "DISPERSION_EMPTY"
        },
        {
          "status": 400,
          "error_code": "DISPERSION_INSUFFICIENT_SAMPLE"
        },
        {
          "status": 422,
          "error_code": "DISPERSION_CV_MEAN_ZERO"
        }
      ]
    }
  },
  "extensions": {
    "worked_example": {
      "scenario": "Monthly returns of a fund",
      "mean": 0.012,
      "sample_variance": 0.0009,
      "sample_std_dev": 0.03,
      "annualised_std_dev": 0.1039,
      "coefficient_of_variation": 2.5
    },
    "scale_comparison": {
      "note": "CV allows comparing dispersion of equity volatility (30%) vs short-term Treasury rate volatility (2%) on a like-for-like basis"
    }
  },
  "related": [
    {
      "feature": "measures-of-central-tendency",
      "type": "recommended"
    },
    {
      "feature": "target-downside-deviation",
      "type": "recommended"
    },
    {
      "feature": "skewness",
      "type": "recommended"
    },
    {
      "feature": "kurtosis",
      "type": "recommended"
    }
  ]
}