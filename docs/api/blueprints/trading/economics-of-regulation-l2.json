{
  "feature": "economics-of-regulation-l2",
  "version": "1.0.0",
  "description": "Analyse rationale, classifications, costs and benefits of regulation across financial markets, antitrust, prudential, and disclosure regimes",
  "category": "trading",
  "tags": [
    "economics",
    "regulation",
    "market-failure",
    "prudential",
    "disclosure",
    "cfa-level-2"
  ],
  "aliases": [
    "regulation-rationale-l2",
    "regulatory-tools-classification",
    "cost-benefit-regulation",
    "prudential-regulation-cfa",
    "antitrust-regulation",
    "disclosure-regulation-cfa",
    "regulatory-capture-risk"
  ],
  "actors": [
    {
      "id": "regulatory_analyst",
      "name": "Regulatory Analyst",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "regulation_id",
      "type": "text",
      "required": true,
      "label": "Regulation identifier"
    },
    {
      "name": "regulation_class",
      "type": "select",
      "required": true,
      "label": "statute | administrative | judicial | self_regulatory"
    }
  ],
  "rules": {
    "rationale": {
      "market_failure": "Externalities, public goods, asymmetric information, monopoly",
      "consumer_protection": "Information disparity between firm and customer",
      "systemic_risk": "Negative spillover from individual firm failure"
    },
    "classifications": {
      "statute": "Law passed by legislature",
      "administrative": "Agency rule under delegated authority",
      "judicial": "Court interpretation forming precedent",
      "self_regulatory": "Industry-organised body — exchanges, SROs"
    },
    "regulators": {
      "government_agencies": "Statutory authority",
      "independent_regulators": "Granted by statute, operationally independent",
      "sros": "Industry-funded; require recognition",
      "outside_bodies": "Standard-setters whose pronouncements regulators adopt"
    },
    "regulatory_tools": {
      "price_mechanisms": "Taxes, subsidies, tradable permits",
      "restricting_supply": "Licensing, quotas",
      "mandates": "Required actions or disclosures",
      "prohibitions": "Forbidden conduct",
      "provision_of_public_goods": "Government supply"
    },
    "cost_benefit": {
      "direct_costs": "Regulatory burden — compliance staff, systems",
      "indirect_costs": "Reduced innovation, regulatory arbitrage",
      "benefits": "Investor protection, market integrity, financial stability",
      "sunset_provisions": "Periodic re-examination"
    },
    "antitrust_regulation": {
      "objective": "Preserve competition; prohibit collusion, abuse of dominance",
      "merger_review": "Block deals reducing market contestability"
    },
    "prudential_regulation": {
      "capital_requirements": "Minimum buffers — Basel framework",
      "liquidity_requirements": "LCR, NSFR",
      "resolution_planning": "Living wills"
    },
    "disclosure_regulation": {
      "securities_acts": "Standardised filings reduce information asymmetry",
      "fair_disclosure": "Selective disclosure prohibited"
    },
    "regulatory_competition_capture": {
      "competition": "Jurisdictions compete to attract listings",
      "capture": "Regulator serves regulated industry, not public"
    },
    "validation": {
      "regulation_required": "regulation_id present",
      "valid_class": "regulation_class in [statute, administrative, judicial, self_regulatory]"
    }
  },
  "outcomes": {
    "analyse_regulation": {
      "priority": 1,
      "description": "Analyse regulation under cost-benefit framework",
      "given": [
        {
          "field": "regulation_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "regulation_class",
          "source": "input",
          "operator": "in",
          "value": [
            "statute",
            "administrative",
            "judicial",
            "self_regulatory"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "regulatory_analyst"
        },
        {
          "action": "emit_event",
          "event": "regulation.analysed"
        }
      ]
    },
    "invalid_class": {
      "priority": 10,
      "description": "Unsupported regulation class",
      "given": [
        {
          "field": "regulation_class",
          "source": "input",
          "operator": "not_in",
          "value": [
            "statute",
            "administrative",
            "judicial",
            "self_regulatory"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "regulation.analysis_rejected"
        }
      ],
      "error": "REG_INVALID_CLASS"
    }
  },
  "errors": [
    {
      "code": "REG_INVALID_CLASS",
      "status": 400,
      "message": "regulation_class must be statute, administrative, judicial, or self_regulatory"
    }
  ],
  "events": [
    {
      "name": "regulation.analysed",
      "payload": [
        "regulation_id",
        "regulation_class",
        "expected_benefit",
        "expected_cost",
        "net_assessment"
      ]
    },
    {
      "name": "regulation.analysis_rejected",
      "payload": [
        "regulation_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not assume regulation always produces net benefit",
      "why": "Regulation imposes direct and opportunity costs; cost-benefit analysis with sunset provisions guards against permanent rules with negative ROI"
    },
    {
      "rule": "Do not ignore regulatory arbitrage when designing rules",
      "why": "Capital and activity migrate to less-regulated jurisdictions; coordinated international rules (e.g. Basel) reduce arbitrage gaps"
    },
    {
      "rule": "Do not conflate self-regulation with absence of regulation",
      "why": "SROs operate under statutory authority and their failure becomes a public-policy issue; treat them as part of the regulatory ecosystem"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/economics/regulation/analyse"
    },
    "request": {
      "schema": {
        "regulation_id": "string",
        "regulation_class": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "regulation_id": "string",
          "net_assessment": "string"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "REG_INVALID_CLASS"
        }
      ]
    }
  },
  "related": [
    {
      "feature": "regulation-28-compliance",
      "type": "recommended"
    }
  ]
}