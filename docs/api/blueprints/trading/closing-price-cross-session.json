{
  "feature": "closing-price-cross-session",
  "version": "1.0",
  "category": "trading",
  "tags": [
    "equity-market",
    "trading-session",
    "order-management",
    "closing-price"
  ],
  "description": "Closing Price Cross (CPX) session enables market participants to trade in the central order book\nat the official closing price once determined. Introduces new Time in Force (TIF) of CPX for\norder direction, with two new trading sessions: Closing Price Publication (CPP) and Closing\nPrice Cross (CPX). CPX session initially pilot-phase for segment ZA01 only.\n",
  "actors": [
    {
      "id": "market_participant",
      "name": "Market Participant",
      "type": "human",
      "role": "Trader submitting orders during CPX session"
    },
    {
      "id": "jse_trading_system",
      "name": "JSE Trading System",
      "type": "system",
      "role": "Processes CPX orders and manages sessions"
    }
  ],
  "states": {
    "field": "session_status",
    "values": [
      {
        "value": "cpp_session",
        "label": "Closing Price Publication (CPP) Session",
        "description": "Five-minute session (ZA01) or one-minute (other segments) for closing price publication and participant confirmation",
        "initial": false
      },
      {
        "value": "cpx_session",
        "label": "Closing Price Cross (CPX) Session",
        "description": "Five-minute session (ZA01 only, pilot) for CPX order submission and matching at published closing price",
        "initial": false
      },
      {
        "value": "post_close",
        "label": "Post Close Session",
        "description": "Trade reporting session",
        "initial": false
      }
    ]
  },
  "outcomes": [
    {
      "name": "cpx_session_starts",
      "description": "CPX session begins after CPP completion and published closing price exists",
      "priority": 1,
      "given": [
        {
          "field": "closing_price_published",
          "source": "system",
          "operator": "exists"
        },
        {
          "field": "cpp_session_completed",
          "source": "system",
          "operator": "exists"
        },
        {
          "field": "segment",
          "source": "db",
          "operator": "eq",
          "value": "ZA01"
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "session_status",
          "from": "cpp_session",
          "to": "cpx_session"
        }
      ]
    },
    {
      "name": "cpx_order_with_valid_tif_accepted",
      "description": "New orders with valid TIF types (CPX, IOC, FOK, DAY, GTT, GTC, GTD) are accepted during CPX session",
      "priority": 2,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "field": "order_tif",
          "source": "input",
          "operator": "in",
          "value": [
            "CPX",
            "IOC",
            "FOK",
            "DAY",
            "GTT",
            "GTC",
            "GTD"
          ]
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "order_status",
          "value": "accepted"
        }
      ]
    },
    {
      "name": "cpx_market_order_accepted",
      "description": "Market orders with valid TIF are accepted and converted to limit orders if not fully matched",
      "priority": 3,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "field": "order_type",
          "source": "input",
          "operator": "eq",
          "value": "MARKET"
        },
        {
          "field": "order_tif",
          "source": "input",
          "operator": "in",
          "value": [
            "CPX",
            "IOC",
            "FOK",
            "DAY",
            "GTT",
            "GTC",
            "GTD"
          ]
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "order_status",
          "value": "accepted_to_orderbook"
        },
        {
          "action": "emit_event",
          "event": "cpx.market_order_accepted",
          "payload": [
            "order_id",
            "quantity",
            "tif"
          ]
        }
      ]
    },
    {
      "name": "cpx_limit_order_exact_price_match",
      "description": "Limit orders accepted only if price exactly matches published closing price",
      "priority": 4,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "field": "order_type",
          "source": "input",
          "operator": "eq",
          "value": "LIMIT"
        },
        {
          "field": "order_price",
          "source": "input",
          "operator": "eq",
          "value": "published_closing_price"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "order_status",
          "value": "accepted_to_orderbook"
        }
      ]
    },
    {
      "name": "cpx_limit_order_decimal_price_rejected",
      "description": "Limit orders rejected when published closing price contains decimals",
      "priority": 5,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "field": "order_type",
          "source": "input",
          "operator": "eq",
          "value": "LIMIT"
        },
        {
          "field": "closing_price_has_decimals",
          "source": "system",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "order_status",
          "value": "rejected"
        },
        {
          "action": "emit_event",
          "event": "cpx.limit_order_rejected_decimal_price",
          "payload": [
            "order_id",
            "closing_price"
          ]
        }
      ]
    },
    {
      "name": "cpx_invalid_order_types_rejected",
      "description": "Specific order types rejected during CPX session",
      "priority": 6,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "any": [
            {
              "field": "order_tif",
              "source": "input",
              "operator": "in",
              "value": [
                "GFA",
                "GFX",
                "OPG",
                "ATC"
              ]
            },
            {
              "field": "order_type",
              "source": "input",
              "operator": "in",
              "value": [
                "STOP",
                "STOP_LIMIT",
                "HIDDEN_LIMIT"
              ]
            }
          ]
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "order_status",
          "value": "rejected"
        }
      ]
    },
    {
      "name": "cpx_no_price_amendment_during_session",
      "description": "Price amendments rejected once CPX session begins",
      "priority": 7,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpx_session"
        },
        {
          "field": "amendment_type",
          "source": "input",
          "operator": "eq",
          "value": "PRICE"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "amendment_status",
          "value": "rejected"
        }
      ]
    },
    {
      "name": "cpp_session_no_new_orders",
      "description": "No new orders allowed during CPP session, only cancellations",
      "priority": 8,
      "given": [
        {
          "field": "session_status",
          "source": "system",
          "operator": "eq",
          "value": "cpp_session"
        },
        {
          "field": "action_type",
          "source": "input",
          "operator": "eq",
          "value": "NEW_ORDER"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "action_status",
          "value": "rejected"
        }
      ]
    },
    {
      "name": "cpp_session_starts",
      "description": "CPP session starts after closing auction or continuous trading completion",
      "priority": 9,
      "given": [
        {
          "field": "auction_completed",
          "source": "system",
          "operator": "exists"
        },
        {
          "field": "auction_extensions_resolved",
          "source": "system",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "session_status",
          "from": "continuous_trading",
          "to": "cpp_session"
        }
      ]
    }
  ],
  "fields": [
    {
      "name": "order_id",
      "type": "token",
      "required": true
    },
    {
      "name": "order_type",
      "type": "select",
      "required": true,
      "options": [
        "MARKET",
        "LIMIT",
        "STOP",
        "STOP_LIMIT",
        "HIDDEN_LIMIT"
      ]
    },
    {
      "name": "order_tif",
      "type": "select",
      "required": true,
      "options": [
        "GFA",
        "GFX",
        "OPG",
        "ATC",
        "CPX",
        "IOC",
        "FOK",
        "DAY",
        "GTT",
        "GTC",
        "GTD"
      ]
    },
    {
      "name": "order_price",
      "type": "number",
      "required": false
    },
    {
      "name": "quantity",
      "type": "number",
      "required": true
    },
    {
      "name": "segment",
      "type": "select",
      "required": true,
      "options": [
        "ZA01",
        "ZA02",
        "ZA03",
        "ZA04",
        "ZA06",
        "ZA11",
        "ZA12"
      ]
    },
    {
      "name": "session_status",
      "type": "select",
      "required": true,
      "options": [
        "cpp_session",
        "cpx_session",
        "post_close"
      ]
    },
    {
      "name": "published_closing_price",
      "type": "number",
      "required": true
    },
    {
      "name": "closing_price_has_decimals",
      "type": "boolean",
      "required": true
    },
    {
      "name": "order_status",
      "type": "select",
      "required": true,
      "options": [
        "accepted",
        "rejected",
        "accepted_to_orderbook",
        "executed",
        "expired",
        "open"
      ]
    },
    {
      "name": "amendment_type",
      "type": "select",
      "required": false,
      "options": [
        "PRICE",
        "QUANTITY",
        "OTHER"
      ]
    }
  ],
  "errors": [
    {
      "code": "CPX_SESSION_NO_CLOSING_PRICE",
      "message": "CPX session cannot start - no published closing price available",
      "severity": "error"
    },
    {
      "code": "CPX_INVALID_ORDER_TYPE",
      "message": "Order type not allowed during CPX session",
      "severity": "error"
    },
    {
      "code": "CPX_LIMIT_ORDER_PRICE_MISMATCH",
      "message": "Limit order price does not match published closing price",
      "severity": "error"
    }
  ],
  "related": [
    {
      "feature": "equity-market-trading",
      "type": "required"
    },
    {
      "feature": "order-management",
      "type": "required"
    },
    {
      "feature": "circuit-breaker-system",
      "type": "recommended"
    }
  ],
  "notes": [
    "CPX session initially available for ZA01 segment only (pilot phase)",
    "CPP session applies to all segments but CPX restricted to ZA01",
    "Published closing price may be VWAP-derived with decimals",
    "JSE tick size is one cent (0.01) for ZA01; decimals require market orders only",
    "Source: Volume C Guidance Note v1.00 (05 November 2013)"
  ]
}