{
  "feature": "prompt-obfuscation-pipeline",
  "version": "1.0.0",
  "description": "Chain converters to transform a prompt into an obfuscated form designed to bypass AI safety filters — supports encoding, character substitution, language translation, and 40+ transforms.",
  "category": "security",
  "tags": [
    "llm",
    "prompt-converter",
    "obfuscation",
    "jailbreak",
    "encoding",
    "red-team",
    "ai-safety"
  ],
  "actors": [
    {
      "id": "red_team_operator",
      "name": "Red-Team Operator",
      "type": "human",
      "description": "Selects converter chain and initiates the obfuscated prompt attack."
    },
    {
      "id": "converter_pipeline",
      "name": "Converter Pipeline",
      "type": "system",
      "description": "Applies converters in sequence; each converter's output feeds the next."
    },
    {
      "id": "target_model",
      "name": "Target AI Model",
      "type": "external",
      "description": "Receives the final obfuscated prompt and returns a response."
    }
  ],
  "fields": [
    {
      "name": "original_prompt",
      "type": "rich_text",
      "required": true,
      "label": "Original Prompt"
    },
    {
      "name": "converter_chain",
      "type": "json",
      "required": true,
      "label": "Converter Chain"
    },
    {
      "name": "data_type",
      "type": "select",
      "required": true,
      "label": "Prompt Modality"
    },
    {
      "name": "converted_prompt",
      "type": "rich_text",
      "required": false,
      "label": "Converted Prompt"
    },
    {
      "name": "converter_results",
      "type": "json",
      "required": false,
      "label": "Per-Converter Results"
    }
  ],
  "rules": {
    "ordering": {
      "apply_in_declared_order": true,
      "each_converter_receives_previous_output": true
    },
    "modality_contract": {
      "output_type_must_match_next_input_type": true,
      "on_mismatch": "halt_pipeline"
    },
    "on_converter_failure": {
      "action": "halt_and_report"
    },
    "llm_backed_converters": {
      "counts_against_model_usage_budget": true
    },
    "human_in_the_loop": {
      "pauses_execution": true,
      "resumes_on_manual_approval": true
    },
    "audit": {
      "store_intermediate_outputs": true,
      "original_prompt": "immutable"
    }
  },
  "outcomes": {
    "modality_mismatch": {
      "priority": 1,
      "error": "CONVERTER_MODALITY_MISMATCH",
      "given": [
        "output modality of converter N does not match required input modality of converter N+1"
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "security.converter.pipeline_failed",
          "payload": [
            "converter_chain",
            "failing_converter",
            "reason"
          ]
        }
      ],
      "result": "Pipeline is halted; error identifies which converter caused the mismatch."
    },
    "converter_error": {
      "priority": 2,
      "error": "CONVERTER_TRANSFORM_FAILED",
      "given": [
        "a converter throws an error during transformation (API failure, encoding error)"
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "security.converter.pipeline_failed",
          "payload": [
            "converter_chain",
            "failing_converter",
            "reason"
          ]
        }
      ],
      "result": "Pipeline is halted; the partially converted prompt is discarded."
    },
    "pipeline_complete": {
      "priority": 10,
      "given": [
        "all converters in the chain complete without error"
      ],
      "then": [
        {
          "action": "set_field",
          "target": "converted_prompt",
          "description": "Final output of the last converter in the chain."
        },
        {
          "action": "emit_event",
          "event": "security.converter.pipeline_complete",
          "payload": [
            "converter_chain",
            "data_type",
            "converted_prompt"
          ]
        }
      ],
      "result": "Converted prompt is ready to be sent to the target model."
    }
  },
  "errors": [
    {
      "code": "CONVERTER_MODALITY_MISMATCH",
      "status": 422,
      "message": "A converter in the chain produced an output type incompatible with the next converter."
    },
    {
      "code": "CONVERTER_TRANSFORM_FAILED",
      "status": 500,
      "message": "A converter failed to transform the prompt. Check converter configuration and dependencies."
    },
    {
      "code": "CONVERTER_CHAIN_EMPTY",
      "status": 400,
      "message": "The converter chain is empty. At least one converter must be configured."
    }
  ],
  "events": [
    {
      "name": "security.converter.pipeline_complete",
      "description": "Emitted when all converters have been applied successfully.",
      "payload": [
        "converter_chain",
        "data_type",
        "converted_prompt"
      ]
    },
    {
      "name": "security.converter.pipeline_failed",
      "description": "Emitted when a converter in the chain fails and the pipeline halts.",
      "payload": [
        "converter_chain",
        "failing_converter",
        "reason"
      ]
    }
  ],
  "related": [
    {
      "feature": "prompt-attack-augmentation",
      "type": "optional",
      "reason": "Alternative augmentation approach used in the garak probe pipeline."
    },
    {
      "feature": "multi-turn-attack-orchestration",
      "type": "recommended",
      "reason": "Multi-turn attacks that apply converter chains per turn."
    },
    {
      "feature": "llm-vulnerability-scan",
      "type": "optional",
      "reason": "Scan pipeline that can integrate obfuscated prompts as augmented attempts."
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_prompt_obfuscation_pipeline",
        "description": "Chain converters to transform a prompt into an obfuscated form designed to bypass AI safety filters — supports encoding, character substitution, language translation, and 40+ transforms.",
        "success_metrics": [
          {
            "metric": "data_accuracy",
            "target": "100%",
            "measurement": "Records matching source of truth"
          },
          {
            "metric": "duplicate_rate",
            "target": "0%",
            "measurement": "Duplicate records detected post-creation"
          }
        ],
        "constraints": [
          {
            "type": "performance",
            "description": "Data consistency must be maintained across concurrent operations",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "modality_mismatch",
          "permission": "autonomous"
        },
        {
          "action": "converter_error",
          "permission": "autonomous"
        },
        {
          "action": "pipeline_complete",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "data_integrity",
        "over": "performance",
        "reason": "data consistency must be maintained across all operations"
      }
    ]
  },
  "extensions": {
    "source": {
      "repo": "https://github.com/microsoft/PyRIT",
      "project": "PyRIT — Python Risk Identification Tool",
      "tech_stack": "Python 3.10+",
      "files_traced": 60,
      "entry_points": [
        "pyrit/prompt_converter/prompt_converter.py",
        "pyrit/prompt_converter/base64_converter.py",
        "pyrit/prompt_converter/translation_converter.py",
        "pyrit/prompt_converter/persuasion_converter.py",
        "pyrit/prompt_normalizer/"
      ]
    }
  }
}