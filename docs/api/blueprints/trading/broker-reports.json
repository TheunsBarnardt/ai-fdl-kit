  "anti_patterns": [
    {
      "rule": "Do not embed personal information or account details in plaintext email bodies",
      "why": "POPIA s.19 requires technical safeguards for PII in transit; plaintext email is a common breach vector"
    },
    {
      "rule": "Do not regenerate tax certificates without preserving prior versions",
      "why": "Tax-authority audits require the ability to reproduce the exact certificate issued on a given date"
    },
    {
      "rule": "Do not run batch schedules on non-business days without calendar validation",
      "why": "Running reports against incomplete end-of-day data produces misleading valuations and client disputes"
    },
    {
      "rule": "Do not retry delivery indefinitely on permanent failures",
      "why": "Unbounded retries mask downstream configuration errors and flood delivery gateways"
    },
    {
      "rule": "Do not allow cross-client data to bleed into a single statement run",
      "why": "Account-scoping errors leak confidential positions and breach client confidentiality"
    },
    {
      "rule": "Do not price portfolio valuations with stale prices without flagging them",
      "why": "Mark-to-market reports based on stale prices mislead clients and distort regulatory capital"
    },
    {
      "rule": "Do not delete generated reports before statutory retention period",
      "why": "Tax-authority and exchange-control rules require multi-year recordkeeping"
    }
  ],
