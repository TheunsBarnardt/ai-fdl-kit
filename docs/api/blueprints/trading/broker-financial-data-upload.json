{
  "feature": "broker-financial-data-upload",
  "version": "1.1.0",
  "description": "Fixed-width bulk GL and financial upload - cash receipts, cash payments and journal entries - with double-entry validation, GL account checks and reversal rules",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "upload",
    "financial-data",
    "cash-book",
    "journal",
    "gl",
    "fixed-width",
    "double-entry"
  ],
  "actors": [
    {
      "id": "participating_broker",
      "name": "Participating Broker",
      "type": "external"
    },
    {
      "id": "back_office_system",
      "name": "Back Office System",
      "type": "system"
    },
    {
      "id": "broker_finance_user",
      "name": "Broker Finance User",
      "type": "human"
    },
    {
      "id": "gl_engine",
      "name": "General Ledger Engine",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "layout_number",
      "type": "text",
      "required": true,
      "label": "Layout Number",
      "validation": [
        {
          "type": "pattern",
          "value": "^(000|063|064|065|999)$",
          "message": "Layout Number failed pattern validation"
        }
      ]
    },
    {
      "name": "broker_code",
      "type": "text",
      "required": true,
      "label": "Broker Code"
    },
    {
      "name": "process_date",
      "type": "date",
      "required": true,
      "label": "Process Date"
    },
    {
      "name": "age_date",
      "type": "date",
      "required": false,
      "label": "Age Date"
    },
    {
      "name": "account_code",
      "type": "text",
      "required": false,
      "label": "GL Account Code"
    },
    {
      "name": "balance_code",
      "type": "text",
      "required": false,
      "label": "Balance Code"
    },
    {
      "name": "designation_code",
      "type": "text",
      "required": false,
      "label": "Designation Code"
    },
    {
      "name": "amount_sign",
      "type": "text",
      "required": false,
      "label": "Amount Sign",
      "validation": [
        {
          "type": "pattern",
          "value": "^[+-]$",
          "message": "Amount Sign failed pattern validation"
        }
      ]
    },
    {
      "name": "amount",
      "type": "number",
      "required": false,
      "label": "Amount (2 implied decimals)"
    },
    {
      "name": "narrative",
      "type": "text",
      "required": false,
      "label": "Narrative"
    },
    {
      "name": "cheque_number",
      "type": "text",
      "required": false,
      "label": "Cheque Number"
    },
    {
      "name": "cash_alpha_code",
      "type": "text",
      "required": false,
      "label": "Cash Alpha Code"
    },
    {
      "name": "branch_code",
      "type": "text",
      "required": false,
      "label": "Branch Code"
    },
    {
      "name": "partner_code",
      "type": "text",
      "required": false,
      "label": "Partner Code"
    },
    {
      "name": "general_analysis_code",
      "type": "text",
      "required": false,
      "label": "General Analysis Code"
    },
    {
      "name": "registration_code",
      "type": "text",
      "required": false,
      "label": "Nominee Registration Code"
    },
    {
      "name": "payee",
      "type": "text",
      "required": false,
      "label": "Payee Name"
    },
    {
      "name": "electronic_payment_indicator",
      "type": "text",
      "required": false,
      "label": "Electronic Payment Indicator"
    },
    {
      "name": "reference_number",
      "type": "text",
      "required": false,
      "label": "Journal Reference Number"
    },
    {
      "name": "sequence",
      "type": "text",
      "required": false,
      "label": "Header Sequence"
    },
    {
      "name": "records_total",
      "type": "number",
      "required": false,
      "label": "Trailer Total Records"
    },
    {
      "name": "records_processed",
      "type": "number",
      "required": false,
      "label": "Records Processed"
    },
    {
      "name": "records_rejected",
      "type": "number",
      "required": false,
      "label": "Records Rejected"
    },
    {
      "name": "financial_entry_type",
      "type": "select",
      "required": false,
      "label": "Financial Entry Type",
      "options": [
        {
          "value": "XOP",
          "label": "Cross Operation / Inter-account Transfer"
        },
        {
          "value": "GL",
          "label": "General Ledger Journal"
        },
        {
          "value": "CR",
          "label": "Cash Receipt"
        },
        {
          "value": "CP",
          "label": "Cash Payment"
        },
        {
          "value": "FEE",
          "label": "Fee Charge"
        },
        {
          "value": "REF",
          "label": "Refund"
        }
      ]
    },
    {
      "name": "currency_code",
      "type": "text",
      "required": false,
      "label": "Transaction Currency"
    },
    {
      "name": "fx_rate",
      "type": "number",
      "required": false,
      "label": "FX Conversion Rate"
    },
    {
      "name": "reversal_flag",
      "type": "boolean",
      "required": false,
      "label": "Reversal Flag"
    }
  ],
  "rules": {
    "submission": [
      "MUST: Support FTP automated submission",
      "MUST: Support online automated upload",
      "MUST: Support online manual upload via release function",
      "MUST: Support batch upload mode",
      "MUST: Configure response email addresses before allowing upload",
      "MUST: Limit manual online uploads to 500 entries per file"
    ],
    "validation": [
      "MUST: Report errors via common error enquiry console per record",
      "MUST: Generate response dataset with per-record status and error messages",
      "MUST: Reject the whole file on trailer errors (missing, duplicate, mismatched broker, total mismatch)",
      "MUST: Zero-fill numeric fields when no value is present (never leave empty)",
      "MUST: Validate process date equals run date for each record",
      "MUST: Validate broker code on each record equals header broker code"
    ],
    "format": [
      "MUST: Use non-delimited fixed-length record format",
      "MUST: Every record is exactly 173 characters",
      "MUST: Start with Header Record (Layout 000) for online uploads",
      "MUST: End with Trailer Record (Layout 999) for online uploads",
      "MUST: Use Layout 063 for cash book receipts",
      "MUST: Use Layout 064 for cash book payments",
      "MUST: Use Layout 065 for general journal entries",
      "MUST: Amount fields carry 2 implied decimals (no decimal point in wire format)"
    ],
    "gl_accounts": [
      "MUST: Validate referenced GL account code exists and is active",
      "MUST: Validate balance code is permitted for the account",
      "MUST: Validate designation code combination against account rules",
      "MUST: Reject postings to closed or suspended GL accounts"
    ],
    "double_entry": [
      "MUST: Every journal batch debits must equal credits to two-decimal precision",
      "MUST: Cash receipt posts debit to bank/cash account, credit to client/GL account",
      "MUST: Cash payment posts credit to bank/cash account, debit to client/GL account",
      "MUST: Reject any journal where aggregate debit-credit difference is non-zero"
    ],
    "currency": [
      "MUST: Convert foreign currency amounts to base currency at official FX rate",
      "MUST: Round converted amounts to 2 decimals using half-up rounding",
      "MUST: Record the FX rate and original currency on every converted posting"
    ],
    "reversal": [
      "MUST: Reverse a cash receipt by posting an equal and opposite cash payment",
      "MUST: Reverse a cash payment by posting an equal and opposite cash receipt",
      "MUST: Allow same-day (T+0) reversal without additional approval",
      "MUST: Require finance supervisor approval to reverse an entry posted on a prior date",
      "MUST: Prohibit reversal once the period has been closed"
    ]
  },
  "errors": [
    {
      "code": "FIN_UPLOAD_INVALID_LAYOUT",
      "status": 400,
      "message": "Financial data upload file has invalid layout structure"
    },
    {
      "code": "FIN_UPLOAD_UNBALANCED_JOURNAL",
      "status": 422,
      "message": "Journal entry debits do not equal credits"
    },
    {
      "code": "FIN_UPLOAD_INVALID_ACCOUNT",
      "status": 422,
      "message": "Referenced GL account does not exist or is not active"
    },
    {
      "code": "FIN_UPLOAD_DUPLICATE_REFERENCE",
      "status": 409,
      "message": "Transaction reference already exists"
    },
    {
      "code": "FIN_UPLOAD_TRAILER_MISMATCH",
      "status": 422,
      "message": "Trailer record total does not match records submitted"
    },
    {
      "code": "FIN_UPLOAD_CURRENCY_INVALID",
      "status": 422,
      "message": "Currency code not recognised or no FX rate available"
    },
    {
      "code": "FIN_UPLOAD_REVERSAL_NOT_ALLOWED",
      "status": 403,
      "message": "Reversal of prior-period entry requires supervisor approval"
    },
    {
      "code": "FIN_UPLOAD_PERIOD_CLOSED",
      "status": 423,
      "message": "Accounting period is closed - reversal not permitted"
    },
    {
      "code": "FIN_UPLOAD_PROCESSING_FAILED",
      "status": 500,
      "message": "Financial upload processing failed"
    }
  ],
  "outcomes": {
    "automated_ftp_upload": {
      "priority": 1,
      "description": "Broker submits financial data via FTP and it is processed automatically",
      "given": [
        {
          "field": "upload_method",
          "source": "input",
          "operator": "eq",
          "value": "ftp"
        },
        {
          "field": "email_configured",
          "source": "db",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "financial_upload"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.received"
        }
      ]
    },
    "manual_online_upload": {
      "priority": 2,
      "description": "Broker uploads financial data via online manual interface with header and trailer",
      "given": [
        {
          "field": "upload_method",
          "source": "input",
          "operator": "eq",
          "value": "online_manual"
        },
        {
          "field": "record_count",
          "source": "input",
          "operator": "lte",
          "value": 500
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "financial_upload_manual"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.manual_received"
        }
      ]
    },
    "bulk_gl_entry_upload": {
      "priority": 3,
      "description": "Accept a bulk file of GL entries (XOP, GL, fees, refunds) and dispatch to the ledger engine",
      "given": [
        {
          "field": "layout_number",
          "source": "input",
          "operator": "in",
          "value": [
            "063",
            "064",
            "065"
          ]
        },
        {
          "field": "record_count",
          "source": "input",
          "operator": "gt",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "gl_entry_parser"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.bulk_gl.received"
        },
        {
          "action": "create_record",
          "type": "gl_batch"
        }
      ]
    },
    "gl_account_validation": {
      "priority": 4,
      "description": "Validate every referenced GL account exists, is active and accepts the balance code",
      "given": [
        {
          "field": "account_code",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "gl_account_validator"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.account.validated"
        }
      ]
    },
    "gl_account_invalid": {
      "priority": 5,
      "error": "FIN_UPLOAD_INVALID_ACCOUNT",
      "description": "Referenced GL account is unknown, closed or suspended",
      "given": [
        {
          "field": "account_status",
          "source": "db",
          "operator": "in",
          "value": [
            "unknown",
            "closed",
            "suspended"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "fin_upload.account.rejected"
        }
      ]
    },
    "double_entry_validation": {
      "priority": 6,
      "description": "Each cash and journal posting generates a matched debit and credit leg",
      "given": [
        {
          "field": "layout_number",
          "source": "input",
          "operator": "in",
          "value": [
            "063",
            "064",
            "065"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "double_entry_poster"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.double_entry.posted"
        }
      ]
    },
    "debit_credit_balancing": {
      "priority": 7,
      "description": "Aggregate debits and credits across a journal batch must balance to zero",
      "given": [
        {
          "field": "debit_total",
          "source": "computed",
          "operator": "exists"
        },
        {
          "field": "credit_total",
          "source": "computed",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "batch_balancer"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.batch.balanced"
        }
      ]
    },
    "unbalanced_journal": {
      "priority": 8,
      "error": "FIN_UPLOAD_UNBALANCED_JOURNAL",
      "description": "Debit and credit totals differ for the batch",
      "given": [
        {
          "field": "debit_credit_diff",
          "source": "computed",
          "operator": "neq",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "fin_upload.journal.unbalanced"
        }
      ]
    },
    "currency_conversion_rounding": {
      "priority": 9,
      "description": "Convert foreign-currency amounts to base currency and round to 2 decimals half-up",
      "given": [
        {
          "field": "currency_code",
          "source": "input",
          "operator": "neq",
          "value": "base"
        },
        {
          "field": "fx_rate",
          "source": "input",
          "operator": "gt",
          "value": 0
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "amount_base_ccy",
          "value": "computed_rounded"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.currency.converted"
        }
      ]
    },
    "same_day_reversal": {
      "priority": 10,
      "description": "Allow T+0 reversal by posting an equal and opposite entry without additional approval",
      "given": [
        {
          "field": "reversal_flag",
          "source": "input",
          "operator": "eq",
          "value": true
        },
        {
          "field": "original_post_date",
          "source": "db",
          "operator": "eq",
          "value": "today"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "reversal_entry"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.reversal.same_day"
        }
      ]
    },
    "prior_date_reversal": {
      "priority": 11,
      "description": "Reversal of an entry posted on a prior date requires supervisor approval and open period",
      "given": [
        {
          "field": "reversal_flag",
          "source": "input",
          "operator": "eq",
          "value": true
        },
        {
          "field": "original_post_date",
          "source": "db",
          "operator": "lt",
          "value": "today"
        },
        {
          "field": "supervisor_approved",
          "source": "input",
          "operator": "eq",
          "value": true
        },
        {
          "field": "period_status",
          "source": "db",
          "operator": "eq",
          "value": "open"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "reversal_entry"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.reversal.prior_date"
        }
      ]
    },
    "reversal_period_closed": {
      "priority": 12,
      "error": "FIN_UPLOAD_PERIOD_CLOSED",
      "description": "Reversal attempted against a closed accounting period",
      "given": [
        {
          "field": "period_status",
          "source": "db",
          "operator": "eq",
          "value": "closed"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "fin_upload.reversal.blocked"
        }
      ]
    },
    "trailer_mismatch": {
      "priority": 13,
      "error": "FIN_UPLOAD_TRAILER_MISMATCH",
      "description": "Trailer totals do not match the records actually received",
      "given": [
        {
          "field": "trailer_valid",
          "source": "computed",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "fin_upload.trailer.rejected"
        }
      ]
    },
    "generate_response_dataset": {
      "priority": 20,
      "description": "Generate response dataset with per-record error lines and notify configured addresses",
      "given": [
        {
          "field": "processing_complete",
          "source": "computed",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "financial_response_dataset"
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "fin_upload.response.delivered"
        }
      ]
    }
  },
  "events": [
    {
      "name": "fin_upload.received",
      "payload": [
        "broker_code",
        "layout_number",
        "process_date"
      ]
    },
    {
      "name": "fin_upload.manual_received",
      "payload": [
        "broker_code",
        "sequence",
        "record_count"
      ]
    },
    {
      "name": "fin_upload.bulk_gl.received",
      "payload": [
        "broker_code",
        "record_count",
        "layout_number"
      ]
    },
    {
      "name": "fin_upload.account.validated",
      "payload": [
        "account_code",
        "balance_code"
      ]
    },
    {
      "name": "fin_upload.account.rejected",
      "payload": [
        "account_code",
        "reason"
      ]
    },
    {
      "name": "fin_upload.double_entry.posted",
      "payload": [
        "reference_number",
        "debit_total",
        "credit_total"
      ]
    },
    {
      "name": "fin_upload.batch.balanced",
      "payload": [
        "reference_number",
        "debit_total",
        "credit_total"
      ]
    },
    {
      "name": "fin_upload.journal.unbalanced",
      "payload": [
        "reference_number",
        "debit_credit_diff"
      ]
    },
    {
      "name": "fin_upload.currency.converted",
      "payload": [
        "currency_code",
        "fx_rate",
        "amount",
        "amount_base_ccy"
      ]
    },
    {
      "name": "fin_upload.reversal.same_day",
      "payload": [
        "reference_number",
        "broker_code"
      ]
    },
    {
      "name": "fin_upload.reversal.prior_date",
      "payload": [
        "reference_number",
        "broker_code",
        "original_post_date"
      ]
    },
    {
      "name": "fin_upload.reversal.blocked",
      "payload": [
        "reference_number",
        "period_status"
      ]
    },
    {
      "name": "fin_upload.trailer.rejected",
      "payload": [
        "broker_code",
        "records_total",
        "records_received"
      ]
    },
    {
      "name": "fin_upload.response.delivered",
      "payload": [
        "broker_code",
        "sequence",
        "records_processed",
        "records_rejected"
      ]
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_financial_data_upload",
        "description": "Fixed-width bulk GL and financial upload - cash receipts, cash payments and journal entries - with double-entry validation, GL account checks and reversal rules",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "automated_ftp_upload",
          "permission": "autonomous"
        },
        {
          "action": "manual_online_upload",
          "permission": "autonomous"
        },
        {
          "action": "bulk_gl_entry_upload",
          "permission": "autonomous"
        },
        {
          "action": "gl_account_validation",
          "permission": "autonomous"
        },
        {
          "action": "gl_account_invalid",
          "permission": "autonomous"
        },
        {
          "action": "double_entry_validation",
          "permission": "autonomous"
        },
        {
          "action": "debit_credit_balancing",
          "permission": "autonomous"
        },
        {
          "action": "unbalanced_journal",
          "permission": "autonomous"
        },
        {
          "action": "currency_conversion_rounding",
          "permission": "autonomous"
        },
        {
          "action": "same_day_reversal",
          "permission": "autonomous"
        },
        {
          "action": "prior_date_reversal",
          "permission": "autonomous"
        },
        {
          "action": "reversal_period_closed",
          "permission": "autonomous"
        },
        {
          "action": "trailer_mismatch",
          "permission": "autonomous"
        },
        {
          "action": "generate_response_dataset",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
  "extensions": {
    "financial_entry_types": {
      "XOP": {
        "name": "Cross Operation",
        "description": "Inter-account transfer between two broker-held accounts",
        "layouts": [
          "065"
        ]
      },
      "GL": {
        "name": "General Ledger Journal",
        "description": "Standalone ledger posting not tied to a cash movement",
        "layouts": [
          "065"
        ]
      },
      "CR": {
        "name": "Cash Receipt",
        "description": "Inbound cash movement debiting the bank/cash ledger",
        "layouts": [
          "063"
        ]
      },
      "CP": {
        "name": "Cash Payment",
        "description": "Outbound cash movement crediting the bank/cash ledger",
