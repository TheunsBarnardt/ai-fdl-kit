{
  "feature": "user-groups-organizations",
  "version": "1.0.0",
  "description": "Hierarchical groups with role inheritance",
  "category": "access",
  "tags": [
    "groups",
    "organizations"
  ],
  "fields": [
    {
      "name": "group_id",
      "type": "text",
      "required": true,
      "label": "Group ID",
      "validation": [
        {
          "type": "required",
          "message": "Group ID required"
        }
      ]
    },
    {
      "name": "group_name",
      "type": "text",
      "required": true,
      "label": "Group Name",
      "validation": [
        {
          "type": "required",
          "message": "Name required"
        }
      ]
    }
  ],
  "rules": {
    "core": "Group hierarchy and role inheritance"
  },
  "outcomes": {
    "group_created": {
      "priority": 5,
      "given": [
        {
          "field": "group_name",
          "operator": "exists",
          "value": null
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "group.created",
          "payload": [
            "group_id"
          ]
        }
      ],
      "result": "Group created"
    }
  },
  "errors": [
    {
      "code": "GROUP_NOT_FOUND",
      "status": 404,
      "message": "Group not found"
    }
  ],
  "events": [
    {
      "name": "group.created",
      "description": "Group created",
      "payload": [
        "group_id"
      ]
    }
  ],
  "related": [],
  "agi": {
    "goals": [
      {
        "id": "reliable_user_groups_organizations",
        "description": "Hierarchical groups with role inheritance",
        "success_metrics": [
          {
            "metric": "unauthorized_access_rate",
            "target": "0%",
            "measurement": "Failed authorization attempts that succeed"
          },
          {
            "metric": "response_time_p95",
            "target": "< 500ms",
            "measurement": "95th percentile response time"
          }
        ],
        "constraints": [
          {
            "type": "security",
            "description": "Follow OWASP security recommendations",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "group_created",
          "permission": "supervised"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "security",
        "over": "usability",
        "reason": "access control must enforce least-privilege principle"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  },
  "extensions": {
    "source": {
      "repo": "https://github.com/keycloak/keycloak",
      "project": "Keycloak",
      "tech_stack": "Java"
    }
  }
}