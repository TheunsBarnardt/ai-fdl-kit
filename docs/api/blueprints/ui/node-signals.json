          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Connect signals to methods completed",
      "priority": 1
    },
    "signal_emission": {
      "given": [
        "Emit signals with payloads is requested"
      ],
      "then": [
        {
          "action": "transition_state",
