{
  "feature": "broker-dematerialisation-upload",
  "version": "1.1.0",
  "description": "Bulk dematerialisation upload from broker to back-office via fixed-width card-code file, validating paper certificates against the register and routing holdings to the central depository",
  "category": "trading",
  "tags": [
    "back-office",
    "broker",
    "upload",
    "demat",
    "dematerialisation",
    "positions",
    "card-codes",
    "fixed-width",
    "certificate-register",
    "central-depository"
  ],
  "actors": [
    {
      "id": "participating_broker",
      "name": "Participating Broker",
      "type": "external"
    },
    {
      "id": "back_office_system",
      "name": "Back Office System",
      "type": "system"
    },
    {
      "id": "central_depository",
      "name": "Central Securities Depository",
      "type": "external"
    },
    {
      "id": "certificate_registrar",
      "name": "Physical Certificate Registrar",
      "type": "external"
    }
  ],
  "fields": [
    {
      "name": "card_code",
      "type": "text",
      "required": true,
      "label": "Card Code"
    },
    {
      "name": "broker_code",
      "type": "text",
      "required": true,
      "label": "Broker Code"
    },
    {
      "name": "upload_date",
      "type": "date",
      "required": true,
      "label": "Upload Date"
    },
    {
      "name": "upload_time",
      "type": "text",
      "required": true,
      "label": "Upload Time"
    },
    {
      "name": "sequence_prefix",
      "type": "text",
      "required": true,
      "label": "Sequence Prefix"
    },
    {
      "name": "sequence_number",
      "type": "text",
      "required": true,
      "label": "Sequence Number"
    },
    {
      "name": "account_code",
      "type": "text",
      "required": true,
      "label": "Account Code"
    },
    {
      "name": "account_type",
      "type": "select",
      "required": true,
      "label": "Account Type",
      "options": [
        {
          "value": "C",
          "label": "Controlled Client"
        }
      ]
    },
    {
      "name": "instrument_type",
      "type": "select",
      "required": true,
      "label": "Instrument Type",
      "options": [
        {
          "value": "E",
          "label": "Electronically Settled"
        }
      ]
    },
    {
      "name": "instrument_alpha",
      "type": "text",
      "required": true,
      "label": "Instrument Alpha"
    },
    {
      "name": "instrument_version",
      "type": "text",
      "required": true,
      "label": "Instrument Version"
    },
    {
      "name": "share_quantity",
      "type": "number",
      "required": true,
      "label": "Share Quantity"
    },
    {
      "name": "portfolio_cost",
      "type": "number",
      "required": false,
      "label": "Portfolio Cost (cents)"
    },
    {
      "name": "demat_request_type",
      "type": "select",
      "required": true,
      "label": "Demat Request Type",
      "options": [
        {
          "value": "D",
          "label": "Deposit (paper -> electronic)"
        },
        {
          "value": "W",
          "label": "Withdrawal (electronic -> paper)"
        },
        {
          "value": "T",
          "label": "Transfer (depository-to-depository)"
        }
      ]
    },
    {
      "name": "certificate_number",
      "type": "text",
      "required": false,
      "label": "Physical Certificate Number"
    },
    {
      "name": "certificate_destroyed",
      "type": "boolean",
      "required": false,
      "label": "Physical Certificate Destruction Confirmed"
    },
    {
      "name": "total_records",
      "type": "number",
      "required": true,
      "label": "Total Records"
    },
    {
      "name": "records_processed",
      "type": "number",
      "required": false,
      "label": "Records Processed"
    },
    {
      "name": "records_rejected",
      "type": "number",
      "required": false,
      "label": "Records Rejected"
    }
  ],
  "rules": {
    "subscription": [
      "MUST: Require broker subscription before enabling DEMAT upload service"
    ],
    "processing": [
      "MUST: Only accept positions on accounts of type C (controlled client)",
      "MUST: Only accept electronically settled instruments",
      "MUST: Only create new positions (no closing of positions via upload)",
      "MUST: Exclude non-dematerialised scrip",
      "MUST: Apply PFV cost only when provided (no actual/average calculation)",
      "MUST: Update position only when all field validations pass",
      "MUST: Validate paper certificate numbers against the physical certificate register before deposit",
      "MUST: Require confirmation of physical certificate destruction before electronic holding is created"
    ],
    "submission": [
      "MUST: Support automated FTP submission and auto-dispatch of processing batch",
      "MUST: Allow up to 10 response e-mail addresses per broker",
      "MUST: Produce a response dataset containing each input line annotated with response codes",
      "MUST: Archive both upload and response files on a rolling cycle"
    ],
    "format": [
      "MUST: Use fixed-width card-code record format, total record length 100",
      "MUST: Begin each file with Header Record (Card Code 000)",
      "MUST: End each file with Trailer Record (Card Code 999)",
      "MUST: Use Card Code 030 for DEMAT share upload records",
      "MUST: Reject entire file if trailer record is missing, duplicated, or totals mismatch"
    ],
    "audit": [
      "MUST: Maintain immutable audit trail of every demat request, validation outcome and depository routing",
      "MUST: Link each electronic holding back to the originating certificate number and destruction evidence"
    ]
  },
  "errors": [
    {
      "code": "DEMAT_UPLOAD_NOT_SUBSCRIBED",
      "status": 403,
      "message": "Broker not subscribed to DEMAT upload service"
    },
    {
      "code": "DEMAT_UPLOAD_INVALID_DEPOSITORY_REF",
      "status": 422,
      "message": "Central depository account or participant reference is invalid"
    },
    {
      "code": "DEMAT_UPLOAD_INSTRUMENT_NOT_FOUND",
      "status": 422,
      "message": "Referenced instrument does not exist or is not electronically settled"
    },
    {
      "code": "DEMAT_UPLOAD_ACCOUNT_NOT_FOUND",
      "status": 422,
      "message": "Referenced client account does not exist or is not type C"
    },
    {
      "code": "DEMAT_UPLOAD_CERT_NOT_IN_REGISTER",
      "status": 422,
      "message": "Physical certificate number not found in certificate register"
    },
    {
      "code": "DEMAT_UPLOAD_CERT_NOT_DESTROYED",
      "status": 409,
      "message": "Physical certificate destruction has not been confirmed"
    },
    {
      "code": "DEMAT_UPLOAD_TRAILER_MISMATCH",
      "status": 422,
      "message": "Trailer totals do not reconcile to records received"
    },
    {
      "code": "DEMAT_UPLOAD_FILE_REJECTED",
      "status": 422,
      "message": "Upload file rejected due to structural error"
    },
    {
      "code": "DEMAT_UPLOAD_PROCESSING_FAILED",
      "status": 500,
      "message": "DEMAT upload processing failed"
    }
  ],
  "outcomes": {
    "not_subscribed": {
      "priority": 1,
      "description": "Broker is not subscribed to the DEMAT upload service",
      "error": "DEMAT_UPLOAD_NOT_SUBSCRIBED",
      "given": [
        {
          "field": "broker_subscribed",
          "source": "db",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "demat_upload.not_subscribed"
        }
      ]
    },
    "automated_demat_upload": {
      "priority": 2,
      "description": "Broker uploads a DEMAT file via automated FTP",
      "given": [
        {
          "field": "broker_subscribed",
          "source": "db",
          "operator": "eq",
          "value": true
        },
        {
          "field": "email_configured",
          "source": "db",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "demat_upload",
          "fields": [
            "broker_code",
            "file_name",
            "total_records",
            "sequence_number",
            "submission_timestamp"
          ]
        },
        {
          "action": "emit_event",
          "event": "demat_upload.received"
        }
      ]
    },
    "bulk_demat_deposit": {
      "priority": 3,
      "description": "Bulk deposit of paper share certificates converted to electronic holdings",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "030"
        },
        {
          "field": "demat_request_type",
          "source": "input",
          "operator": "eq",
          "value": "D"
        },
        {
          "field": "account_type",
          "source": "db",
          "operator": "eq",
          "value": "C"
        },
        {
          "field": "instrument_type",
          "source": "db",
          "operator": "eq",
          "value": "E"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "electronic_holding",
          "fields": [
            "account_code",
            "instrument_alpha",
            "share_quantity",
            "portfolio_cost",
            "certificate_number"
          ]
        },
        {
          "action": "call_service",
          "target": "central_depository_router"
        },
        {
          "action": "emit_event",
          "event": "demat_upload.deposit.created"
        }
      ]
    },
    "demat_validation_against_cert_register": {
      "priority": 4,
      "description": "Validate the paper certificate against the physical certificate register before creating the electronic holding",
      "given": [
        {
          "field": "demat_request_type",
          "source": "input",
          "operator": "eq",
          "value": "D"
        },
        {
          "field": "certificate_number",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "certificate_register_validator"
        },
        {
          "action": "set_field",
          "target": "certificate_destroyed",
          "value": true
        },
        {
          "action": "emit_event",
          "event": "demat_upload.certificate.validated"
        }
      ],
      "error": "DEMAT_UPLOAD_CERT_NOT_IN_REGISTER"
    },
    "demat_rejection_handling": {
      "priority": 5,
      "description": "Record-level rejection with response code appended to the originating line",
      "given": [
        {
          "field": "record_valid",
          "source": "computed",
          "operator": "eq",
          "value": false
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "records_rejected",
          "value": "records_rejected_plus_1"
        },
        {
          "action": "create_record",
          "type": "demat_response_line",
          "fields": [
            "original_line",
            "response_code",
            "error_message"
          ]
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "demat_upload.record.rejected"
        }
      ],
      "error": "DEMAT_UPLOAD_FILE_REJECTED"
    },
    "validate_depository_reference": {
      "priority": 6,
      "description": "Validate central depository account and participant reference",
      "given": [
        {
          "field": "card_code",
          "source": "input",
          "operator": "eq",
          "value": "030"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "depository_reference_validator"
        },
        {
          "action": "emit_event",
          "event": "demat_upload.depository.validated"
        }
      ]
    },
    "generate_response_dataset": {
      "priority": 7,
      "description": "Generate response dataset with per-record response codes and totals",
      "given": [
        {
          "field": "processing_status",
          "source": "system",
          "operator": "eq",
          "value": "completed"
        }
      ],
      "then": [
        {
          "action": "create_record",
          "type": "demat_response_dataset",
          "fields": [
            "broker_code",
            "sequence_number",
            "total_records",
            "records_processed",
            "records_rejected"
          ]
        },
        {
          "action": "notify",
          "channel": "email"
        },
        {
          "action": "emit_event",
          "event": "demat_upload.response.delivered"
        }
      ]
    },
    "archive_upload": {
      "priority": 8,
      "description": "Archive processed DEMAT upload and response files on rolling cycle",
      "given": [
        {
          "field": "processing_status",
          "source": "system",
          "operator": "eq",
          "value": "completed"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "archive_storage"
        },
        {
          "action": "emit_event",
          "event": "demat_upload.archived"
        }
      ]
    }
  },
  "agi": {
    "goals": [
      {
        "id": "reliable_broker_dematerialisation_upload",
        "description": "Bulk dematerialisation upload with certificate-register validation, depository routing, and full audit trail",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          },
          {
            "metric": "certificate_reconciliation_rate",
            "target": "100%",
            "measurement": "Electronic holdings reconciled to destroyed paper certificates"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          },
          {
            "type": "regulatory",
            "description": "No electronic holding created without confirmed destruction of paper certificate",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes",
        "before confirming physical certificate destruction"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3",
        "certificate_register_mismatch"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "automated_demat_upload",
          "permission": "autonomous"
        },
        {
          "action": "bulk_demat_deposit",
          "permission": "supervised"
        },
        {
          "action": "demat_validation_against_cert_register",
          "permission": "supervised"
        },
        {
          "action": "demat_rejection_handling",
          "permission": "autonomous"
        },
        {
          "action": "generate_response_dataset",
          "permission": "autonomous"
        },
        {
          "action": "archive_upload",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "dematerialisation is irreversible once paper certificates are destroyed"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details",
        "no electronic holding exists without a matching destroyed certificate reference"
      ]
    }
  },
  "extensions": {
    "demat_request_types": {
      "D": {
        "name": "Deposit",
        "description": "Paper share certificate lodged and converted to electronic holding"
      },
      "W": {
        "name": "Withdrawal",
        "description": "Electronic holding converted back to paper certificate"
      },
      "T": {
        "name": "Transfer",
        "description": "Holding transferred between central depository participants"
      }
