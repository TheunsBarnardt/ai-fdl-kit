{
  "feature": "floating-rate-note-pricing",
  "version": "1.0.0",
  "description": "Floating rate note pricing using discount margin methodology and swap zero curve.",
  "category": "trading",
  "tags": [
    "bonds",
    "floating-rate",
    "frn",
    "pricing",
    "money-market",
    "jibar"
  ],
  "fields": [
    {
      "name": "notional",
      "type": "number",
      "required": true,
      "label": "Notional Amount"
    },
    {
      "name": "settlement_date",
      "type": "date",
      "required": true,
      "label": "Settlement Date"
    },
    {
      "name": "maturity_date",
      "type": "date",
      "required": true,
      "label": "Maturity Date"
    },
    {
      "name": "market_spread",
      "type": "number",
      "required": true,
      "label": "Market Spread"
    }
  ],
  "rules": {
    "pricing": {
      "forward_rate": "Fwd_rate = (DF(t)/DF(t+1) - 1) × 365/days",
      "coupon_payment": "Coupon = Nominal × (Forward_Rate + Issue_Spread) × days/365",
      "frn_price": "Price = Sum[DF_zero × (Coupon_i + Principal)]"
    }
  },
  "outcomes": {
    "frn_priced": {
      "description": "Calculate FRN all-in price using discount margin method",
      "given": [
        {
          "field": "market_spread",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "maturity_date",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "all_in_price",
          "value": "discounted cash flows"
        },
        {
          "action": "emit_event",
          "event": "frn.price.calculated",
          "payload": [
            "settlement_date",
            "all_in_price"
          ]
        }
      ],
      "result": "FRN all-in price calculated"
    }
  },
  "errors": [
    {
      "code": "INVALID_SPREAD",
      "status": 400,
      "message": "Spread values must be non-negative"
    }
  ],
  "related": [
    {
      "feature": "bond-pricing-models",
      "type": "required"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_floating_rate_note_pricing",
        "description": "Floating rate note pricing using discount margin methodology and swap zero curve.",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "frn_priced",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "request_response",
      "consumes": [
        {
          "capability": "bond_pricing_models",
          "from": "bond-pricing-models",
          "fallback": "fail"
        }
      ]
    }
  }
}