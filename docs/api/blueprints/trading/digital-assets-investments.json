{
  "feature": "digital-assets-investments",
  "version": "1.0.0",
  "description": "Evaluate digital assets on distributed ledgers using proof-of-work or proof-of-stake consensus — crypto, tokens, stablecoins, NFTs — and their investment features",
  "category": "trading",
  "tags": [
    "digital-assets",
    "cryptocurrency",
    "distributed-ledger",
    "proof-of-work",
    "proof-of-stake",
    "cfa-level-1"
  ],
  "aliases": [
    "cryptocurrency-investment",
    "distributed-ledger-technology",
    "proof-of-work-consensus",
    "proof-of-stake-consensus",
    "stablecoin-investment",
    "tokenized-asset",
    "nft-investment"
  ],
  "actors": [
    {
      "id": "digital_analyst",
      "name": "Digital Asset Analyst",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "asset_id",
      "type": "text",
      "required": true,
      "label": "Digital asset identifier"
    },
    {
      "name": "asset_type",
      "type": "select",
      "required": true,
      "label": "cryptocurrency | utility_token | security_token | stablecoin | nft"
    },
    {
      "name": "consensus_mechanism",
      "type": "select",
      "required": false,
      "label": "proof_of_work | proof_of_stake | delegated_pos | other"
    }
  ],
  "rules": {
    "distributed_ledger": {
      "definition": "Shared, cryptographically secured database distributed across nodes",
      "permissioned_vs_permissionless": "Permissionless (public) supports open participation; permissioned restricts to vetted participants"
    },
    "consensus_mechanisms": {
      "proof_of_work": "Miners solve puzzles; high energy use; Bitcoin",
      "proof_of_stake": "Validators stake tokens; energy-efficient; Ethereum post-merge",
      "delegated_pos": "Token holders elect validators"
    },
    "digital_asset_types": {
      "cryptocurrency": "Native tokens of blockchains; medium of exchange, store of value",
      "utility_token": "Access to network services",
      "security_token": "Tokenised traditional securities; subject to securities law",
      "stablecoin": "Pegged to fiat or basket; collateralised or algorithmic",
      "nft": "Non-fungible; unique digital asset representation"
    },
    "investment_features": {
      "high_volatility": "Large drawdowns; weak fundamentals anchor",
      "correlation": "Historically low, rising with institutional adoption",
      "custody_risk": "Private-key loss is permanent; exchange counterparty risk",
      "regulatory_uncertainty": "Evolving treatment across jurisdictions"
    },
    "access_routes": {
      "direct": "Self-custody or exchange holdings",
      "etfs_and_funds": "Spot and futures-based products",
      "equity_proxies": "Miners and exchanges as indirect exposure"
    },
    "validation": {
      "asset_required": "asset_id present",
      "valid_type": "asset_type in allowed set"
    }
  },
  "outcomes": {
    "analyse_digital_asset": {
      "priority": 1,
      "description": "Analyse digital-asset investment",
      "given": [
        {
          "field": "asset_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "asset_type",
          "source": "input",
          "operator": "in",
          "value": [
            "cryptocurrency",
            "utility_token",
            "security_token",
            "stablecoin",
            "nft"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "digital_analyst"
        },
        {
          "action": "emit_event",
          "event": "digital.analysed"
        }
      ]
    },
    "invalid_type": {
      "priority": 10,
      "description": "Unsupported asset type",
      "given": [
        {
          "field": "asset_type",
          "source": "input",
          "operator": "not_in",
          "value": [
            "cryptocurrency",
            "utility_token",
            "security_token",
            "stablecoin",
            "nft"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "digital.analysis_rejected"
        }
      ],
      "error": "DIGITAL_INVALID_TYPE"
    }
  },
  "errors": [
    {
      "code": "DIGITAL_INVALID_TYPE",
      "status": 400,
      "message": "asset_type must be cryptocurrency, utility_token, security_token, stablecoin, or nft"
    }
  ],
  "events": [
    {
      "name": "digital.analysed",
      "payload": [
        "asset_id",
        "asset_type",
        "consensus_mechanism",
        "risk_profile"
      ]
    },
    {
      "name": "digital.analysis_rejected",
      "payload": [
        "asset_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not treat stablecoins as cash equivalents",
      "why": "De-pegging risk and collateral quality vary widely; algorithmic stablecoins have failed catastrophically"
    },
    {
      "rule": "Do not assume self-custody eliminates counterparty risk",
      "why": "Private-key loss or theft is permanent; operational risk replaces counterparty risk rather than eliminating it"
    },
    {
      "rule": "Do not allocate to unregistered security tokens for regulated mandates",
      "why": "Most jurisdictions classify many tokens as securities; unregistered issuance creates compliance exposure"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/alt-investments/digital/analyse"
    },
    "request": {
      "schema": {
        "asset_id": "string",
        "asset_type": "string",
        "consensus_mechanism": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "asset_id": "string",
          "asset_type": "string",
          "risk_profile": "string"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "DIGITAL_INVALID_TYPE"
        }
      ]
    }
  },
  "related": [
    {
      "feature": "alt-investments-features-categories",
      "type": "required"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_digital_assets_investments",
        "description": "Evaluate digital assets on distributed ledgers using proof-of-work or proof-of-stake consensus — crypto, tokens, stablecoins, NFTs — and their investment features",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "analyse_digital_asset",
          "permission": "autonomous"
        },
        {
          "action": "invalid_type",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "orchestrated",
      "consumes": [
        {
          "capability": "alt_investments_features_categories",
          "from": "alt-investments-features-categories",
          "fallback": "fail"
        }
      ]
    }
  }
}