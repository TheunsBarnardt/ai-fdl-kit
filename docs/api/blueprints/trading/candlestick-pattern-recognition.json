  "anti_patterns": [
    {
      "rule": "Do not use candlestick patterns without trend context",
      "why": "Hammer is only bullish after a downtrend; Hanging Man only bearish after an uptrend — applying them in a ranging market generates random signals"
    },
    {
      "rule": "Do not treat a +100 signal as an immediate entry signal",
      "why": "TA-Lib pattern signals are placed on the completion bar; standard practice is to wait for the NEXT bar's open or confirmation close before entering"
    },
    {
      "rule": "Do not run all 61 patterns at every tick in real-time without caching",
      "why": "Each function call recomputes from startIdx to endIdx; batch across all patterns on bar close to avoid excessive CPU on each tick"
    },
    {
      "rule": "Do not ignore the penetration parameter on Morning Star / Evening Star",
      "why": "Default penetration of 0.3 means the third bar must close 30% into the first bar's body; lowering it generates more (but weaker) signals"
    },
    {
      "rule": "Do not use candlestick signals on synthetic or interpolated price data",
      "why": "Patterns like Doji, Marubozu, and Engulfing rely on exact OHLC relationships — synthesized or gap-filled prices break structural assumptions"
    },
    {
      "rule": "Do not conflate CDLHAMMER and CDLHANGINGMAN (same shape, opposite interpretation)",
      "why": "TA-Lib detects BOTH on a bar with that shape and assigns the correct signal based on the prior trend; if trend detection is wrong, signal polarity is wrong"
    }
  ],
  "extensions": {
    "tech_stack": {
      "language": "C99",
      "bindings": "Java, .NET, Rust, Python",
      "source_repo": "https://github.com/TA-Lib/ta-lib"
    },
    "pattern_count": 61,
    "output_type": "Integer Array (+100 / -100 / 0) — unlike price indicators which return Double Array",
    "body_average_period": "TA-Lib uses TA_CANDLE_AVGPERIOD (typically 14) for internal body/shadow classification",
    "candle_settings": {
      "default_settings": "Based on statistical norms from historical price data; can be tuned per instrument",
      "settings_types": [
        "BodyDoji",
        "BodyLong",
        "BodyShort",
        "BodyVeryLong",
        "ShadowLong",
        "ShadowVeryLong",
        "ShadowShort",
        "ShadowVeryShort",
        "Near",
        "Far",
        "Equal"
      ]
    }
  }
