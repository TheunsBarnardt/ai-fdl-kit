{
  "feature": "touch-input",
  "version": "1.0.0",
  "description": "Multi-touch and gesture input for mobile devices",
  "category": "integration",
  "tags": [
    "integration",
    "godot"
  ],
  "actors": [
    {
      "id": "game_engine",
      "name": "Godot Engine",
      "type": "system"
    }
  ],
  "outcomes": {
    "touch_detection": {
      "given": [
        "Detect touch screen input is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Detect touch screen input completed",
      "priority": 1
    },
    "multi-touch": {
      "given": [
        "Handle multiple simultaneous touches is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Handle multiple simultaneous touches completed",
      "priority": 2
    },
    "pressure_sensitivity": {
      "given": [
        "Read touch pressure if supported is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Read touch pressure if supported completed",
      "priority": 3
    },
    "drag_gestures": {
      "given": [
        "Detect touch drag motion is requested"
      ],
      "then": [
        {
          "action": "transition_state",
          "field": "status",
          "from": "idle",
          "to": "active"
        }
      ],
      "result": "Detect touch drag motion completed",
      "priority": 4
    }
  },
  "rules": {
    "implementation": {
      "description": "Feature implemented in C++ engine core"
    },
    "platform_agnostic": {
      "description": "Works across desktop, web, mobile platforms"
    }
  },
  "related": [],
  "agi": {
    "goals": [
      {
        "id": "reliable_touch_input",
        "description": "Multi-touch and gesture input for mobile devices",
        "success_metrics": [
          {
            "metric": "success_rate",
            "target": ">= 99.5%",
            "measurement": "Successful operations divided by total attempts"
          },
          {
            "metric": "error_recovery_rate",
            "target": ">= 95%",
            "measurement": "Errors that auto-recover without manual intervention"
          }
        ],
        "constraints": [
          {
            "type": "availability",
            "description": "Must degrade gracefully when dependencies are unavailable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised"
    },
    "safety": {
      "action_permissions": [
        {
          "action": "touch_detection",
          "permission": "autonomous"
        },
        {
          "action": "multi-touch",
          "permission": "autonomous"
        },
        {
          "action": "pressure_sensitivity",
          "permission": "autonomous"
        },
        {
          "action": "drag_gestures",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "reliability",
        "over": "throughput",
        "reason": "integration failures can cascade across systems"
      }
    ]
  },
  "extensions": {
    "tech_stack": {
      "language": "C++",
      "runtime": "Godot 4.x"
    }
  }
}