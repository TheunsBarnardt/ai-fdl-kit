{
  "feature": "mtm-bond-valuation",
  "version": "1.0.0",
  "description": "Mark-to-market bond valuation framework for daily portfolio accounting.\nEstablishes pricing hierarchy, accrued interest conventions, and rounding rules.\n",
  "category": "trading",
  "tags": [
    "bonds",
    "valuation",
    "mark-to-market",
    "mtm",
    "portfolio",
    "accounting"
  ],
  "fields": [
    {
      "name": "valuation_date",
      "type": "date",
      "required": true,
      "label": "Valuation Date"
    },
    {
      "name": "bond_isin",
      "type": "text",
      "required": true,
      "label": "Bond ISIN"
    },
    {
      "name": "quoted_clean_price",
      "type": "number",
      "required": false,
      "label": "Quoted Clean Price"
    },
    {
      "name": "bid_price",
      "type": "number",
      "required": false,
      "label": "Bid Price"
    },
    {
      "name": "ask_price",
      "type": "number",
      "required": false,
      "label": "Ask Price"
    }
  ],
  "rules": {
    "pricing": {
      "pricing_hierarchy": "1. Recent trade quotes (last N hours)\n2. Bid-ask spread midpoint\n3. Derived from yield curve\n4. Benchmark spread assumption\n5. Previous close price\n",
      "accrued_interest_calculation": "Accrued = (Days_Since_Last_Coupon / 365) × Annual_Coupon\n"
    }
  },
  "outcomes": {
    "bond_valued": {
      "description": "Mark bond-to-market using pricing hierarchy and accrued interest",
      "given": [
        {
          "field": "valuation_date",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "bond_isin",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "set_field",
          "target": "mtm_clean_price",
          "value": "from pricing hierarchy"
        },
        {
          "action": "set_field",
          "target": "accrued_interest",
          "value": "calculated per A/365"
        },
        {
          "action": "set_field",
          "target": "all_in_price",
          "value": "clean_price + accrued_interest"
        },
        {
          "action": "emit_event",
          "event": "bond.mtm.valued",
          "payload": [
            "valuation_date",
            "bond_isin",
            "mtm_clean_price"
          ]
        }
      ],
      "result": "Bond marked-to-market"
    },
    "portfolio_aggregated": {
      "description": "Aggregate daily MTM valuations across portfolio",
      "given": [
        {
          "field": "valuation_date",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "portfolio.mtm.complete",
          "payload": [
            "valuation_date"
          ]
        }
      ],
      "result": "Portfolio MTM valuation completed"
    }
  },
  "errors": [
    {
      "code": "NO_PRICING_DATA",
      "status": 400,
      "message": "No quoted prices available for bond"
    }
  ],
  "related": [
    {
      "feature": "bond-pricing-models",
      "type": "required"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_mtm_bond_valuation",
        "description": "Mark-to-market bond valuation framework for daily portfolio accounting.\nEstablishes pricing hierarchy, accrued interest conventions, and rounding rules.\n",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "bond_valued",
          "permission": "autonomous"
        },
        {
          "action": "portfolio_aggregated",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "request_response",
      "consumes": [
        {
          "capability": "bond_pricing_models",
          "from": "bond-pricing-models",
          "fallback": "fail"
        }
      ]
    }
  }
}