{
  "feature": "multiple-regression-basics-l2",
  "version": "1.0.0",
  "description": "Multiple linear regression — formulate model with multiple independent variables, interpret coefficients and intercept, and validate the six classical OLS assumptions",
  "category": "trading",
  "tags": [
    "quant",
    "multiple-regression",
    "ols",
    "cfa-level-2"
  ],
  "aliases": [
    "multiple-linear-regression-l2",
    "mlr-assumptions-l2",
    "mlr-coefficient-interpretation",
    "ols-multivariate",
    "regression-mlr-basics"
  ],
  "actors": [
    {
      "id": "regression_engine_l2",
      "name": "Multiple Regression Engine",
      "type": "system"
    }
  ],
  "fields": [
    {
      "name": "model_id",
      "type": "text",
      "required": true,
      "label": "Model identifier"
    },
    {
      "name": "dependent_variable",
      "type": "text",
      "required": true,
      "label": "Y variable name"
    },
    {
      "name": "independent_variables",
      "type": "json",
      "required": true,
      "label": "Array of X variable names"
    }
  ],
  "rules": {
    "model_form": {
      "equation": "Y_i = b0 + b1*X1_i + b2*X2_i + ... + bk*Xk_i + e_i",
      "coefficient_interpretation": "Slope b_j = expected change in Y for one-unit change in X_j holding all other Xs constant"
    },
    "six_assumptions": {
      "linearity": "Relationship between Y and Xs is linear in coefficients",
      "independence": "Independent variables are not random and no exact linear relation between two or more Xs",
      "homoskedasticity": "Variance of residuals is constant across observations",
      "independence_of_errors": "Residuals are uncorrelated across observations",
      "normality": "Residuals are normally distributed",
      "no_multicollinearity": "Independent variables are not perfectly correlated"
    },
    "uses": {
      "explanation": "Identify which Xs explain Y",
      "forecasting": "Predict Y from new X values",
      "estimation": "Quantify economic relationships"
    },
    "validation": {
      "model_required": "model_id present",
      "variables_required": "dependent_variable and independent_variables present"
    }
  },
  "outcomes": {
    "fit_mlr": {
      "priority": 1,
      "description": "Fit multiple linear regression model",
      "given": [
        {
          "field": "model_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "dependent_variable",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "independent_variables",
          "source": "input",
          "operator": "exists"
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "regression_engine_l2"
        },
        {
          "action": "emit_event",
          "event": "mlr.fitted"
        }
      ]
    }
  },
  "errors": [
    {
      "code": "MLR_MISSING_INPUTS",
      "status": 400,
      "message": "model_id, dependent_variable and independent_variables required"
    }
  ],
  "events": [
    {
      "name": "mlr.fitted",
      "payload": [
        "model_id",
        "coefficients",
        "r_squared",
        "adjusted_r_squared",
        "n_observations"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not interpret slope coefficients in isolation",
      "why": "Each slope is a partial effect holding other Xs constant; ignoring multicollinearity inflates standard errors and misleads inference"
    },
    {
      "rule": "Do not include perfectly collinear regressors",
      "why": "Violates assumption of no exact linear relationship; OLS cannot invert the design matrix"
    },
    {
      "rule": "Do not skip residual diagnostics after fitting",
      "why": "All six assumptions must hold for inference; assumption violations make t/F tests unreliable even if R² looks high"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/quant/mlr/fit"
    },
    "request": {
      "schema": {
        "model_id": "string",
        "dependent_variable": "string",
        "independent_variables": "array"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "model_id": "string",
          "coefficients": "object",
          "r_squared": "number"
        }
      }
    }
  },
  "related": [
    {
      "feature": "simple-linear-regression-ols",
      "type": "required"
    },
    {
      "feature": "regression-assumptions",
      "type": "required"
    },
    {
      "feature": "multiple-regression-evaluation-l2",
      "type": "recommended"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_multiple_regression_basics_l2",
        "description": "Multiple linear regression — formulate model with multiple independent variables, interpret coefficients and intercept, and validate the six classical OLS assumptions",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "fit_mlr",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "orchestrated",
      "consumes": [
        {
          "capability": "simple_linear_regression_ols",
          "from": "simple-linear-regression-ols",
          "fallback": "fail"
        },
        {
          "capability": "regression_assumptions",
          "from": "regression-assumptions",
          "fallback": "fail"
        }
      ]
    }
  }
}