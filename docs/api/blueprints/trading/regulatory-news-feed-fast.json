{
  "feature": "regulatory-news-feed-fast",
  "version": "1.0.0",
  "description": "Real-time regulatory news via FAST UDP multicast with TCP replay.",
  "category": "trading",
  "fields": [
    {
      "name": "news_id",
      "type": "text",
      "required": true,
      "label": "News ID"
    }
  ],
  "rules": {
    "delivery": {
      "multicast": "Real-time UDP multicast feeds",
      "replay": "TCP replay channel"
    }
  },
  "outcomes": {
    "logon_successful": {
      "priority": 1,
      "description": "Client authenticates",
      "given": [
        {
          "field": "credentials_valid",
          "source": "request",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "session.established",
          "payload": [
            "user_id"
          ]
        }
      ],
      "result": "Session active"
    },
    "news_published": {
      "priority": 2,
      "description": "News published",
      "given": [
        {
          "field": "news_available",
          "source": "system",
          "operator": "eq",
          "value": true
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "news.published",
          "payload": [
            "news_id"
          ]
        }
      ],
      "result": "News disseminated"
    }
  },
  "errors": [
    {
      "code": "AUTH_FAILED",
      "status": 401,
      "message": "Authentication failed"
    }
  ],
  "events": [
    {
      "name": "session.established",
      "payload": [
        "user_id"
      ]
    },
    {
      "name": "news.published",
      "payload": [
        "news_id"
      ]
    }
  ],
  "actors": [
    {
      "id": "client",
      "name": "Client",
      "type": "human",
      "description": "Regulatory news subscriber"
    }
  ],
  "related": [
    {
      "feature": "market-data-feed-fast-udp",
      "type": "extends",
      "reason": "Inherits shared FAST UDP multicast and TCP recovery/replay specification"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_regulatory_news_feed_fast",
        "description": "Real-time regulatory news via FAST UDP multicast with TCP replay.",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "logon_successful",
          "permission": "autonomous"
        },
        {
          "action": "news_published",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    }
  }
}