{
  "feature": "cfa-code-of-ethics",
  "version": "1.0.0",
  "description": "State the CFA Institute Code of Ethics and its six principles, and describe the organization of the seven Standards of Professional Conduct they govern",
  "category": "trading",
  "tags": [
    "ethics",
    "cfa-code",
    "standards-of-conduct",
    "cfa-level-1"
  ],
  "aliases": [
    "cfa-institute-code",
    "six-principles-code",
    "standards-of-professional-conduct",
    "code-and-standards-overview"
  ],
  "actors": [
    {
      "id": "code_reviewer",
      "name": "Code Reviewer",
      "type": "human"
    }
  ],
  "fields": [
    {
      "name": "review_id",
      "type": "text",
      "required": true,
      "label": "Code review identifier"
    },
    {
      "name": "member_type",
      "type": "select",
      "required": true,
      "label": "member | candidate"
    }
  ],
  "rules": {
    "code_principles": {
      "one": "Act with integrity, competence, diligence, respect, and in ethical manner with clients, prospective clients, colleagues, and employers",
      "two": "Place integrity of the investment profession and interests of clients above own interests",
      "three": "Use reasonable care and exercise independent professional judgement when conducting analysis, making recommendations, taking actions",
      "four": "Practice and encourage others to practice in a professional and ethical manner",
      "five": "Promote integrity and viability of the global capital markets for benefit of society",
      "six": "Maintain and improve professional competence and strive to maintain and improve competence of other investment professionals"
    },
    "standards_organization": {
      "i": "Professionalism",
      "ii": "Integrity of Capital Markets",
      "iii": "Duties to Clients",
      "iv": "Duties to Employers",
      "v": "Investment Analysis, Recommendations, and Actions",
      "vi": "Conflicts of Interest",
      "vii": "Responsibilities as a CFA Institute Member or Candidate"
    },
    "applicability": {
      "who": "CFA Institute members, charter holders, candidates",
      "scope": "All professional activities regardless of jurisdiction"
    },
    "validation": {
      "review_required": "review_id present",
      "valid_member": "member_type in [member, candidate]"
    }
  },
  "outcomes": {
    "review_code_compliance": {
      "priority": 1,
      "description": "Review conduct against Code",
      "given": [
        {
          "field": "review_id",
          "source": "input",
          "operator": "exists"
        },
        {
          "field": "member_type",
          "source": "input",
          "operator": "in",
          "value": [
            "member",
            "candidate"
          ]
        }
      ],
      "then": [
        {
          "action": "call_service",
          "target": "code_reviewer"
        },
        {
          "action": "emit_event",
          "event": "code.reviewed"
        }
      ]
    },
    "invalid_member": {
      "priority": 10,
      "description": "Unsupported member type",
      "given": [
        {
          "field": "member_type",
          "source": "input",
          "operator": "not_in",
          "value": [
            "member",
            "candidate"
          ]
        }
      ],
      "then": [
        {
          "action": "emit_event",
          "event": "code.review_rejected"
        }
      ],
      "error": "CODE_INVALID_MEMBER"
    }
  },
  "errors": [
    {
      "code": "CODE_INVALID_MEMBER",
      "status": 400,
      "message": "member_type must be member or candidate"
    }
  ],
  "events": [
    {
      "name": "code.reviewed",
      "payload": [
        "review_id",
        "member_type",
        "principles_breached",
        "standards_breached"
      ]
    },
    {
      "name": "code.review_rejected",
      "payload": [
        "review_id",
        "reason_code"
      ]
    }
  ],
  "anti_patterns": [
    {
      "rule": "Do not treat CFA Code as advisory suggestions",
      "why": "Violations lead to sanctions including suspension of charter; breach is a career event"
    },
    {
      "rule": "Do not claim partial CFA Code compliance",
      "why": "Code applies in full to all professional activities; selective application is itself a breach"
    },
    {
      "rule": "Do not use local law compliance as defence against Code breach",
      "why": "Code applies strictest of local law, employer policy, and CFA Standards — the highest standard prevails"
    }
  ],
  "api": {
    "http": {
      "method": "POST",
      "path": "/ethics/code/review"
    },
    "request": {
      "schema": {
        "review_id": "string",
        "member_type": "string"
      }
    },
    "response": {
      "success": {
        "status": 200,
        "schema": {
          "review_id": "string",
          "compliant": "boolean"
        }
      },
      "errors": [
        {
          "status": 400,
          "error_code": "CODE_INVALID_MEMBER"
        }
      ]
    }
  },
  "related": [
    {
      "feature": "ethics-framework-investment",
      "type": "required"
    },
    {
      "feature": "standard-i-professionalism",
      "type": "required"
    },
    {
      "feature": "standard-ii-integrity-capital-markets",
      "type": "required"
    },
    {
      "feature": "standard-iii-duties-to-clients",
      "type": "required"
    }
  ],
  "agi": {
    "goals": [
      {
        "id": "reliable_cfa_code_of_ethics",
        "description": "State the CFA Institute Code of Ethics and its six principles, and describe the organization of the seven Standards of Professional Conduct they govern",
        "success_metrics": [
          {
            "metric": "policy_violation_rate",
            "target": "0%",
            "measurement": "Operations that violate defined policies"
          },
          {
            "metric": "audit_completeness",
            "target": "100%",
            "measurement": "All decisions have complete audit trails"
          }
        ],
        "constraints": [
          {
            "type": "regulatory",
            "description": "All operations must be auditable and traceable",
            "negotiable": false
          }
        ]
      }
    ],
    "autonomy": {
      "level": "supervised",
      "human_checkpoints": [
        "before making irreversible changes"
      ],
      "escalation_triggers": [
        "error_rate > 5",
        "consecutive_failures > 3"
      ]
    },
    "safety": {
      "action_permissions": [
        {
          "action": "review_code_compliance",
          "permission": "autonomous"
        },
        {
          "action": "invalid_member",
          "permission": "autonomous"
        }
      ]
    },
    "tradeoffs": [
      {
        "prefer": "accuracy",
        "over": "latency",
        "reason": "trading operations require precise execution and full audit trails"
      }
    ],
    "verification": {
      "invariants": [
        "error messages never expose internal system details"
      ]
    },
    "coordination": {
      "protocol": "orchestrated",
      "consumes": [
        {
          "capability": "ethics_framework_investment",
          "from": "ethics-framework-investment",
          "fallback": "fail"
        },
        {
          "capability": "standard_i_professionalism",
          "from": "standard-i-professionalism",
          "fallback": "fail"
        },
        {
          "capability": "standard_ii_integrity_capital_markets",
          "from": "standard-ii-integrity-capital-markets",
          "fallback": "fail"
        },
        {
          "capability": "standard_iii_duties_to_clients",
          "from": "standard-iii-duties-to-clients",
          "fallback": "fail"
        }
      ]
    }
  }
}